---
import { t } from '../lib/i18n';
import type { Locale } from '../lib/i18n';

interface BoardMember {
  name: string;
  initials?: string;
  role_de: string;
  role_en: string;
  tier: 'president' | 'vice' | 'ressort';
  tier_order: number;
  branch?: 'left' | 'right' | 'bottom';
  photo?: string;
}

interface Props {
  members: BoardMember[];
  locale: Locale;
}

const { members, locale } = Astro.props;

const president = members.find(m => m.tier === 'president');
const vice = members.find(m => m.tier === 'vice');
const ressorts = members.filter(m => m.tier === 'ressort').sort((a, b) => a.tier_order - b.tier_order);
const leftRessorts = ressorts.filter(m => m.branch === 'left');
const rightRessorts = ressorts.filter(m => m.branch === 'right' || (!m.branch));
const bottomRessorts = ressorts.filter(m => m.branch === 'bottom');

const initials = (m: BoardMember) => m.initials || m.name.split(' ').map(w => w[0]).join('').toUpperCase();
const role = (m: BoardMember) => locale === 'en' ? m.role_en : m.role_de;
const photoSrc = (m: BoardMember) => m.photo ? `/images/board/${m.photo}` : null;
const nameParts = (m: BoardMember) => {
  const idx = m.name.indexOf(' ');
  return idx === -1 ? { first: m.name, last: '' } : { first: m.name.slice(0, idx), last: m.name.slice(idx + 1) };
};
---
<div class="org-chart">
  {president && (
    <div class="org-tier org-tier-president">
      <div class="org-card">
        {photoSrc(president)
          ? <img class="org-photo" src={photoSrc(president)!} alt={president.name} loading="lazy" />
          : <div class="org-avatar">{initials(president)}</div>}
        <div class="org-role">{role(president)}</div>
        <div class="org-name"><span>{nameParts(president).first}</span><span>{nameParts(president).last}</span></div>
      </div>
    </div>
  )}

  {vice && (
    <div class="org-tier org-tier-vice">
      <div class="org-card">
        {photoSrc(vice)
          ? <img class="org-photo" src={photoSrc(vice)!} alt={vice.name} loading="lazy" />
          : <div class="org-avatar">{initials(vice)}</div>}
        <div class="org-role">{role(vice)}</div>
        <div class="org-name"><span>{nameParts(vice).first}</span><span>{nameParts(vice).last}</span></div>
      </div>
    </div>
  )}

  {ressorts.length > 0 && (
    <div class="org-tier org-tier-ressorts" data-count={ressorts.length - bottomRessorts.length}>
      <div class="org-branch org-branch-left">
        {leftRessorts.map(m => (
          <div class="org-card">
            {photoSrc(m)
              ? <img class="org-photo" src={photoSrc(m)!} alt={m.name} loading="lazy" />
              : <div class="org-avatar">{initials(m)}</div>}
            <div class="org-role">{role(m)}</div>
            <div class="org-name"><span>{nameParts(m).first}</span><span>{nameParts(m).last}</span></div>
          </div>
        ))}
      </div>
      <div class="org-branch org-branch-right">
        {rightRessorts.map(m => (
          <div class="org-card">
            {photoSrc(m)
              ? <img class="org-photo" src={photoSrc(m)!} alt={m.name} loading="lazy" />
              : <div class="org-avatar">{initials(m)}</div>}
            <div class="org-role">{role(m)}</div>
            <div class="org-name"><span>{nameParts(m).first}</span><span>{nameParts(m).last}</span></div>
          </div>
        ))}
      </div>
    </div>
  )}

  {bottomRessorts.length > 0 && (
    <div class="org-tier org-tier-bottom">
      {bottomRessorts.map(m => (
        <div class="org-card">
          {photoSrc(m)
            ? <img class="org-photo" src={photoSrc(m)!} alt={m.name} loading="lazy" />
            : <div class="org-avatar">{initials(m)}</div>}
          <div class="org-role">{role(m)}</div>
          <div class="org-name"><span>{nameParts(m).first}</span><span>{nameParts(m).last}</span></div>
        </div>
      ))}
    </div>
  )}
</div>

<style>
  .org-chart {
    --org-line-color: var(--border, rgba(0, 0, 0, 0.15));
    --org-line-width: 2px;
    --org-card-bg: var(--kscw-blue);
    --org-card-color: #fff;
    --org-gap-v: var(--space-lg);
    --org-gap-h: var(--space-md);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--org-gap-v);
    width: 100%;
  }

  .org-tier {
    display: flex;
    justify-content: center;
    position: relative;
  }

  .org-tier-ressorts {
    display: grid;
    grid-template-columns: repeat(var(--ressort-count, 5), 200px);
    justify-content: center;
    gap: var(--org-gap-h);
    width: 100%;
    max-width: 1100px;
  }
  .org-tier-ressorts[data-count="1"] { --ressort-count: 1; }
  .org-tier-ressorts[data-count="2"] { --ressort-count: 2; }
  .org-tier-ressorts[data-count="3"] { --ressort-count: 3; }
  .org-tier-ressorts[data-count="4"] { --ressort-count: 4; }
  .org-tier-ressorts[data-count="5"] { --ressort-count: 5; }
  .org-tier-ressorts[data-count="6"] { --ressort-count: 6; }

  /* Desktop: the branch wrappers are "transparent" — cards become direct
     grid children of .org-tier-ressorts so the 5-column row works. */
  .org-branch {
    display: contents;
  }

  .org-card {
    background: var(--org-card-bg);
    color: var(--org-card-color);
    padding: var(--space-md) var(--space-lg);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    text-align: center;
    width: 200px;
    min-width: 0;
    min-height: 240px;
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
  }
  /* Grid stretches all ressort cards to the tallest one's height; push the
     name to the bottom of its card so all names align on the same baseline
     regardless of how many lines the role label wraps to. */
  .org-tier-ressorts .org-name {
    margin-top: auto;
  }

  .org-avatar,
  .org-photo {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    margin-bottom: 0.5rem;
  }
  .org-avatar {
    background: rgba(255, 255, 255, 0.18);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.04em;
  }
  .org-photo {
    object-fit: cover;
    border: 2px solid rgba(255, 255, 255, 0.4);
  }

  .org-role {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 0.85;
    line-height: 1.25;
  }

  .org-name {
    font-size: var(--text-base);
    font-weight: 600;
    line-height: 1.25;
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-top: 0.5rem;
  }
  .org-name span:empty { display: none; }

  .org-status {
    font-size: var(--text-xs);
    opacity: 0.8;
    font-style: italic;
  }

  /* ── Connectors (desktop tree) ───────────────────────────── */
  /* Vertical drop from President → Vice */
  .org-tier-vice::before {
    content: "";
    position: absolute;
    top: calc(var(--org-gap-v) * -1);
    left: 50%;
    width: var(--org-line-width);
    height: var(--org-gap-v);
    background: var(--org-line-color);
    transform: translateX(-50%);
    z-index: 1;
  }

  /* Vertical drop from Vice → horizontal trunk */
  .org-tier-ressorts::before {
    content: "";
    position: absolute;
    top: calc(var(--org-gap-v) * -1);
    left: 50%;
    width: var(--org-line-width);
    height: calc(var(--org-gap-v) / 2);
    background: var(--org-line-color);
    transform: translateX(-50%);
    z-index: 1;
  }

  /* Horizontal trunk above ressorts: each card draws its own segment,
     extended into the side gaps by half so neighbours' segments meet
     without visible breaks. First/last child stop at their own centre. */
  .org-tier-ressorts .org-card::before {
    content: "";
    position: absolute;
    top: calc(var(--org-gap-v) / -2);
    left: calc(var(--org-gap-h) / -2);
    right: calc(var(--org-gap-h) / -2);
    height: var(--org-line-width);
    background: var(--org-line-color);
    z-index: 1;
  }
  .org-tier-ressorts .org-card:first-child::before {
    left: 50%;
    right: calc(var(--org-gap-h) / -2);
  }
  .org-tier-ressorts .org-card:last-child::before {
    left: calc(var(--org-gap-h) / -2);
    right: 50%;
  }

  /* Bottom tier (Beisitz): single card centered, drop from above */
  .org-tier-bottom {
    position: relative;
  }
  .org-tier-bottom::before {
    content: "";
    position: absolute;
    top: calc(var(--org-gap-v) * -1);
    left: 50%;
    width: var(--org-line-width);
    height: var(--org-gap-v);
    background: var(--org-line-color);
    transform: translateX(-50%);
    z-index: 1;
  }

  /* Vertical drop from trunk → each ressort card */
  .org-tier-ressorts .org-card::after {
    content: "";
    position: absolute;
    top: calc(var(--org-gap-v) / -2);
    left: 50%;
    width: var(--org-line-width);
    height: calc(var(--org-gap-v) / 2);
    background: var(--org-line-color);
    transform: translateX(-50%);
    z-index: 1;
  }

  /* ── Mobile: vertical tree with two branches ──
     President → Vice → splits into two columns (left = TKs, right = others).
     Each branch is a vertical stack. Connector lines redrawn for the
     mobile shape (T-junction off Vice). */
  @media (max-width: 900px) {
    .org-chart {
      --org-gap-v: var(--space-md);
      --org-gap-h: var(--space-md);
      max-width: 480px;
    }

    /* Smaller everything; uniform card width + height for all cards */
    .org-card {
      padding: var(--space-sm) var(--space-md);
      width: 160px;
      min-width: 0;
      max-width: none;
      min-height: 200px;
      gap: 0.15rem;
    }
    .org-avatar,
    .org-photo {
      width: 44px;
      height: 44px;
      margin-bottom: 0.3rem;
    }
    .org-avatar { font-size: 0.9rem; }
    .org-role { font-size: 0.65rem; }
    .org-name { font-size: var(--text-sm); }

    /* Two-column ressorts grid; both branches stretch to the tier's
       height, cards within each branch distribute evenly so left/right
       sides feel balanced and connector stubs align with the spine. */
    .org-tier-ressorts {
      grid-template-columns: repeat(2, 160px);
      justify-content: center;
      gap: var(--space-md);
      align-items: start;
    }
    .org-branch {
      display: flex;
      flex-direction: column;
      gap: var(--space-md);
    }
    .org-tier-ressorts .org-card { height: auto; }
    .org-tier-ressorts .org-name { margin-top: 0; }


    /* Fishbone layout: a single vertical spine runs down the center of
       the ressorts tier from top (Vice connector) to bottom. Each card
       attaches to the spine via a short horizontal stub from its inner
       edge to the center line. */
    .org-tier-ressorts .org-card::before,
    .org-tier-ressorts .org-card::after {
      display: none;
    }
    /* Central vertical spine spanning the full height of the ressorts */
    .org-tier-ressorts::before {
      content: "";
      position: absolute;
      top: calc(var(--org-gap-v) * -1);
      bottom: 0;
      left: 50%;
      width: var(--org-line-width);
      height: auto;
      background: var(--org-line-color);
      transform: translateX(calc(var(--org-line-width) / -2));
      z-index: 1;
    }
    .org-tier-ressorts::after { display: none; }

    .org-branch { position: relative; }
    .org-branch::before { display: none; }

    /* Horizontal stub from each card to the central spine.
       Left branch cards: stub on the right side, reaching to center.
       Right branch cards: stub on the left side, reaching to center. */
    .org-tier-ressorts .org-card {
      position: relative;
    }
    .org-branch-left .org-card::after {
      content: "";
      display: block;
      position: absolute;
      top: 50%;
      left: 100%;
      width: var(--space-md);
      height: var(--org-line-width);
      background: var(--org-line-color);
      transform: translateY(-50%);
      z-index: 1;
    }
    .org-branch-right .org-card::after {
      content: "";
      display: block;
      position: absolute;
      top: 50%;
      left: auto;
      right: 100%;
      width: var(--space-md);
      height: var(--org-line-width);
      background: var(--org-line-color);
      transform: translateY(-50%);
      z-index: 1;
    }
  }

  @media (max-width: 380px) {
    /* Very narrow: shrink avatar + tighter padding */
    .org-avatar,
    .org-photo { width: 40px; height: 40px; }
    .org-card { padding: 0.5rem 0.6rem; }
  }
</style>
