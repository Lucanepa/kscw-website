---
import { t } from '../lib/i18n';
import type { Locale } from '../lib/i18n';

interface BoardMember {
  name: string;
  initials?: string;
  role_de: string;
  role_en: string;
  tier: 'president' | 'vice' | 'ressort';
  tier_order: number;
  photo?: string;
}

interface Props {
  members: BoardMember[];
  locale: Locale;
}

const { members, locale } = Astro.props;

const president = members.find(m => m.tier === 'president');
const vice = members.find(m => m.tier === 'vice');
const ressorts = members.filter(m => m.tier === 'ressort').sort((a, b) => a.tier_order - b.tier_order);

const initials = (m: BoardMember) => m.initials || m.name.split(' ').map(w => w[0]).join('').toUpperCase();
const role = (m: BoardMember) => locale === 'en' ? m.role_en : m.role_de;
const photoSrc = (m: BoardMember) => m.photo ? `/images/board/${m.photo}` : null;
---
<div class="org-chart">
  {president && (
    <div class="org-tier org-tier-president">
      <div class="org-card">
        {photoSrc(president)
          ? <img class="org-photo" src={photoSrc(president)!} alt={president.name} loading="lazy" />
          : <div class="org-avatar">{initials(president)}</div>}
        <div class="org-role">{role(president)}</div>
        <div class="org-name">{president.name}</div>
      </div>
    </div>
  )}

  {vice && (
    <div class="org-tier org-tier-vice">
      <div class="org-card">
        {photoSrc(vice)
          ? <img class="org-photo" src={photoSrc(vice)!} alt={vice.name} loading="lazy" />
          : <div class="org-avatar">{initials(vice)}</div>}
        <div class="org-role">{role(vice)}</div>
        <div class="org-name">{vice.name}</div>
      </div>
    </div>
  )}

  {ressorts.length > 0 && (
    <div class="org-tier org-tier-ressorts" data-count={ressorts.length}>
      {ressorts.map(m => (
        <div class="org-card">
          {photoSrc(m)
            ? <img class="org-photo" src={photoSrc(m)!} alt={m.name} loading="lazy" />
            : <div class="org-avatar">{initials(m)}</div>}
          <div class="org-role">{role(m)}</div>
          <div class="org-name">{m.name}</div>
        </div>
      ))}
    </div>
  )}
</div>

<style>
  .org-chart {
    --org-line-color: var(--border, rgba(0, 0, 0, 0.15));
    --org-line-width: 2px;
    --org-card-bg: var(--kscw-blue);
    --org-card-color: #fff;
    --org-gap-v: var(--space-lg);
    --org-gap-h: var(--space-md);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--org-gap-v);
    width: 100%;
  }

  .org-tier {
    display: flex;
    justify-content: center;
    position: relative;
  }

  .org-tier-ressorts {
    display: grid;
    grid-template-columns: repeat(var(--ressort-count, 5), minmax(0, 1fr));
    gap: var(--org-gap-h);
    width: 100%;
    max-width: 1100px;
  }
  .org-tier-ressorts[data-count="1"] { --ressort-count: 1; }
  .org-tier-ressorts[data-count="2"] { --ressort-count: 2; }
  .org-tier-ressorts[data-count="3"] { --ressort-count: 3; }
  .org-tier-ressorts[data-count="4"] { --ressort-count: 4; }
  .org-tier-ressorts[data-count="5"] { --ressort-count: 5; }
  .org-tier-ressorts[data-count="6"] { --ressort-count: 6; }

  .org-card {
    background: var(--org-card-bg);
    color: var(--org-card-color);
    padding: var(--space-md) var(--space-lg);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    text-align: center;
    min-width: 200px;
    max-width: 260px;
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }
  .org-tier-ressorts .org-card {
    min-width: 0;
    max-width: none;
    height: 100%;
  }
  /* Grid stretches all ressort cards to the tallest one's height; push the
     name to the bottom of its card so all names align on the same baseline
     regardless of how many lines the role label wraps to. */
  .org-tier-ressorts .org-name {
    margin-top: auto;
  }

  .org-avatar,
  .org-photo {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    margin-bottom: 0.5rem;
  }
  .org-avatar {
    background: rgba(255, 255, 255, 0.18);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.04em;
  }
  .org-photo {
    object-fit: cover;
    border: 2px solid rgba(255, 255, 255, 0.4);
  }

  .org-role {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 0.85;
    line-height: 1.25;
  }

  .org-name {
    font-size: var(--text-base);
    font-weight: 600;
    line-height: 1.25;
  }

  .org-status {
    font-size: var(--text-xs);
    opacity: 0.8;
    font-style: italic;
  }

  /* ── Connectors (desktop tree) ───────────────────────────── */
  /* Vertical drop from President → Vice */
  .org-tier-vice::before {
    content: "";
    position: absolute;
    top: calc(var(--org-gap-v) * -1);
    left: 50%;
    width: var(--org-line-width);
    height: var(--org-gap-v);
    background: var(--org-line-color);
    transform: translateX(-50%);
    z-index: 1;
  }

  /* Vertical drop from Vice → horizontal trunk */
  .org-tier-ressorts::before {
    content: "";
    position: absolute;
    top: calc(var(--org-gap-v) * -1);
    left: 50%;
    width: var(--org-line-width);
    height: calc(var(--org-gap-v) / 2);
    background: var(--org-line-color);
    transform: translateX(-50%);
    z-index: 1;
  }

  /* Horizontal trunk above ressorts: each card draws its own segment,
     extended into the side gaps by half so neighbours' segments meet
     without visible breaks. First/last child stop at their own centre. */
  .org-tier-ressorts .org-card::before {
    content: "";
    position: absolute;
    top: calc(var(--org-gap-v) / -2);
    left: calc(var(--org-gap-h) / -2);
    right: calc(var(--org-gap-h) / -2);
    height: var(--org-line-width);
    background: var(--org-line-color);
    z-index: 1;
  }
  .org-tier-ressorts .org-card:first-child::before {
    left: 50%;
    right: calc(var(--org-gap-h) / -2);
  }
  .org-tier-ressorts .org-card:last-child::before {
    left: calc(var(--org-gap-h) / -2);
    right: 50%;
  }

  /* Vertical drop from trunk → each ressort card */
  .org-tier-ressorts .org-card::after {
    content: "";
    position: absolute;
    top: calc(var(--org-gap-v) / -2);
    left: 50%;
    width: var(--org-line-width);
    height: calc(var(--org-gap-v) / 2);
    background: var(--org-line-color);
    transform: translateX(-50%);
    z-index: 1;
  }

  /* ── Mobile: drop the org-chart visualization, present compactly ──
     Below 900px the hierarchy is no longer drawn (single-column tree
     would be a long scroll). President + Vice each occupy a full-width
     compact card; the 5 ressorts collapse into a 2-column grid. */
  @media (max-width: 900px) {
    .org-chart {
      --org-gap-v: var(--space-md);
      max-width: 520px;
    }
    /* Drop all connector lines on mobile */
    .org-tier-vice::before,
    .org-tier-ressorts::before,
    .org-tier-ressorts .org-card::before,
    .org-tier-ressorts .org-card::after {
      display: none;
    }
    /* Compact cards: smaller avatar, tighter padding */
    .org-card {
      padding: var(--space-sm) var(--space-md);
      min-width: 0;
      max-width: none;
      width: 100%;
    }
    .org-avatar,
    .org-photo {
      width: 48px;
      height: 48px;
      margin-bottom: 0.375rem;
    }
    .org-avatar { font-size: 1rem; }
    .org-tier-president .org-card,
    .org-tier-vice .org-card {
      width: 100%;
    }
    /* Ressorts as 2-column grid */
    .org-tier-ressorts {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-md);
    }
    .org-tier-ressorts .org-name {
      font-size: var(--text-sm);
    }
  }

  @media (max-width: 420px) {
    /* Very narrow phones: ressorts go single-column */
    .org-tier-ressorts { grid-template-columns: 1fr; }
  }
</style>
