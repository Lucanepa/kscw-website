                </div>
              </div>
              <div class="dropdown-divider"></div>
              <a href={l(locale === 'de' ? '/volleyball/reglemente' : '/volleyball/regulations')} class="dropdown-link">{t(locale, 'navRegulations')}</a>
            </div>
          </div>

          <div class="nav-item">
