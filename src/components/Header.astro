---
import { t, getAlternateUrl } from '../lib/i18n';
import type { Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const otherLocale = locale === 'de' ? 'en' : 'de';
const altUrl = getAlternateUrl(Astro.url);

// Helper to prefix locale
const l = (path: string) => `/${locale}${path}`;

// Build the alternate path for language toggle
const currentPath = Astro.url.pathname;
const dePath = currentPath.replace(`/en/`, `/de/`).replace(/^\/en$/, '/de');
const enPath = currentPath.replace(`/de/`, `/en/`).replace(/^\/de$/, '/en');
---
  <header class="site-header">
    <div class="container">
      <nav class="nav-inner">
        <a href={l('/')} class="nav-logo">
          <img src="/images/kscw_weiss.png" alt="KSC Wiedikon">
          <span>KSC Wiedikon</span>
        </a>

        <!-- Desktop Navigation -->
        <div class="nav-menu">
          <div class="nav-item">
            <button type="button" class="nav-link">
              <span>{t(locale, 'navClub')}</span>
              <svg class="chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
            </button>
            <div class="nav-dropdown">
              <a href={l('/club/ueber-uns')} class="dropdown-link">{t(locale, 'navAbout')}</a>
              <a href={l('/club/vorstand')} class="dropdown-link">{t(locale, 'navBoard')}</a>
              <a href={l('/club/kontakt')} class="dropdown-link">{t(locale, 'navContact')}</a>
            </div>
          </div>

          <div class="nav-item">
            <button type="button" class="nav-link">
              <span>{t(locale, 'navVolleyball')}</span>
              <svg class="chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
