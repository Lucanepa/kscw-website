        <a href="https://wiedisync.kscw.ch" class="nav-link btn btn-gold btn-sm" target="_blank" rel="noopener"><i data-lucide="lock" style="width:14px;height:14px;"></i> Wiedisync</a>
        <div class="lang-toggle" role="radiogroup" aria-label="Language">
          <a href={locale === 'de' ? currentPath : dePath} class={`lang-btn ${locale === 'de' ? 'active' : ''}`} aria-label="Deutsch">DE</a>
          <span class="lang-sep">|</span>
          <a href={locale === 'en' ? currentPath : enPath} class={`lang-btn ${locale === 'en' ? 'active' : ''}`} aria-label="English">EN</a>
        </div>
        </div>

        <button class="nav-hamburger" aria-label={t(locale, 'navOpenMenu')}>
          <div class="hamburger-icon">
            <span></span>
            <span></span>
            <span></span>
          </div>
        </button>
      </nav>
    </div>

    <!-- Mobile Navigation -->
    <div class="mobile-nav">
      <div class="lang-toggle mobile-lang-toggle" role="radiogroup" aria-label="Language">
