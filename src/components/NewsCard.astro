---
interface Props {
  title: string;
  excerpt: string;
  date: string;
  category: 'club' | 'volleyball' | 'basketball';
}

const { title, excerpt, date, category } = Astro.props;

const badgeClass = category === 'volleyball' ? 'badge badge-blue'
  : category === 'basketball' ? 'badge badge-gold'
  : 'badge';

const badgeLabel = category === 'volleyball' ? 'Volleyball'
  : category === 'basketball' ? 'Basketball'
  : 'Club';
---
<article class="card news-card fade-in">
  <div class="card-img-placeholder">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="width:48px;height:48px;opacity:0.3;">
      <path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2" />
      <line x1="18" y1="2" x2="18" y2="22" />
      <line x1="10" y1="6" x2="14" y2="6" />
      <line x1="10" y1="10" x2="14" y2="10" />
      <line x1="10" y1="14" x2="14" y2="14" />
    </svg>
  </div>
  <div class="card-body">
    <div class="flex items-center gap-sm mb-md">
      <span class="news-date">{date}</span>
      <span class={badgeClass}>{badgeLabel}</span>
    </div>
    <h3>{title}</h3>
    <p class="news-excerpt">{excerpt}</p>
  </div>
</article>
