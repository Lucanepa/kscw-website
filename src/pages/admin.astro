---
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title>KSCW Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="icon" href="/images/kscw_trio.png" type="image/png">
  <link href="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.snow.css" rel="stylesheet">
  <script is:inline>
    if (localStorage.getItem('kscw-theme') === 'light') {
      document.documentElement.classList.add('light');
    }
  </script>
</head>
<body>
  <div id="admin-app"></div>

  <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js" integrity="sha384-utBUCeG4SYaCm4m7GQZYr8Hy8Fpy3V4KGjBZaf4WTKOcwhCYpt/0PfeEe3HNlwx8" crossorigin="anonymous"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/dompurify@3.2.4/dist/purify.min.js" integrity="sha384-eEu5CTj3qGvu9PdJuS+YlkNi7d2XxQROAFYOr59zgObtlcux1ae1Il3u7jvdCSWu" crossorigin="anonymous"></script>
  <script is:inline>
  (function() {
    'use strict';

    var DIRECTUS_URL = (window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1')
      ? 'https://directus-dev.kscw.ch' : 'https://directus.kscw.ch';
    var AUTH_KEY = 'kscw_admin_auth';
    var TURNSTILE_SITE_KEY = '0x4AAAAAACoYmx3xiDfRbmv9';
    var app = document.getElementById('admin-app');
    var currentTab = 'news';
    var adminLang = localStorage.getItem('admin-lang') || 'de';
    var quillInstance = null;
    var turnstileWidgetId = null;
    var turnstileToken = '';

    // ── Directus auth token management ───────────────────────
    function storeAuth(result) {
      sessionStorage.setItem(AUTH_KEY, JSON.stringify({
        access_token: result.access_token,
        refresh_token: result.refresh_token,
        expires_at: Date.now() + result.expires,
      }));
    }
    function getAuth() {
      var raw = sessionStorage.getItem(AUTH_KEY);
      if (!raw) return null;
      try { return JSON.parse(raw); } catch(e) { return null; }
    }
    async function getValidToken() {
      var auth = getAuth();
      if (!auth) return null;
      if (auth.expires_at - Date.now() < 30000) {
        var res = await fetch(DIRECTUS_URL + '/auth/refresh', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ refresh_token: auth.refresh_token, mode: 'json' }),
        });
        if (!res.ok) { sessionStorage.removeItem(AUTH_KEY); return null; }
        var data = await res.json();
        storeAuth(data.data);
        return data.data.access_token;
      }
      return auth.access_token;
    }

    // ── i18n ─────────────────────────────────────────────────
    var i18n = {
      de: {
        websiteAdmin: 'Websiteverwaltung',
        login: 'Anmelden',
        loggingIn: 'Wird angemeldet...',
        logout: 'Abmelden',
        email: 'E-Mail',
        password: 'Passwort',
        showPassword: 'Passwort anzeigen',
        accessDenied: 'Zugang verweigert',
        accessDeniedMsg: 'Du hast keine Berechtigung für den Website-Admin.',
        loading: 'Laden...',
        noEntries: 'Keine Einträge vorhanden.',
        noTitle: '(Ohne Titel)',
        published: 'Publiziert',
        draft: 'Entwurf',
        edit: 'Bearbeiten',
        delete: 'Löschen',
        confirmDelete: 'Diesen Eintrag wirklich löschen?',
        deleteError: 'Fehler beim Löschen: ',
        loadError: 'Fehler beim Laden: ',
        loginError: 'Anmeldung fehlgeschlagen. Bitte prüfe E-Mail und Passwort.',
        loginDenied: 'Zugang verweigert — fehlende Berechtigung.',
        newItem: 'Neu erstellen',
        title: 'Titel',
        excerpt: 'Kurzfassung',
        content: 'Inhalt',
        category: 'Kategorie',
        image: 'Bild',
        publishDate: 'Veröffentlichungsdatum',
        isPublished: 'Veröffentlicht',
        type: 'Typ',
        startDate: 'Startdatum',
        endDate: 'Enddatum',
        allDay: 'Ganztägig',
        location: 'Ort',
        description: 'Beschreibung',
        participationRequired: 'Teilnahme erforderlich',
        respondBy: 'Antwort bis',
        teams: 'Teams',
        allTeams: 'Alle Teams',
        none: 'Keine',
        minParticipants: 'Min. Teilnehmer',
        maxParticipants: 'Max. Teilnehmer',
        requiredParticipants: 'Pflicht-Teilnehmer',
        requireNoteIfAbsent: 'Begründung bei Absage erforderlich',
        search: 'Suchen...',
        cancel: 'Abbrechen',
        save: 'Speichern',
        saving: 'Wird gespeichert...',
        saveError: 'Fehler beim Speichern: ',
        translationFailed: 'Übersetzung fehlgeschlagen',
        create: 'Neu erstellen',
        forgotPassword: 'Passwort vergessen?',
        resetPasswordInfo: 'Gib deine E-Mail-Adresse ein und klicke auf «Passwort zurücksetzen». Du erhältst eine E-Mail mit einem Link zum Setzen deines Passworts.',
        resetPassword: 'Passwort zurücksetzen',
        resetPasswordSent: 'Falls ein Konto mit dieser E-Mail existiert, wurde ein Link zum Zurücksetzen gesendet.',
        resetPasswordError: 'Fehler beim Senden. Bitte versuche es erneut.',
        backToLogin: 'Zurück zur Anmeldung'
      },
      en: {
        websiteAdmin: 'Website Management',
        login: 'Login',
        loggingIn: 'Logging in...',
        logout: 'Logout',
        email: 'Email',
        password: 'Password',
        showPassword: 'Show password',
        accessDenied: 'Access Denied',
        accessDeniedMsg: 'You do not have permission to access the admin panel.',
        loading: 'Loading...',
        noEntries: 'No entries found.',
        noTitle: '(Untitled)',
        published: 'Published',
        draft: 'Draft',
        edit: 'Edit',
        delete: 'Delete',
        confirmDelete: 'Are you sure you want to delete this entry?',
        deleteError: 'Error deleting: ',
        loadError: 'Error loading: ',
        loginError: 'Login failed. Please check your email and password.',
        loginDenied: 'Access denied — insufficient permissions.',
        newItem: 'Create new',
        title: 'Title',
        excerpt: 'Summary',
        content: 'Content',
        category: 'Category',
        image: 'Image',
        publishDate: 'Publish date',
        isPublished: 'Published',
        type: 'Type',
        startDate: 'Start date',
        endDate: 'End date',
        allDay: 'All day',
        location: 'Location',
        description: 'Description',
        participationRequired: 'Participation required',
        respondBy: 'Respond by',
        teams: 'Teams',
        allTeams: 'All teams',
        none: 'None',
        minParticipants: 'Min. participants',
        maxParticipants: 'Max. participants',
        requiredParticipants: 'Required participants',
        requireNoteIfAbsent: 'Require note if not joining',
        search: 'Search...',
        cancel: 'Cancel',
        save: 'Save',
        saving: 'Saving...',
        saveError: 'Error saving: ',
        translationFailed: 'Translation failed',
        create: 'Create new',
        forgotPassword: 'Forgot password?',
        resetPasswordInfo: 'Enter your email address and click "Reset password". You will receive an email with a link to set your password.',
        resetPassword: 'Reset password',
        resetPasswordSent: 'If an account with this email exists, a reset link has been sent.',
        resetPasswordError: 'Error sending reset email. Please try again.',
        backToLogin: 'Back to login'
      }
    };
    function t(key) { return (i18n[adminLang] || i18n.de)[key] || key; }
    var cachedTeams = null; // [{id, name, sport}]
    var cachedMembers = null; // [{id, first_name, last_name, email}]

    // ── Data caches ───────────────────────────────────────────
    function fetchTeams() {
      if (cachedTeams) return Promise.resolve(cachedTeams);
      return getValidToken().then(function(token) {
        return fetch(DIRECTUS_URL + '/items/teams?filter[active][_eq]=true&sort=sport,name&fields=id,name,sport&limit=-1', {
          headers: { 'Authorization': 'Bearer ' + token },
        });
      }).then(function(res) { return res.json(); })
        .then(function(data) { cachedTeams = data.data; return cachedTeams; });
    }
    function fetchMembers() {
      if (cachedMembers) return Promise.resolve(cachedMembers);
      return getValidToken().then(function(token) {
        return fetch(DIRECTUS_URL + '/users?sort=first_name,last_name&fields=id,first_name,last_name,email&limit=-1', {
          headers: { 'Authorization': 'Bearer ' + token },
        });
      }).then(function(res) { return res.json(); })
        .then(function(data) { cachedMembers = data.data; return cachedMembers; });
    }

    // ── Auth helpers ──────────────────────────────────────────
    async function isAuthorized() {
      var token = await getValidToken();
      if (!token) return false;
      var res = await fetch(DIRECTUS_URL + '/users/me?fields=id,email,first_name,last_name,role.name', {
        headers: { 'Authorization': 'Bearer ' + token },
      });
      if (!res.ok) return false;
      var user = (await res.json()).data;
      var roleName = user.role ? user.role.name : '';
      return ['website_admin', 'admin', 'superuser'].indexOf(roleName.toLowerCase()) !== -1;
    }

    // ── Escape helpers ────────────────────────────────────────
    function escapeHtml(str) {
      var div = document.createElement('div');
      div.textContent = str || '';
      return div.innerHTML;
    }
    function escapeAttr(str) {
      return (str || '').replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    // ── Safe DOM helpers (avoid innerHTML with user data) ─────
    function setAppContent(html) {
      // All HTML here is hardcoded template strings with user values
      // escaped via escapeHtml/escapeAttr. This is safe by construction.
      app.innerHTML = DOMPurify.sanitize(html, { ADD_TAGS: ['form'], ADD_ATTR: ['data-tab', 'data-action', 'data-id', 'required', 'autocomplete'] });
    }

    // ── Render Router ─────────────────────────────────────────
    async function render() {
      if (!getAuth()) {
        renderLogin();
      } else if (!(await isAuthorized())) {
        renderAccessDenied();
      } else {
        renderAdmin();
      }
    }

    // ── Login Page ────────────────────────────────────────────
    function renderLogin() {
      setAppContent(
        '<div class="admin-login">' +
          '<div class="admin-login-card">' +
            '<img src="/images/kscw_trio.png" alt="KSC Wiedikon" class="admin-login-logo">' +
            '<div class="admin-login-icon">' +
              '<svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="var(--kscw-gold)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
                '<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>' +
                '<path d="M7 11V7a5 5 0 0 1 10 0v4"/>' +
              '</svg>' +
            '</div>' +
            '<h1>KSCW Admin</h1>' +
            '<p class="admin-login-subtitle">' + t('websiteAdmin') + '</p>' +
            '<form id="login-form">' +
              '<div class="admin-field">' +
                '<label for="email">' + t('email') + '</label>' +
                '<input type="email" id="email" required autocomplete="email" placeholder="admin@kscw.ch">' +
              '</div>' +
              '<div class="admin-field">' +
                '<label for="password">' + t('password') + '</label>' +
                '<div class="admin-password-wrap">' +
                  '<input type="password" id="password" required autocomplete="current-password" placeholder="••••••••">' +
                  '<button type="button" id="toggle-pw" class="admin-pw-toggle" aria-label="' + t('showPassword') + '">' +
                    '<svg id="eye-open" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
                      '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>' +
                      '<circle cx="12" cy="12" r="3"/>' +
                    '</svg>' +
                    '<svg id="eye-closed" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">' +
                      '<path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24"/>' +
                      '<line x1="1" y1="1" x2="23" y2="23"/>' +
                    '</svg>' +
                  '</button>' +
                '</div>' +
              '</div>' +
              '<div id="login-error" class="admin-error" style="display:none;"></div>' +
              '<div id="admin-turnstile"></div>' +
              '<button type="submit" class="admin-login-btn">' + t('login') + '</button>' +
            '</form>' +
            '<button type="button" id="forgot-pw-link" class="admin-forgot-link">' + t('forgotPassword') + '</button>' +
          '</div>' +
        '</div>'
      );

      // Render Turnstile widget
      var adminTurnstileEl = document.getElementById('admin-turnstile');
      function renderAdminTurnstile() {
        if (!adminTurnstileEl || !window.turnstile) return;
        if (turnstileWidgetId !== null) return;
        turnstileWidgetId = window.turnstile.render(adminTurnstileEl, {
          sitekey: TURNSTILE_SITE_KEY,
          theme: 'auto',
          size: 'compact',
          callback: function(token) { turnstileToken = token; },
          'expired-callback': function() { turnstileToken = ''; },
        });
      }
      if (window.turnstile) {
        renderAdminTurnstile();
      } else {
        var tsPoll = 0;
        var tsInterval = setInterval(function() {
          tsPoll++;
          if (window.turnstile) { clearInterval(tsInterval); renderAdminTurnstile(); }
          if (tsPoll > 50) clearInterval(tsInterval);
        }, 100);
      }

      document.getElementById('login-form').addEventListener('submit', function(e) {
        e.preventDefault();
        var email = document.getElementById('email').value;
        var password = document.getElementById('password').value;
        var errEl = document.getElementById('login-error');
        var btn = e.target.querySelector('button[type="submit"]');
        btn.disabled = true;
        btn.textContent = t('loggingIn');

        var headers = { 'Content-Type': 'application/json' };
        if (turnstileToken) headers['X-Turnstile-Token'] = turnstileToken;

        fetch(DIRECTUS_URL + '/auth/login', {
          method: 'POST', headers: headers,
          body: JSON.stringify({ email: email, password: password }),
        })
          .then(function(res) {
            if (!res.ok) throw new Error('Login failed');
            return res.json();
          })
          .then(function(data) {
            storeAuth(data.data);
            return isAuthorized();
          })
          .then(function(authorized) {
            if (!authorized) {
              errEl.textContent = t('loginDenied');
              errEl.style.display = 'block';
              sessionStorage.removeItem(AUTH_KEY);
              btn.disabled = false;
              btn.textContent = t('login');
            } else {
              render();
            }
          })
          .catch(function() {
            errEl.textContent = t('loginError');
            errEl.style.display = 'block';
            btn.disabled = false;
            btn.textContent = t('login');
            if (window.turnstile && turnstileWidgetId !== null) {
              window.turnstile.reset(turnstileWidgetId);
              turnstileToken = '';
            }
          });
      });

      document.getElementById('toggle-pw').addEventListener('click', function() {
        var pwInput = document.getElementById('password');
        var open = document.getElementById('eye-open');
        var closed = document.getElementById('eye-closed');
        if (pwInput.type === 'password') {
          pwInput.type = 'text';
          open.style.display = 'none';
          closed.style.display = 'block';
        } else {
          pwInput.type = 'password';
          open.style.display = 'block';
          closed.style.display = 'none';
        }
      });

      document.getElementById('forgot-pw-link').addEventListener('click', function() {
        renderForgotPassword();
      });
    }

    // ── Forgot Password Page ─────────────────────────────────
    function renderForgotPassword() {
      setAppContent(
        '<div class="admin-login">' +
          '<div class="admin-login-card">' +
            '<img src="/images/kscw_trio.png" alt="KSC Wiedikon" class="admin-login-logo">' +
            '<div class="admin-login-icon">' +
              '<svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="var(--kscw-gold)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
                '<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>' +
                '<polyline points="22,6 12,13 2,6"/>' +
              '</svg>' +
            '</div>' +
            '<h1>' + t('resetPassword') + '</h1>' +
            '<p class="admin-login-subtitle" style="text-transform:none;letter-spacing:0;font-size:0.8rem;line-height:1.4;">' + t('resetPasswordInfo') + '</p>' +
            '<form id="reset-form">' +
              '<div class="admin-field">' +
                '<label for="reset-email">' + t('email') + '</label>' +
                '<input type="email" id="reset-email" required autocomplete="email" placeholder="name@kscw.ch">' +
              '</div>' +
              '<div id="reset-msg" class="admin-error" style="display:none;"></div>' +
              '<button type="submit" class="admin-login-btn">' + t('resetPassword') + '</button>' +
            '</form>' +
            '<button type="button" id="back-to-login" class="admin-forgot-link">' + t('backToLogin') + '</button>' +
          '</div>' +
        '</div>'
      );

      document.getElementById('reset-form').addEventListener('submit', function(e) {
        e.preventDefault();
        var email = document.getElementById('reset-email').value;
        var msgEl = document.getElementById('reset-msg');
        var btn = e.target.querySelector('button[type="submit"]');
        btn.disabled = true;

        fetch(DIRECTUS_URL + '/kscw/password-request', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email }),
        })
          .then(function(res) { if (!res.ok) throw new Error('Reset failed'); })
          .then(function() {
            msgEl.textContent = t('resetPasswordSent');
            msgEl.style.display = 'block';
            msgEl.classList.remove('admin-error');
            msgEl.classList.add('admin-success');
            btn.disabled = true;
          })
          .catch(function() {
            msgEl.textContent = t('resetPasswordError');
            msgEl.style.display = 'block';
            msgEl.classList.remove('admin-success');
            msgEl.classList.add('admin-error');
            btn.disabled = false;
          });
      });

      document.getElementById('back-to-login').addEventListener('click', function() {
        renderLogin();
      });
    }

    // ── Access Denied ─────────────────────────────────────────
    function renderAccessDenied() {
      setAppContent(
        '<div class="admin-login">' +
          '<div class="admin-login-card">' +
            '<h1>' + t('accessDenied') + '</h1>' +
            '<p style="color:var(--text-secondary);margin-bottom:1.5rem;">' + t('accessDeniedMsg') + '</p>' +
            '<button class="admin-btn" id="denied-logout">' + t('logout') + '</button>' +
          '</div>' +
        '</div>'
      );
      document.getElementById('denied-logout').addEventListener('click', function() {
        sessionStorage.removeItem(AUTH_KEY);
        render();
      });
    }

    // ── Admin Dashboard ───────────────────────────────────────
    function renderAdmin() {
      setAppContent(
        '<div class="admin-shell">' +
          '<header class="admin-header">' +
            '<div class="admin-header-inner">' +
              '<a href="/" class="admin-logo">' +
                '<img src="/images/kscw_trio.png" alt="" style="height:32px;">' +
                '<span style="line-height:1.1;font-size:0.85em;">Website<br>Admin</span>' +
              '</a>' +
              '<div class="admin-header-actions">' +
                '<button class="admin-lang-toggle" id="lang-toggle">' +
                  '<span class="admin-lang-opt' + (adminLang === 'de' ? ' active' : '') + '" data-lang="de">DE</span>' +
                  '<span class="admin-lang-opt' + (adminLang === 'en' ? ' active' : '') + '" data-lang="en">EN</span>' +
                '</button>' +
                '<button class="admin-btn admin-btn-ghost" id="logout-btn">' + t('logout') + '</button>' +
              '</div>' +
            '</div>' +
          '</header>' +
          '<div class="admin-tabs">' +
            '<button class="admin-tab' + (currentTab === 'news' ? ' active' : '') + '" data-tab="news">News</button>' +
            '<button class="admin-tab' + (currentTab === 'events' ? ' active' : '') + '" data-tab="events">Events</button>' +
          '</div>' +
          '<div class="admin-content" id="admin-content"></div>' +
          '<button class="admin-fab" id="fab-btn" title="' + t('create') + '">+</button>' +
        '</div>'
      );

      // Modal container
      var modalDiv = document.createElement('div');
      modalDiv.id = 'admin-modal';
      modalDiv.className = 'admin-modal-overlay';
      modalDiv.style.display = 'none';
      app.appendChild(modalDiv);

      document.getElementById('logout-btn').addEventListener('click', function() {
        sessionStorage.removeItem(AUTH_KEY);
        render();
      });

      document.getElementById('lang-toggle').addEventListener('click', function() {
        adminLang = adminLang === 'de' ? 'en' : 'de';
        localStorage.setItem('admin-lang', adminLang);
        renderAdmin();
      });

      document.querySelectorAll('.admin-tab').forEach(function(tab) {
        tab.addEventListener('click', function() {
          currentTab = this.getAttribute('data-tab');
          document.querySelectorAll('.admin-tab').forEach(function(t) { t.classList.remove('active'); });
          this.classList.add('active');
          loadItems();
        });
      });

      document.getElementById('fab-btn').addEventListener('click', function() {
        openModal(null);
      });

      loadItems();
    }

    // ── Load Items ────────────────────────────────────────────
    function loadItems() {
      var content = document.getElementById('admin-content');
      content.textContent = '';
      var loadingDiv = document.createElement('div');
      loadingDiv.className = 'admin-loading';
      loadingDiv.textContent = t('loading');
      content.appendChild(loadingDiv);

      var collection = currentTab === 'news' ? 'news' : 'events';
      var sort = currentTab === 'news' ? '-published_at' : '-start_date';

      getValidToken().then(function(token) {
        return fetch(DIRECTUS_URL + '/items/' + collection + '?sort=' + sort + '&limit=50', {
          headers: { 'Authorization': 'Bearer ' + token },
        });
      }).then(function(res) { return res.json(); })
        .then(function(result) {
          var items = result.data || [];
          content.textContent = '';

          if (!items.length) {
            var emptyDiv = document.createElement('div');
            emptyDiv.className = 'admin-empty';
            emptyDiv.textContent = t('noEntries');
            content.appendChild(emptyDiv);
            return;
          }

          var list = document.createElement('div');
          list.className = 'admin-list';

          items.forEach(function(item) {
            var date = currentTab === 'news'
              ? (item.published_at || item.created || '').substring(0, 10)
              : (item.start_date || '').substring(0, 10);
            var title = item.title || t('noTitle');
            var category = currentTab === 'news' ? (item.category || '') : (item.event_type || '');

            var row = document.createElement('div');
            row.className = 'admin-list-item';

            // Info section
            var info = document.createElement('div');
            info.className = 'admin-list-info';

            var h3 = document.createElement('h3');
            h3.className = 'admin-list-title';
            h3.textContent = title;
            info.appendChild(h3);

            var meta = document.createElement('div');
            meta.className = 'admin-list-meta';
            var dateSpan = document.createElement('span');
            dateSpan.textContent = date;
            meta.appendChild(dateSpan);
            if (category) {
              var catBadge = document.createElement('span');
              catBadge.className = 'admin-badge';
              catBadge.textContent = category;
              meta.appendChild(catBadge);
            }
            if (currentTab === 'news') {
              var statusBadge = document.createElement('span');
              statusBadge.className = item.is_published ? 'admin-badge admin-badge-green' : 'admin-badge admin-badge-gray';
              statusBadge.textContent = item.is_published ? t('published') : t('draft');
              meta.appendChild(statusBadge);
            }
            info.appendChild(meta);
            row.appendChild(info);

            // Actions
            var actions = document.createElement('div');
            actions.className = 'admin-list-actions';

            var editBtn = document.createElement('button');
            editBtn.className = 'admin-btn admin-btn-sm';
            editBtn.textContent = t('edit');
            editBtn.addEventListener('click', function() {
              getValidToken().then(function(token) {
                return fetch(DIRECTUS_URL + '/items/' + collection + '/' + item.id, {
                  headers: { 'Authorization': 'Bearer ' + token },
                });
              }).then(function(res) { return res.json(); })
                .then(function(data) { openModal(data.data); });
            });
            actions.appendChild(editBtn);

            var deleteBtn = document.createElement('button');
            deleteBtn.className = 'admin-btn admin-btn-sm admin-btn-danger';
            deleteBtn.textContent = t('delete');
            deleteBtn.addEventListener('click', function() {
              if (confirm(t('confirmDelete'))) {
                getValidToken().then(function(token) {
                  return fetch(DIRECTUS_URL + '/items/' + collection + '/' + item.id, {
                    method: 'DELETE',
                    headers: { 'Authorization': 'Bearer ' + token },
                  });
                }).then(function(res) {
                  if (!res.ok) throw new Error('HTTP ' + res.status);
                  loadItems();
                }).catch(function(err) { alert(t('deleteError') + err.message); });
              }
            });
            actions.appendChild(deleteBtn);

            row.appendChild(actions);
            list.appendChild(row);
          });

          content.appendChild(list);
        })
        .catch(function(err) {
          content.textContent = '';
          var errDiv = document.createElement('div');
          errDiv.className = 'admin-error';
          errDiv.textContent = t('loadError') + err.message;
          content.appendChild(errDiv);
        });
    }

    // ── Modal (Create / Edit) ─────────────────────────────────
    function openModal(item) {
      var modal = document.getElementById('admin-modal');
      var isEdit = !!item;
      var isNews = currentTab === 'news';
      var modalTitle = isEdit ? t('edit') : t('newItem');

      // Build form HTML (all values escaped)
      var formHtml = '<div class="admin-modal-content">' +
        '<div class="admin-modal-header">' +
          '<h2>' + escapeHtml(modalTitle) + '</h2>' +
          '<button class="admin-modal-close" id="modal-close">&times;</button>' +
        '</div>' +
        '<form id="modal-form" class="admin-modal-body">';

      // Title with silent auto-translation
      var titleVal = item ? (adminLang === 'en' && item.title_en ? item.title_en : item.title) : '';
      var otherVal = item ? (adminLang === 'de' ? (item.title_en || '') : item.title) : '';
      formHtml += fieldInput('title', t('title'), titleVal, true);

      if (isNews) {
        formHtml += '<input type="hidden" name="title_en" value="' + escapeAttr(otherVal) + '">';
        formHtml += '<input type="hidden" name="slug" value="' + escapeAttr(item ? item.slug : '') + '">';
        formHtml += fieldTextarea('excerpt', t('excerpt'), item ? item.excerpt : '');
        formHtml += '<div class="admin-field"><label>' + t('content') + '</label><div id="quill-editor" style="min-height:200px;"></div></div>';
        formHtml += fieldSelect('category', t('category'), ['club', 'volleyball', 'basketball'], item ? item.category : 'club');
        formHtml += fieldFile('image', t('image'));
        if (item && item.image) {
          formHtml += '<div class="admin-field"><img src="' + escapeAttr(DIRECTUS_URL + '/assets/' + item.image + '?width=200&quality=80') + '" style="max-height:100px;border-radius:var(--radius-md);"></div>';
        }
        formHtml += fieldDate('published_at', t('publishDate'), item ? (item.published_at || '').substring(0, 10) : new Date().toISOString().substring(0, 10));
        formHtml += fieldCheckbox('is_published', t('isPublished'), item ? item.is_published : true, { toggle: true });
      } else {
        // Events form
        formHtml += fieldSelect('event_type', t('type'), ['verein', 'social', 'meeting', 'tournament', 'other'], item ? item.event_type : 'verein');
        formHtml += fieldDate('start_date', t('startDate'), item ? (item.start_date || '').substring(0, 10) : '');
        formHtml += fieldDate('end_date', t('endDate'), item ? (item.end_date || '').substring(0, 10) : '');
        formHtml += fieldCheckbox('all_day', t('allDay'), item ? item.all_day : true);
        formHtml += fieldInput('location', t('location'), item ? (item.location || '') : '');
        formHtml += '<div class="admin-field"><label>' + t('description') + '</label><div id="quill-editor" style="min-height:150px;"></div></div>';

        // Participation section
        var hasParticipation = item && (item.respond_by || (item.teams && item.teams.length) || item.max_players || item.min_players || item.require_note_if_absent || (item.required_participants && item.required_participants.length));
        formHtml += fieldCheckbox('participation_required', t('participationRequired'), !!hasParticipation);
        formHtml += '<div id="participation-fields" style="' + (hasParticipation ? '' : 'display:none;') + '">';
        formHtml += fieldDate('respond_by', t('respondBy'), item ? (item.respond_by || '').substring(0, 10) : '');

        // Teams selector (placeholder — filled dynamically)
        formHtml += '<div class="admin-field">' +
          '<label>' + t('teams') + '</label>' +
          '<div class="admin-team-presets" id="team-presets"></div>' +
          '<div class="admin-multiselect-tags" id="teams-tags"></div>' +
          '<div id="teams-dropdown" class="admin-multiselect-dropdown" style="display:none;"></div>' +
          '<input type="hidden" name="teams" value="' + escapeAttr(item && item.teams ? JSON.stringify(item.teams) : '[]') + '">' +
        '</div>';

        formHtml += fieldNumber('min_players', t('minParticipants'), item ? item.min_players : '');
        formHtml += fieldNumber('max_players', t('maxParticipants'), item ? item.max_players : '');
        formHtml += fieldCheckbox('require_note_if_absent', t('requireNoteIfAbsent'), item ? !!item.require_note_if_absent : false, { toggle: true });

        // Required participants (multi-search select — filled dynamically)
        formHtml += '<div class="admin-field">' +
          '<label>' + t('requiredParticipants') + '</label>' +
          '<input type="text" id="member-search" placeholder="' + t('search') + '" autocomplete="off">' +
          '<div class="admin-multiselect-tags" id="members-tags"></div>' +
          '<div id="members-dropdown" class="admin-multiselect-dropdown" style="display:none;"></div>' +
          '<input type="hidden" name="required_participants" value="' + escapeAttr(item && item.required_participants ? JSON.stringify(item.required_participants) : '[]') + '">' +
        '</div>';

        formHtml += '</div>'; // close participation-fields
      }

      formHtml += '<div class="admin-modal-footer">' +
          '<button type="button" class="admin-btn" id="modal-cancel">' + t('cancel') + '</button>' +
          '<button type="submit" class="admin-btn admin-btn-primary" id="modal-save">' + t('save') + '</button>' +
        '</div>' +
        '</form>' +
      '</div>';

      // Form HTML is built from escaped values (escapeHtml/escapeAttr) — safe to set directly.
      // DOMPurify strips form attributes (name, type, value) which breaks form submission.
      // User-generated content (Quill editor) is sanitized separately on save.
      modal.innerHTML = formHtml;
      modal.style.display = 'flex';

      // Initialize Quill
      quillInstance = null;
      var editorEl = document.getElementById('quill-editor');
      if (editorEl) {
        quillInstance = new Quill(editorEl, {
          theme: 'snow',
          modules: {
            toolbar: [
              [{ header: [2, 3, false] }],
              ['bold', 'italic', 'underline'],
              [{ list: 'ordered' }, { list: 'bullet' }],
              ['link', 'image'],
              ['clean']
            ]
          }
        });
        var bodyContent = isNews ? (item ? item.body : '') : (item ? item.description : '');
        if (bodyContent) {
          quillInstance.clipboard.dangerouslyPasteHTML(DOMPurify.sanitize(bodyContent));
        }
      }

      // Auto-generate slug + silent auto-translate title (news only)
      if (isNews) {
        var titleInput = document.querySelector('#modal-form [name="title"]');
        var slugInput = document.querySelector('#modal-form [name="slug"]');
        var titleEnInput = document.querySelector('#modal-form [name="title_en"]');
        var translateTimer = null;

        function generateSlug(text) {
          return text.toLowerCase()
            .replace(/[äÄ]/g, 'ae').replace(/[öÖ]/g, 'oe').replace(/[üÜ]/g, 'ue').replace(/[ß]/g, 'ss')
            .replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
        }

        function autoTranslate(text) {
          if (!text || text.length < 3) { titleEnInput.value = ''; return; }
          var tgtLang = adminLang === 'de' ? 'en' : 'de';
          fetch('https://api.mymemory.translated.net/get?q=' + encodeURIComponent(text) + '&langpair=' + adminLang + '|' + tgtLang)
            .then(function(r) { return r.json(); })
            .then(function(data) {
              var translated = data.responseData && data.responseData.translatedText;
              if (translated) {
                if (translated === translated.toUpperCase() && text !== text.toUpperCase()) {
                  translated = translated.charAt(0).toUpperCase() + translated.slice(1).toLowerCase();
                }
                titleEnInput.value = translated;
              }
            })
            .catch(function() { /* silent fail */ });
        }

        if (titleInput) {
          titleInput.addEventListener('input', function() {
            if (!isEdit && slugInput) {
              slugInput.value = generateSlug(this.value);
            }
            clearTimeout(translateTimer);
            translateTimer = setTimeout(function() {
              autoTranslate(titleInput.value.trim());
            }, 600);
          });
        }

        // Translate on load if editing and no translation exists yet
        if (isEdit && titleInput && titleInput.value && !titleEnInput.value) {
          autoTranslate(titleInput.value.trim());
        }
      }

      // ── Participation toggle (events only) ───────────────────
      if (!isNews) {
        var partCheck = document.querySelector('[name="participation_required"]');
        var partFields = document.getElementById('participation-fields');
        if (partCheck && partFields) {
          partCheck.addEventListener('change', function() {
            partFields.style.display = this.checked ? '' : 'none';
          });
        }
        initTeamsSelector(item);
        initMembersSelector(item);
      }

      // Close handlers
      document.getElementById('modal-close').addEventListener('click', closeModal);
      document.getElementById('modal-cancel').addEventListener('click', closeModal);
      modal.addEventListener('click', function(e) {
        if (e.target === modal) closeModal();
      });

      // Submit handler
      document.getElementById('modal-form').addEventListener('submit', function(e) {
        e.preventDefault();
        saveItem(item);
      });
    }

    function closeModal() {
      var modal = document.getElementById('admin-modal');
      modal.style.display = 'none';
      modal.textContent = '';
      quillInstance = null;
    }

    // ── Upload file to Directus ─────────────────────────────
    async function uploadFile(token, file) {
      var fd = new FormData();
      fd.append('file', file);
      var res = await fetch(DIRECTUS_URL + '/files', {
        method: 'POST',
        headers: { 'Authorization': 'Bearer ' + token },
        body: fd,
      });
      if (!res.ok) throw new Error('File upload failed: ' + res.status);
      var data = await res.json();
      return data.data.id;
    }

    async function saveItem(existingItem) {
      var form = document.getElementById('modal-form');
      var saveBtn = document.getElementById('modal-save');
      saveBtn.disabled = true;
      saveBtn.textContent = t('saving');

      var isNews = currentTab === 'news';
      var collection = isNews ? 'news' : 'events';
      var payload = {};

      var rawTitle = form.querySelector('[name="title"]').value;

      try {
        var token = await getValidToken();

        if (isNews) {
          var translatedTitle = form.querySelector('[name="title_en"]').value;
          // Admin typed in adminLang, translation is the other language
          if (adminLang === 'en') {
            payload.title_en = rawTitle;                      // input is EN
            payload.title = translatedTitle || rawTitle;       // translation is DE
          } else {
            payload.title = rawTitle;                          // input is DE
            if (translatedTitle) payload.title_en = translatedTitle; // translation is EN
          }
          payload.slug = form.querySelector('[name="slug"]').value;
          payload.excerpt = form.querySelector('[name="excerpt"]').value;
          payload.body = quillInstance ? DOMPurify.sanitize(quillInstance.root.innerHTML) : '';
          payload.category = form.querySelector('[name="category"]').value;
          payload.published_at = form.querySelector('[name="published_at"]').value;
          payload.is_published = form.querySelector('[name="is_published"]').checked;

          var imageInput = form.querySelector('[name="image"]');
          if (imageInput && imageInput.files.length > 0) {
            payload.image = await uploadFile(token, imageInput.files[0]);
          }
        } else {
          payload.title = rawTitle;
          payload.event_type = form.querySelector('[name="event_type"]').value;
          payload.start_date = form.querySelector('[name="start_date"]').value;
          payload.end_date = form.querySelector('[name="end_date"]').value || form.querySelector('[name="start_date"]').value;
          payload.all_day = form.querySelector('[name="all_day"]').checked;
          payload.location = form.querySelector('[name="location"]').value;
          payload.description = quillInstance ? DOMPurify.sanitize(quillInstance.root.innerHTML) : '';

          var participationRequired = form.querySelector('[name="participation_required"]').checked;
          if (participationRequired) {
            payload.respond_by = form.querySelector('[name="respond_by"]').value || null;
            var teamsVal = form.querySelector('[name="teams"]').value;
            var teamsArr; try { teamsArr = JSON.parse(teamsVal || '[]'); } catch (_) { teamsArr = []; }
            payload.teams = teamsArr;
            var minP = form.querySelector('[name="min_players"]').value;
            var maxP = form.querySelector('[name="max_players"]').value;
            payload.min_players = minP ? Number(minP) : 0;
            payload.max_players = maxP ? Number(maxP) : 0;
            payload.require_note_if_absent = form.querySelector('[name="require_note_if_absent"]').checked;
            var reqParts; try { reqParts = JSON.parse(form.querySelector('[name="required_participants"]').value || '[]'); } catch (_) { reqParts = []; }
            payload.required_participants = reqParts;
          } else {
            // Clear participation fields
            payload.respond_by = null;
            payload.teams = [];
            payload.min_players = 0;
            payload.max_players = 0;
            payload.require_note_if_absent = false;
            payload.required_participants = [];
          }
        }

        var url = existingItem
          ? DIRECTUS_URL + '/items/' + collection + '/' + existingItem.id
          : DIRECTUS_URL + '/items/' + collection;
        var method = existingItem ? 'PATCH' : 'POST';

        var res = await fetch(url, {
          method: method,
          headers: {
            'Authorization': 'Bearer ' + token,
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(payload),
        });
        if (!res.ok) {
          var errData = await res.json().catch(function() { return {}; });
          throw new Error(errData.errors ? errData.errors[0].message : 'HTTP ' + res.status);
        }
        closeModal();
        loadItems();
      } catch(err) {
        alert(t('saveError') + (err.message || err));
        saveBtn.disabled = false;
        saveBtn.textContent = t('save');
      }
    }

    // ── Form field helpers (all values escaped) ───────────────
    function fieldInput(name, label, value, required) {
      return '<div class="admin-field">' +
        '<label for="f-' + name + '">' + escapeHtml(label) + '</label>' +
        '<input type="text" name="' + name + '" id="f-' + name + '" value="' + escapeAttr(value || '') + '"' + (required ? ' required' : '') + '>' +
      '</div>';
    }
    function fieldTextarea(name, label, value) {
      return '<div class="admin-field">' +
        '<label for="f-' + name + '">' + escapeHtml(label) + '</label>' +
        '<textarea name="' + name + '" id="f-' + name + '" rows="3">' + escapeHtml(value || '') + '</textarea>' +
      '</div>';
    }
    function fieldDate(name, label, value) {
      return '<div class="admin-field">' +
        '<label for="f-' + name + '">' + escapeHtml(label) + '</label>' +
        '<input type="date" name="' + name + '" id="f-' + name + '" value="' + escapeAttr(value || '') + '">' +
      '</div>';
    }
    function fieldSelect(name, label, options, selected) {
      var html = '<div class="admin-field"><label for="f-' + name + '">' + escapeHtml(label) + '</label><select name="' + name + '" id="f-' + name + '">';
      options.forEach(function(opt) {
        html += '<option value="' + escapeAttr(opt) + '"' + (opt === selected ? ' selected' : '') + '>' + escapeHtml(opt.charAt(0).toUpperCase() + opt.slice(1)) + '</option>';
      });
      html += '</select></div>';
      return html;
    }
    function fieldNumber(name, label, value) {
      return '<div class="admin-field">' +
        '<label for="f-' + name + '">' + escapeHtml(label) + '</label>' +
        '<input type="number" name="' + name + '" id="f-' + name + '" value="' + escapeAttr(value != null && value !== '' ? String(value) : '') + '" min="0">' +
      '</div>';
    }
    function fieldFile(name, label) {
      return '<div class="admin-field">' +
        '<label for="f-' + name + '">' + escapeHtml(label) + '</label>' +
        '<input type="file" name="' + name + '" id="f-' + name + '" accept="image/*">' +
      '</div>';
    }
    function fieldCheckbox(name, label, checked, opts) {
      opts = opts || {};
      if (opts.toggle) {
        return '<div class="admin-field admin-field-toggle">' +
          '<label class="admin-toggle-label">' + escapeHtml(label) +
          '<span class="admin-toggle">' +
            '<input type="checkbox" name="' + name + '"' + (checked ? ' checked' : '') + '>' +
            '<span class="admin-toggle-track"><span class="admin-toggle-thumb"></span></span>' +
          '</span></label>' +
        '</div>';
      }
      return '<div class="admin-field admin-field-check">' +
        '<label><input type="checkbox" name="' + name + '"' + (checked ? ' checked' : '') + '> ' + escapeHtml(label) + '</label>' +
      '</div>';
    }

    // ── Teams multi-select with presets ─────────────────────
    function initTeamsSelector(item) {
      var selectedTeams = (item && item.teams) ? item.teams.slice() : [];
      var hiddenInput = document.querySelector('[name="teams"]');
      var tagsContainer = document.getElementById('teams-tags');
      var presetsContainer = document.getElementById('team-presets');
      if (!hiddenInput || !tagsContainer || !presetsContainer) return;

      function syncHidden() {
        hiddenInput.value = JSON.stringify(selectedTeams);
      }

      function renderTags(teams) {
        tagsContainer.textContent = '';
        selectedTeams.forEach(function(tid) {
          var team = teams ? teams.find(function(t) { return t.id === tid; }) : null;
          var tag = document.createElement('span');
          tag.className = 'admin-tag';
          tag.textContent = team ? team.name : tid;
          var removeBtn = document.createElement('button');
          removeBtn.type = 'button';
          removeBtn.className = 'admin-tag-remove';
          removeBtn.textContent = '\u00d7';
          removeBtn.addEventListener('click', function() {
            selectedTeams = selectedTeams.filter(function(id) { return id !== tid; });
            syncHidden();
            renderTags(teams);
          });
          tag.appendChild(removeBtn);
          tagsContainer.appendChild(tag);
        });
      }

      fetchTeams().then(function(teams) {
        // Preset buttons
        var presets = [
          { label: t('allTeams'), filter: function() { return teams; } },
          { label: 'Volleyball', filter: function() { return teams.filter(function(tt) { return tt.sport === 'volleyball'; }); } },
          { label: 'Basketball', filter: function() { return teams.filter(function(tt) { return tt.sport === 'basketball'; }); } }
        ];
        presets.forEach(function(p) {
          var btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'admin-btn admin-btn-sm';
          btn.textContent = p.label;
          btn.addEventListener('click', function() {
            selectedTeams = p.filter().map(function(t) { return t.id; });
            syncHidden();
            renderTags(teams);
          });
          presetsContainer.appendChild(btn);
        });

        // Clear button
        var clearBtn = document.createElement('button');
        clearBtn.type = 'button';
        clearBtn.className = 'admin-btn admin-btn-sm admin-btn-danger';
        clearBtn.textContent = t('none');
        clearBtn.addEventListener('click', function() {
          selectedTeams = [];
          syncHidden();
          renderTags(teams);
        });
        presetsContainer.appendChild(clearBtn);

        // Individual team checkboxes
        var dropdown = document.getElementById('teams-dropdown');
        dropdown.style.display = '';
        dropdown.style.maxHeight = '200px';
        dropdown.style.overflowY = 'auto';
        teams.forEach(function(team) {
          var label = document.createElement('label');
          label.className = 'admin-dropdown-item';
          var cb = document.createElement('input');
          cb.type = 'checkbox';
          cb.checked = selectedTeams.includes(team.id);
          cb.addEventListener('change', function() {
            if (this.checked) {
              if (!selectedTeams.includes(team.id)) selectedTeams.push(team.id);
            } else {
              selectedTeams = selectedTeams.filter(function(id) { return id !== team.id; });
            }
            syncHidden();
            renderTags(teams);
          });
          var sportBadge = document.createElement('span');
          sportBadge.className = 'admin-badge';
          sportBadge.textContent = team.sport === 'volleyball' ? 'VB' : 'BB';
          sportBadge.style.marginLeft = '4px';
          label.appendChild(cb);
          var nameSpan = document.createElement('span');
          nameSpan.textContent = ' ' + team.name + ' ';
          label.appendChild(nameSpan);
          label.appendChild(sportBadge);
          dropdown.appendChild(label);
        });

        renderTags(teams);
      });
    }

    // ── Members multi-search select ──────────────────────────
    function initMembersSelector(item) {
      var selectedMembers = (item && item.required_participants) ? item.required_participants.slice() : [];
      var hiddenInput = document.querySelector('[name="required_participants"]');
      var tagsContainer = document.getElementById('members-tags');
      var searchInput = document.getElementById('member-search');
      var dropdown = document.getElementById('members-dropdown');
      if (!hiddenInput || !tagsContainer || !searchInput || !dropdown) return;

      var allMembers = [];

      function syncHidden() {
        hiddenInput.value = JSON.stringify(selectedMembers);
      }

      function memberName(m) {
        return (m.first_name || '') + ' ' + (m.last_name || '');
      }

      function renderTags() {
        tagsContainer.textContent = '';
        selectedMembers.forEach(function(mid) {
          var member = allMembers.find(function(m) { return m.id === mid; });
          var tag = document.createElement('span');
          tag.className = 'admin-tag';
          tag.textContent = member ? memberName(member).trim() : mid;
          var removeBtn = document.createElement('button');
          removeBtn.type = 'button';
          removeBtn.className = 'admin-tag-remove';
          removeBtn.textContent = '\u00d7';
          removeBtn.addEventListener('click', function() {
            selectedMembers = selectedMembers.filter(function(id) { return id !== mid; });
            syncHidden();
            renderTags();
          });
          tag.appendChild(removeBtn);
          tagsContainer.appendChild(tag);
        });
      }

      function renderDropdown(query) {
        dropdown.textContent = '';
        if (!query) { dropdown.style.display = 'none'; return; }
        var q = query.toLowerCase();
        var matches = allMembers.filter(function(m) {
          if (selectedMembers.includes(m.id)) return false;
          var name = memberName(m).toLowerCase();
          var email = (m.email || '').toLowerCase();
          return name.indexOf(q) !== -1 || email.indexOf(q) !== -1;
        }).slice(0, 20);

        if (!matches.length) {
          dropdown.style.display = 'none';
          return;
        }

        dropdown.style.display = '';
        matches.forEach(function(m) {
          var option = document.createElement('div');
          option.className = 'admin-dropdown-option';
          var nameText = document.createElement('span');
          nameText.textContent = memberName(m).trim();
          option.appendChild(nameText);
          if (m.email) {
            var emailSpan = document.createElement('span');
            emailSpan.className = 'admin-dropdown-email';
            emailSpan.textContent = m.email;
            option.appendChild(emailSpan);
          }
          option.addEventListener('click', function() {
            selectedMembers.push(m.id);
            syncHidden();
            renderTags();
            searchInput.value = '';
            dropdown.style.display = 'none';
          });
          dropdown.appendChild(option);
        });
      }

      fetchMembers().then(function(members) {
        allMembers = members;
        renderTags();

        searchInput.addEventListener('input', function() {
          renderDropdown(this.value);
        });
        searchInput.addEventListener('focus', function() {
          if (this.value) renderDropdown(this.value);
        });
        // Close dropdown on outside click
        document.addEventListener('click', function(e) {
          if (!searchInput.contains(e.target) && !dropdown.contains(e.target)) {
            dropdown.style.display = 'none';
          }
        });
      });
    }

    // ── Init ──────────────────────────────────────────────────
    render();
  })();
  </script>
</body>
</html>

