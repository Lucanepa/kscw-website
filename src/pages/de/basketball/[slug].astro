---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { basketballTeams } from '../../../data/team-routes';
import { t } from '../../../lib/i18n';

const locale = 'de';

export function getStaticPaths() {
  return basketballTeams.map((team) => ({
    params: { slug: team.slug },
    props: { pbId: team.pbId, short: team.short },
  }));
}

const { pbId, short } = Astro.props;
---
<BaseLayout title={`${short} — KSC Wiedikon`} locale={locale}>
  <!-- Hero: rendered by JS -->
  <section id="team-hero-container"></section>

  <!-- Team photo: rendered by JS -->
  <div id="team-photo-container"></div>

  <!-- Content tabs -->
  <section class="section">
    <div class="container">
      <div class="tab-bar" role="tablist">
        <button class="tab-btn active" data-tab="kader" role="tab" aria-selected="true">{t(locale, 'teamTabRoster')}</button>
        <button class="tab-btn" data-tab="spiele" role="tab" aria-selected="false">{t(locale, 'teamTabGames')}</button>
        <button class="tab-btn" data-tab="rangliste" role="tab" aria-selected="false">{t(locale, 'teamTabRankings')}</button>
        <button class="tab-btn" data-tab="training" role="tab" aria-selected="false">{t(locale, 'teamTabTraining')}</button>
      </div>

      <div class="tab-panel active" data-tab-panel="kader" role="tabpanel">
        <div id="roster-view-toggle" class="roster-view-toggle">
          <button class="roster-view-btn active" data-view="grid" title="Grid" aria-label="Grid-Ansicht">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
          </button>
          <button class="roster-view-btn" data-view="list" title="Liste" aria-label="Listen-Ansicht">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
          </button>
        </div>
        <div id="roster-grid" class="roster-grid">
          <p class="text-muted text-sm">{t(locale, 'teamLoadingRoster')}</p>
        </div>
        <div id="roster-meta" class="mt-lg"></div>
      </div>

      <div class="tab-panel" data-tab-panel="spiele" role="tabpanel">
        <div id="upcoming-section">
          <h2 style="font-size: var(--text-2xl); margin-bottom: var(--space-lg);">{t(locale, 'teamUpcoming')}</h2>
          <div id="upcoming-games">
            <p class="text-muted text-sm">{t(locale, 'teamLoadingGames')}</p>
          </div>
        </div>
        <div id="results-section">
          <h2 style="font-size: var(--text-2xl); margin-top: var(--space-2xl); margin-bottom: var(--space-lg);">{t(locale, 'teamResults')}</h2>
          <div id="recent-results">
            <p class="text-muted text-sm">{t(locale, 'teamLoadingResults')}</p>
          </div>
        </div>
      </div>

      <div class="tab-panel" data-tab-panel="rangliste" role="tabpanel">
        <div id="rankings-table">
          <p class="text-muted text-sm">{t(locale, 'teamLoadingRankings')}</p>
        </div>
      </div>

      <div class="tab-panel" data-tab-panel="training" role="tabpanel">
        <div id="training-list">
          <p class="text-muted text-sm">{t(locale, 'teamLoadingTrainings')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Instagram embed -->
  <section id="instagram-embed-container" class="section" style="display:none;">
    <div class="container">
      <h2 id="instagram-heading" style="font-size: var(--text-2xl); margin-bottom: var(--space-lg);">Instagram</h2>
      <div id="instagram-embed" class="instagram-embed-wrapper"></div>
    </div>
  </section>

  <!-- CTA: rendered by JS -->
  <div id="cta-container"></div>

  <script is:inline define:vars={{ pbId, short }}>
    window.TEAM_CONFIG = { short: short, pbId: pbId };
  </script>
  <script is:inline src="/js/i18n.js"></script>
  <script is:inline>i18n.init();</script>
  <script is:inline src="/js/data.js"></script>
  <script is:inline src="/js/game-modal.js"></script>
  <script is:inline src="/js/team-page.js"></script>
</BaseLayout>
