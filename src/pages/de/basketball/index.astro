---
import PageLayout from '../../../layouts/PageLayout.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import CTA from '../../../components/CTA.astro';
import { t } from '../../../lib/i18n';

const locale = 'de';
---
<PageLayout
  title="Basketball — KSC Wiedikon"
  description="Alle Basketball-Teams des KSC Wiedikon — Von der 1. Liga bis U8."
  locale={locale}
  pageTitle={t(locale, 'bbTitle')}
  pageSubtitle={t(locale, 'bbSubtitle')}
>
  <!-- Damen -->
  <section class="section">
    <div class="container">
      <SectionHeader title={t(locale, 'bbWomen')} />
      <div class="grid grid-4">

        <!-- Lions -->
        <a href={`/${locale}/basketball/lions`} class="card team-card team-card--photo">
          <img src="https://kscw-api.lucanepa.com/api/files/pbc_1568971955/31k9c1qk62p23oe/bblions_ldzkbkw0b2.jpg?thumb=640x0" alt="Teamfoto" class="team-card-img" loading="lazy">
          <div class="card-body">
            <div class="team-card-header">
              <span class="chip" style="background: #6d28d9; color: #ffffff;">Lions</span>
              <h3>Lions</h3>
            </div>
            <span class="badge badge-blue">1. Liga</span>
            <p class="team-card-meta mt-sm">Mo 20:00–21:30, Do 19:30–21:30</p>
            <p class="team-card-meta mt-md" style="color: var(--kscw-blue); font-weight: 600;">{t(locale, 'bbMore')} &rarr;</p>
          </div>
        </a>

        <!-- Rhinos -->
        <a href={`/${locale}/basketball/rhinos`} class="card team-card team-card--photo">
          <img src="https://kscw-api.lucanepa.com/api/files/pbc_1568971955/cj55682587v210q/bbrhinos_jzjphi50in.jpg?thumb=640x0" alt="Teamfoto" class="team-card-img" loading="lazy">
          <div class="card-body">
            <div class="team-card-header">
              <span class="chip" style="background: #059669; color: #ffffff;">Rhinos</span>
              <h3>Rhinos</h3>
            </div>
            <span class="badge badge-blue">2. Liga</span>
            <p class="team-card-meta mt-sm">Di 20:00–21:30, Do 20:00–21:30</p>
            <p class="team-card-meta mt-md" style="color: var(--kscw-blue); font-weight: 600;">{t(locale, 'bbMore')} &rarr;</p>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- Herren -->
  <section class="section-alt">
    <div class="container">
      <SectionHeader title={t(locale, 'bbMen')} />
      <div class="grid grid-4">

        <!-- BB-H1 -->
        <a href={`/${locale}/basketball/h1`} class="card team-card team-card--photo">
          <img src="https://kscw-api.lucanepa.com/api/files/pbc_1568971955/wpg9887276cdkd9/bbh1_bo760yoe5s.jpg?thumb=640x0" alt="Teamfoto" class="team-card-img" loading="lazy">
          <div class="card-body">
            <div class="team-card-header">
              <span class="chip" style="background: #9a3412; color: #ffffff;">BB-H1</span>
              <h3>Herren 1</h3>
            </div>
            <span class="badge badge-blue">1. Liga</span>
            <p class="team-card-meta mt-sm">Mo 20:00–21:30, Mi 20:00–21:30</p>
            <p class="team-card-meta mt-md" style="color: var(--kscw-blue); font-weight: 600;">{t(locale, 'bbMore')} &rarr;</p>
          </div>
        </a>

        <!-- BB-H3 -->
        <a href={`/${locale}/basketball/h3`} class="card team-card team-card--photo">
