---
import PageLayout from '../../../layouts/PageLayout.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import TeamCard from '../../../components/TeamCard.astro';
import CTA from '../../../components/CTA.astro';
import { t } from '../../../lib/i18n';
import { fetchAllTeams } from '../../../lib/pocketbase';
import type { TeamData } from '../../../data/teams';

const locale = 'de';
const basePath = `/${locale}/basketball`;

const allTeams = await fetchAllTeams();
const bb = (cat: string) =>
  allTeams
    .filter((t: TeamData) => t.sport === 'basketball' && t.category === cat)
    .sort((a: TeamData, b: TeamData) => a.order - b.order);

const women = bb('women');
const men = bb('men');
const youth = bb('youth');

const moreText = `${t(locale, 'bbMore')} &rarr;`;
---
<PageLayout
  title="Basketball — KSC Wiedikon"
  description="Alle Basketball-Teams des KSC Wiedikon — Von der 1. Liga bis U8."
  locale={locale}
  pageTitle={t(locale, 'bbTitle')}
  pageSubtitle={t(locale, 'bbSubtitle')}
>
  <!-- Damen -->
  <section class="section">
    <div class="container">
      <SectionHeader title={t(locale, 'bbWomen')} />
      <div class="grid grid-4">
        {women.map((team: TeamData) => (
          <TeamCard team={team} locale={locale} basePath={basePath} moreText={moreText} />
        ))}
      </div>
    </div>
  </section>

  <!-- Herren -->
  <section class="section-alt">
    <div class="container">
      <SectionHeader title={t(locale, 'bbMen')} />
      <div class="grid grid-4">
        {men.map((team: TeamData) => (
          <TeamCard team={team} locale={locale} basePath={basePath} moreText={moreText} />
        ))}
      </div>
    </div>
  </section>

  <!-- Nachwuchs -->
  <section class="section">
    <div class="container">
      <SectionHeader title={t(locale, 'bbYouth')} />
      <div class="grid grid-4">
        {youth.map((team: TeamData) => (
          <TeamCard team={team} locale={locale} basePath={basePath} moreText={moreText} />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTA
    title={t(locale, 'bbCTA')}
    text={t(locale, 'bbCTAText')}
    buttonLabel={t(locale, 'bbCTAButton')}
    buttonHref={`/${locale}/club/kontakt`}
  />

  <script src="../../../islands/scroll-animations.ts"></script>
</PageLayout>
