---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { t } from '../../../lib/i18n';
import contactPersonsData from '../../../data/contact-persons.json';

const locale = 'de';
const contactPersons = contactPersonsData;
const volleyballContacts = contactPersons.filter(c => c.sport === 'volleyball');
const basketballContacts = contactPersons.filter(c => c.sport === 'basketball');
---
<BaseLayout
  title="Kontakt — KSC Wiedikon"
  description="Kontaktiere den KSC Wiedikon — Volleyball und Basketball in Zürich-Wiedikon."
  locale={locale}
>
  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <h1>{t(locale, 'contactTitle')}</h1>
      <p style="font-size: var(--text-lg); margin-top: var(--space-sm); opacity: 0.85;">{t(locale, 'contactSubtitle')}</p>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="section">
    <div class="container">
      <div class="contact-layout">

        <!-- Contact Form -->
        <div class="contact-form">
          <h2>{t(locale, 'contactFormHeading')}</h2>
          <form id="contact-form" action="#" method="post">
            <div class="form-row">
              <div class="form-group">
                <label for="vorname">{t(locale, 'contactFirstName')}</label>
                <input type="text" id="vorname" name="vorname" placeholder={t(locale, 'contactFirstNamePlaceholder')} required>
              </div>
              <div class="form-group">
                <label for="nachname">{t(locale, 'contactLastName')}</label>
                <input type="text" id="nachname" name="nachname" placeholder={t(locale, 'contactLastNamePlaceholder')} required>
              </div>
            </div>
            <div class="form-group">
              <label for="email">{t(locale, 'contactEmail')}</label>
              <input type="email" id="email" name="email" placeholder={t(locale, 'contactEmailPlaceholder')} required>
            </div>
            <div class="form-group">
              <label for="betreff">{t(locale, 'contactSubject')}</label>
              <select id="betreff" name="betreff" required>
                <option value="" disabled selected>{t(locale, 'contactSubjectPlaceholder')}</option>
                <option value="allgemein">{t(locale, 'contactSubjectGeneral')}</option>
                <option value="volleyball">{t(locale, 'contactSubjectVolleyball')}</option>
                <option value="basketball">{t(locale, 'contactSubjectBasketball')}</option>
                <option value="sponsoring">{t(locale, 'contactSubjectSponsoring')}</option>
                <option value="mitgliedschaft">{t(locale, 'contactSubjectMembership')}</option>
                <option value="sonstiges">{t(locale, 'contactSubjectOther')}</option>
              </select>
            </div>
            <div class="form-group" id="team-group" style="display: none;">
              <label for="team-select">{t(locale, 'contactTeam')}</label>
              <select id="team-select" name="team">
                <option value="" disabled selected>{t(locale, 'contactTeamPlaceholder')}</option>
              </select>
            </div>
            <div class="form-group">
              <label for="nachricht">{t(locale, 'contactMessage')}</label>
              <textarea id="nachricht" name="nachricht" placeholder={t(locale, 'contactMessagePlaceholder')} required></textarea>
            </div>
            <div id="turnstile-container" class="form-group"></div>
            <button type="submit" class="form-submit">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
              <span>{t(locale, 'contactSubmit')}</span>
            </button>
          </form>
          <div id="form-feedback" style="display: none;"></div>
        </div>

        <!-- Sidebar -->
        <div class="contact-sidebar">
          <h2>{t(locale, 'contactSidebar')}</h2>

          <div class="contact-info-card">
            <h3>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--kscw-blue, #4A55A2)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              <span>{t(locale, 'contactGeneral')}</span>
            </h3>
            <p>
              KSC Wiedikon<br>
              <a href="mailto:kontakt@kscw.ch">kontakt@kscw.ch</a>
            </p>
          </div>

          {volleyballContacts.length > 0 && (
            <div class="contact-info-card">
              <h3>
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--kscw-blue, #4A55A2)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20"/><path d="M2 12c3-3 6.5-5 10-5s7 2 10 5"/><path d="M2 12c3 3 6.5 5 10 5s7-2 10-5"/></svg>
                Volleyball
              </h3>
              {volleyballContacts.map((contact, i) => (
                <p style={i > 0 ? 'margin-top: var(--space-sm);' : ''}>
                  {contact.name}<br>
                  <a href={`mailto:${contact.email}`}>{contact.email}</a>
                </p>
              ))}
            </div>
          )}

          {basketballContacts.length > 0 && (
            <div class="contact-info-card">
              <h3>
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ea580c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M7 12a5 5 0 0 1 10 0"/><path d="M12 7a5 5 0 0 0 0 10"/></svg>
                Basketball
              </h3>
              {basketballContacts.map((contact, i) => (
                <p style={i > 0 ? 'margin-top: var(--space-sm);' : ''}>
                  {contact.name}<br>
                  <a href={`mailto:${contact.email}`}>{contact.email}</a>
                </p>
              ))}
            </div>
          )}

          <div class="contact-info-card">
            <h3>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--kscw-blue, #4A55A2)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" x2="15.42" y1="13.51" y2="17.49"/><line x1="15.41" x2="8.59" y1="6.51" y2="10.49"/></svg>
              <span>{t(locale, 'contactSocialMedia')}</span>
            </h3>
            <div class="social-links">
              <a href="https://www.facebook.com/kscwiedikon/" class="social-link">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                KSC-Wiedikon
              </a>
              <a href="https://www.instagram.com/ksc_wiedikon/" class="social-link">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
                @ksc_wiedikon
              </a>
            </div>
          </div>

        </div>

      </div>
    </div>
  </section>

  <!-- Scripts -->
  <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  <script is:inline src="/js/contact-form.js"></script>
  <script src="../../../islands/scroll-animations.ts"></script>
</BaseLayout>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-2xl);
    align-items: start;
  }
  @media (max-width: 768px) {
    .contact-layout { grid-template-columns: 1fr; }
  }
  .contact-form {
    background: var(--bg-white);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
  }
  .contact-form h2 {
    font-size: var(--text-xl);
    font-weight: 700;
    margin-bottom: var(--space-lg);
    color: var(--text-primary);
  }
  .form-group {
    margin-bottom: var(--space-md);
  }
  .form-group label {
    display: block;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-xs);
  }
  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 0.625rem 0.875rem;
    font-size: var(--text-sm);
    font-family: 'Inter', sans-serif;
    border: 1px solid var(--border);
    border-radius: var(--radius-md, 8px);
    background: var(--bg-white);
    color: var(--text-primary);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    box-sizing: border-box;
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--kscw-blue, #4A55A2);
    box-shadow: 0 0 0 3px rgba(74, 85, 162, 0.15);
  }
  .form-group textarea {
    min-height: 140px;
    resize: vertical;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }
  @media (max-width: 480px) {
    .form-row { grid-template-columns: 1fr; }
  }
  .form-submit {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    padding: 0.75rem 1.5rem;
    font-size: var(--text-sm);
    font-weight: 600;
    font-family: 'Inter', sans-serif;
    color: #ffffff;
    background: var(--kscw-blue, #4A55A2);
    border: none;
    border-radius: var(--radius-md, 8px);
    cursor: pointer;
    transition: background 0.2s ease, transform 0.1s ease;
  }
  .form-submit:hover {
    background: #3b4590;
  }
  .form-submit:active {
    transform: scale(0.98);
  }
  .contact-sidebar h2 {
    font-size: var(--text-xl);
    font-weight: 700;
    margin-bottom: var(--space-lg);
  }
  .contact-info-card {
    background: var(--bg-white);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    margin-bottom: var(--space-lg);
  }
  .contact-info-card h3 {
    font-size: var(--text-base);
    font-weight: 700;
    margin-bottom: var(--space-sm);
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    color: var(--text-primary);
  }
  .contact-info-card p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.8;
    margin: 0;
  }
  .contact-info-card a {
    color: var(--kscw-blue, #4A55A2);
    text-decoration: underline;
  }
  .social-links {
    display: flex;
    gap: var(--space-md);
    margin-top: var(--space-md);
  }
  .social-link {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .social-link:hover {
    color: var(--kscw-blue, #4A55A2);
  }
  #team-group {
    overflow: hidden;
    transition: max-height 0.3s ease, opacity 0.3s ease;
  }
  #team-group[style*="display: none"] {
    max-height: 0;
    opacity: 0;
  }
  .form-feedback {
    padding: 0.875rem 1rem;
    border-radius: var(--radius-md, 8px);
    font-size: var(--text-sm);
    font-weight: 500;
    margin-top: var(--space-md);
  }
  .form-feedback--success {
    background: rgba(34, 197, 94, 0.1);
    color: #16a34a;
    border: 1px solid rgba(34, 197, 94, 0.3);
  }
  .form-feedback--error {
    background: rgba(239, 68, 68, 0.1);
    color: #dc2626;
    border: 1px solid rgba(239, 68, 68, 0.3);
  }
  @media (prefers-color-scheme: dark) {
    .form-feedback--success { color: #4ade80; }
    .form-feedback--error { color: #f87171; }
  }
  .form-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
  #turnstile-container {
    min-height: 0;
  }
</style>
