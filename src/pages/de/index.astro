---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import { t } from '../../lib/i18n';

const locale = 'de';
---
<BaseLayout
  title="KSC Wiedikon — Basketball & Volleyball"
  description="KSC Wiedikon — Basketball und Volleyball seit 1982. Sportverein in Zürich-Wiedikon mit über 30 Teams."
  locale={locale}
>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <img src="/images/kscw_trio.png" alt="" class="hero-logo" aria-hidden="true">
        <h1>KSC Wiedikon</h1>
        <p class="hero-subtitle">{t(locale, 'homeSubtitle')}</p>
        <div class="hero-buttons">
          <a href={`/${locale}/volleyball/`} class="btn sport-btn sport-btn--vb">Volleyball</a>
          <a href={`/${locale}/basketball/`} class="btn sport-btn sport-btn--bb">Basketball</a>
        </div>
      </div>
    </div>
  </section>

  <!-- News -->
  <section class="section" id="news">
    <div class="container">
      <SectionHeader title={t(locale, 'homeNews')} />
      <div id="news-grid" class="grid grid-3">
        <!-- Populated by client-side JS -->
      </div>
    </div>
  </section>

  <!-- Upcoming Games -->
  <section class="section-alt" id="upcoming-games">
    <div class="container">
      <SectionHeader title={t(locale, 'homeUpcomingGames')} />
      <div class="sport-tabs" data-target="upcoming-games-list">
        <button class="sport-tab active" data-filter="all">Alle</button>
        <button class="sport-tab" data-filter="volleyball">Volleyball</button>
        <button class="sport-tab" data-filter="basketball">Basketball</button>
      </div>
      <table class="game-table" id="upcoming-games-list">
        <tbody><!-- Populated by client-side JS --></tbody>
      </table>
    </div>
  </section>

  <!-- Recent Results -->
  <section class="section" id="recent-results">
    <div class="container">
      <SectionHeader title={t(locale, 'homeRecentResults')} />
      <div class="sport-tabs" data-target="recent-results-list">
        <button class="sport-tab active" data-filter="all">Alle</button>
        <button class="sport-tab" data-filter="volleyball">Volleyball</button>
        <button class="sport-tab" data-filter="basketball">Basketball</button>
      </div>
      <table class="game-table" id="recent-results-list">
        <tbody><!-- Populated by client-side JS --></tbody>
      </table>
    </div>
  </section>

  <!-- Sponsors -->
  <section class="section-alt" id="sponsors">
    <div class="container">
      <SectionHeader
        title={t(locale, 'homePartners')}
        actionHref={`/${locale}/sponsoren/`}
        actionLabel={t(locale, 'homeAllSponsors')}
      />
      <div class="sponsor-overflow">
        <div id="sponsor-track" class="sponsor-track">
          <!-- Populated by client-side JS -->
        </div>
      </div>
    </div>
  </section>

  <!-- Client-side data loading (same as current site) -->
  <script is:inline src="/js/data.js"></script>
  <script is:inline src="/js/game-modal.js"></script>
  <script is:inline>
    (function () {
      'use strict';

      // Loading placeholders
      ['news-grid'].forEach(function(id) {
        var el = document.getElementById(id);
        if (el && !el.children.length) {
          var p = document.createElement('div');
          p.style.textAlign = 'center'; p.style.padding = '2rem'; p.style.opacity = '0.5';
          p.textContent = 'Laden...';
          el.appendChild(p);
        }
      });
      // Table loading rows
      ['upcoming-games-list', 'recent-results-list'].forEach(function(id) {
        var tbl = document.getElementById(id);
        if (tbl) {
          var tbody = tbl.querySelector('tbody') || tbl;
          if (!tbody.children.length) {
            var tr = document.createElement('tr');
            var td = document.createElement('td');
            td.setAttribute('colspan', '6');
            td.style.textAlign = 'center'; td.style.padding = '2rem'; td.style.opacity = '0.5';
            td.textContent = 'Laden...';
            tr.appendChild(td);
            tbody.appendChild(tr);
          }
        }
      });

      // Sport icons — filled versions matching Wiedisync (hardcoded SVG, safe)
      var VB_SVG = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" fill="#FFC832" stroke="#4A55A2" stroke-width="1.5"/><path d="M11.1 7.1a16.55 16.55 0 0 1 10.9 4" stroke="#4A55A2" stroke-width="1.5"/><path d="M12 12a12.6 12.6 0 0 1-8.7 5" stroke="#4A55A2" stroke-width="1.5"/><path d="M16.8 13.6a16.55 16.55 0 0 1-9 7.5" stroke="#4A55A2" stroke-width="1.5"/><path d="M20.7 17a12.8 12.8 0 0 0-8.7-5 13.3 13.3 0 0 1 0-10" stroke="#4A55A2" stroke-width="1.5"/><path d="M6.3 3.8a16.55 16.55 0 0 0 1.9 11.5" stroke="#4A55A2" stroke-width="1.5"/></svg>';
      var BB_SVG = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="transform:rotate(90deg)"><circle cx="12" cy="12" r="10" fill="#F97316"/><path d="M4.93 4.93c4.08 2.64 8.74 3.2 14.14 0"/><path d="M4.93 19.07c4.08-2.64 8.74-3.2 14.14 0"/><line x1="12" y1="2" x2="12" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/></svg>';

      function sportSvg(game) {
        return (game.sport === 'basketball' || game.teamShort.indexOf('BB-') === 0) ? BB_SVG : VB_SVG;
      }

      function createIconEl(game) {
        var span = document.createElement('span');
        span.className = 'game-sport-icon';
        // SAFE: sportSvg() returns only hardcoded VB_SVG or BB_SVG constants defined above.
        // No user input flows into this string. Using innerHTML for SVG namespace compat.
        span.innerHTML = sportSvg(game); // eslint-disable-line no-unsanitized/property
        return span;
      }

      function createChip(D, teamShort) {
        var t = D.getTeam(teamShort);
        var chip = document.createElement('span');
        chip.className = 'chip';
        if (t) {
          chip.style.background = t.bg; chip.style.color = t.text;
          chip.style.border = '1px solid ' + t.border; chip.textContent = t.short;
        } else {
          chip.style.background = '#e2e8f0'; chip.style.color = '#475569'; chip.textContent = teamShort;
        }
        return chip;
      }

      // ── Game data cache for filtering ──
      var cachedUpcoming = [];
      var cachedCompleted = [];

      function makeCell(content, className) {
        var td = document.createElement('td');
        if (className) td.className = className;
        if (typeof content === 'string') td.textContent = content;
        else if (content) td.appendChild(content);
        return td;
      }

      function buildGameRow(D, game, showScore) {
        var tr = document.createElement('tr');
        tr.className = 'fade-in';
        tr._gameData = game; // store for click handler

        // 1: sport icon
        tr.appendChild(makeCell(createIconEl(game), 'gt-icon'));

        // 2: date
        tr.appendChild(makeCell(D.formatDate(game.date), 'gt-date'));

        // 3: time
        tr.appendChild(makeCell(game.time || '', 'gt-time'));

        // 4: team chip
        tr.appendChild(makeCell(createChip(D, game.teamShort), 'gt-team'));

        // 5: home/away
        var badge = document.createElement('span');
        badge.className = 'game-badge ' + (game.isHome ? 'home' : 'away');
        badge.textContent = game.isHome ? 'Heim' : 'Ausw.';
        tr.appendChild(makeCell(badge, 'gt-loc'));

        // 6: matchup
        var matchup = game.isHome ? ('KSCW vs ' + game.opponent) : (game.opponent + ' vs KSCW');
        tr.appendChild(makeCell(matchup, 'gt-matchup'));

        // 7: score (results) or empty spacer (upcoming)
        if (showScore && game.score) {
          var scoreSpan = document.createElement('span');
          var win = D.isWin(game);
          scoreSpan.className = 'game-score';
          if (win === true) scoreSpan.className += ' win';
          else if (win === false) scoreSpan.className += ' loss';
          scoreSpan.textContent = game.score;
          tr.appendChild(makeCell(scoreSpan, 'gt-score'));
        } else {
          tr.appendChild(makeCell('', 'gt-score'));
        }

        return tr;
      }

      function renderGameTable(tableId, games, showScore) {
        var tbl = document.getElementById(tableId);
        if (!tbl) return;
        var tbody = tbl.querySelector('tbody') || tbl;
        while (tbody.firstChild) tbody.removeChild(tbody.firstChild);
        var D = window.KSCW;
        if (!games.length) {
          var tr = document.createElement('tr');
          var td = document.createElement('td');
          td.setAttribute('colspan', '7');
          td.className = 'game-empty';
          td.textContent = 'Keine Spiele gefunden.';
          tr.appendChild(td); tbody.appendChild(tr);
          return;
        }
        var frag = document.createDocumentFragment();
        for (var i = 0; i < games.length; i++) {
          frag.appendChild(buildGameRow(D, games[i], showScore));
        }
        tbody.appendChild(frag);
      }

      function renderAll() {
        var D = window.KSCW;
        if (!D) return;

        // Cache game data
        cachedUpcoming = D.getUpcomingGames().slice(0, 10);
        cachedCompleted = D.getCompletedGames().slice(0, 10);

        // Render game tables
        renderGameTable('upcoming-games-list', cachedUpcoming.slice(0, 5), false);
        renderGameTable('recent-results-list', cachedCompleted.slice(0, 5), true);

        // News Cards
        var newsGrid = document.getElementById('news-grid');
        if (newsGrid && D.news) {
          while (newsGrid.firstChild) newsGrid.removeChild(newsGrid.firstChild);
          var articles = D.news.slice(0, 6);
          var fragment = document.createDocumentFragment();
          for (var i = 0; i < articles.length; i++) {
            var n = articles[i];
            var article = document.createElement('article');
            article.className = 'card news-card fade-in';
            var imgPlaceholder = document.createElement('div');
            imgPlaceholder.className = 'card-img-placeholder';
            var iconSvg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
            iconSvg.setAttribute('viewBox', '0 0 24 24');
            iconSvg.setAttribute('fill', 'none');
            iconSvg.setAttribute('stroke', 'currentColor');
            iconSvg.setAttribute('stroke-width', '1.5');
            iconSvg.style.width = '48px'; iconSvg.style.height = '48px'; iconSvg.style.opacity = '0.3';
            var path1 = document.createElementNS('http://www.w3.org/2000/svg', 'path');
            path1.setAttribute('d', 'M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2');
            iconSvg.appendChild(path1); imgPlaceholder.appendChild(iconSvg);
            article.appendChild(imgPlaceholder);
            var body = document.createElement('div'); body.className = 'card-body';
            var meta = document.createElement('div'); meta.className = 'flex items-center gap-sm mb-md';
            var dateSpan = document.createElement('span'); dateSpan.className = 'news-date';
            dateSpan.textContent = D.formatDate(n.date); meta.appendChild(dateSpan);
            var catBadge = document.createElement('span'); catBadge.className = 'badge';
            if (n.category === 'volleyball') { catBadge.className += ' badge-blue'; catBadge.textContent = 'Volleyball'; }
            else if (n.category === 'basketball') { catBadge.className += ' badge-gold'; catBadge.textContent = 'Basketball'; }
            else { catBadge.textContent = 'Club'; }
            meta.appendChild(catBadge); body.appendChild(meta);
            var title = document.createElement('h3'); title.textContent = n.title; body.appendChild(title);
            var excerpt = document.createElement('p'); excerpt.className = 'news-excerpt';
            excerpt.textContent = n.excerpt; body.appendChild(excerpt);
            article.appendChild(body); fragment.appendChild(article);
          }
          newsGrid.appendChild(fragment);
        }

        // Sponsor Carousel
        var sponsorTrack = document.getElementById('sponsor-track');
        if (sponsorTrack) {
          fetch('https://kscw-api.lucanepa.com/api/public/sponsors')
            .then(function (res) { return res.json(); })
            .then(function (data) {
              var allSponsors = data.sponsors || [];
              if (!allSponsors.length) return;
              var spFrag = document.createDocumentFragment();
              for (var pass = 0; pass < 2; pass++) {
                for (var s = 0; s < allSponsors.length; s++) {
                  var sp = allSponsors[s];
                  var link = document.createElement('a');
                  link.href = sp.website_url || '#';
                  link.className = 'sponsor-item';
                  if (sp.website_url) { link.target = '_blank'; link.rel = 'noopener noreferrer'; }
                  link.title = sp.name;
                  if (sp.logo_url) {
                    var img = document.createElement('img');
                    img.src = sp.logo_url;
                    img.alt = sp.name;
                    img.style.maxHeight = '40px'; img.style.objectFit = 'contain';
                    link.appendChild(img);
                  } else {
                    var label = document.createElement('span');
                    label.textContent = sp.name; link.appendChild(label);
                  }
                  spFrag.appendChild(link);
                }
              }
              sponsorTrack.appendChild(spFrag);
            }).catch(function () {});
        }
      }

      // ── Sport filter tabs ──
      function filterBySport(source, sport) {
        if (sport === 'all') return source.slice(0, 5);
        return source.filter(function (g) { return g.sport === sport; }).slice(0, 5);
      }

      document.querySelectorAll('.sport-tabs').forEach(function (tabGroup) {
        tabGroup.addEventListener('click', function (e) {
          var btn = e.target.closest('.sport-tab');
          if (!btn) return;
          var filter = btn.getAttribute('data-filter');
          var targetId = tabGroup.getAttribute('data-target');
          tabGroup.querySelectorAll('.sport-tab').forEach(function (b) { b.classList.remove('active'); });
          btn.classList.add('active');
          var isUpcoming = targetId === 'upcoming-games-list';
          var source = isUpcoming ? cachedUpcoming : cachedCompleted;
          renderGameTable(targetId, filterBySport(source, filter), !isUpcoming);
          requestAnimationFrame(observeNewFadeIns);
        });
      });

      function observeNewFadeIns() {
        var els = document.querySelectorAll('.fade-in:not(.visible)');
        if (!els.length) return;
        if (!('IntersectionObserver' in window)) {
          els.forEach(function(el) { el.classList.add('visible'); });
          return;
        }
        var obs = new IntersectionObserver(function(entries, o) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) { entry.target.classList.add('visible'); o.unobserve(entry.target); }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -20px 0px' });
        els.forEach(function(el) { obs.observe(el); });
      }

      function renderAndAnimate() { renderAll(); requestAnimationFrame(observeNewFadeIns); }

      if (window.KSCW && window.KSCW.ready) {
        renderAndAnimate();
      } else {
        document.addEventListener('kscw-data-ready', renderAndAnimate);
        var poll = setInterval(function () {
          if (window.KSCW && window.KSCW.ready) { clearInterval(poll); renderAndAnimate(); }
        }, 100);
      }

      // ── Game row click → modal ──
      document.querySelectorAll('.game-table').forEach(function (tbl) {
        tbl.addEventListener('click', function (e) {
          var tr = e.target.closest('tr');
          if (tr && tr._gameData && window.showGameModal) {
            window.showGameModal(tr._gameData, 'de');
          }
        });
      });
    })();
  </script>
  <script src="../../islands/scroll-animations.ts"></script>
  <script src="../../islands/sponsor-carousel.ts"></script>
</BaseLayout>
