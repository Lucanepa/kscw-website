---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import { t } from '../../lib/i18n';
import heroLogo from '../../assets/images/kscw_trio.png';
import { getLatestNews } from '../../lib/fetch/news';
import { getUpcomingEvents } from '../../lib/fetch/events';

const locale = 'de';

let newsArticles: any[] = [];
try {
  newsArticles = await getLatestNews(6);
} catch (e) {
  console.warn('Failed to fetch news:', e);
}

let upcomingEvents: any[] = [];
try {
  const events = await getUpcomingEvents(3);
  upcomingEvents = events.map(ev => ({
    title: ev.title,
    date: ev.startDate,
    time: '',
    location: ev.location || '',
    category: ev.eventType || 'other',
    description: ev.description || '',
  }));
} catch (e) {
  console.warn('Failed to fetch events:', e);
}
---
<BaseLayout
  title="KSC Wiedikon — Basketball & Volleyball"
  description="KSC Wiedikon — Basketball und Volleyball seit 1982. Sportverein in Zürich-Wiedikon mit über 30 Teams."
  locale={locale}
>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <Image src={heroLogo} alt="" class="hero-logo" aria-hidden="true" loading="eager" />
        <h1>KSC Wiedikon</h1>
        <p class="hero-subtitle">{t(locale, 'homeSubtitle')}</p>
        <div class="hero-buttons">
          <a href={`/${locale}/volleyball/`} class="btn sport-btn sport-btn--vb">Volleyball</a>
          <a href={`/${locale}/basketball/`} class="btn sport-btn sport-btn--bb">Basketball</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Games (upcoming + recent results side-by-side on desktop) -->
  <section class="section" id="games">
    <div class="container">
      <div class="games-grid">
        <div class="games-grid__col">
          <SectionHeader title={t(locale, 'homeUpcomingGames')} />
          <div class="sport-tabs" data-target="upcoming-games-list">
            <button class="sport-tab active" data-filter="all">Alle</button>
            <button class="sport-tab" data-filter="volleyball">Volleyball</button>
            <button class="sport-tab" data-filter="basketball">Basketball</button>
          </div>
          <table class="game-table" id="upcoming-games-list">
            <tbody><!-- Populated by client-side JS --></tbody>
          </table>
        </div>
        <div class="games-grid__col">
          <SectionHeader title={t(locale, 'homeRecentResults')} />
          <div class="sport-tabs" data-target="recent-results-list">
            <button class="sport-tab active" data-filter="all">Alle</button>
            <button class="sport-tab" data-filter="volleyball">Volleyball</button>
            <button class="sport-tab" data-filter="basketball">Basketball</button>
          </div>
          <table class="game-table" id="recent-results-list">
            <tbody><!-- Populated by client-side JS --></tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- News -->
  <section class="section-alt" id="news">
    <div class="container">
      <SectionHeader title={t(locale, 'homeNews')} />
      <div class="grid grid-3">
        {newsArticles.length > 0 ? (
          newsArticles.map(n => (
            <article class="card news-card fade-in" data-news-id={n.id}>
              <div class="card-img-placeholder">
                {n.imageUrl ? (
                  <img src={n.imageUrl} alt={n.title} />
                ) : (
                  <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8"/><path d="M15 18h-5"/><path d="M10 6h8v4h-8V6Z"/></svg>
                )}
              </div>
              <div class="card-body">
                <div class="flex items-center gap-sm mb-md">
                  <span class="news-date">{new Date(n.date).toLocaleDateString('de-CH')}</span>
                  <span class={`badge ${n.category === 'volleyball' ? 'badge-blue' : n.category === 'basketball' ? 'badge-orange' : ''}`}>
                    {n.category === 'volleyball' ? 'Volleyball' : n.category === 'basketball' ? 'Basketball' : 'Club'}
                  </span>
                </div>
                <h3>{n.title}</h3>
                <p class="news-excerpt">{n.excerpt}</p>
              </div>
              <script type="application/json" class="news-data" set:html={JSON.stringify({ title: n.title, body: n.body, date: n.date, category: n.category, image: n.imageUrl, author: n.author })} />
            </article>
          ))
        ) : (
          <p>Keine News vorhanden.</p>
        )}
      </div>
    </div>
  </section>

  <!-- Events -->
  {upcomingEvents.length > 0 && (
    <section class="section" id="events">
      <div class="container">
        <SectionHeader title={t(locale, 'homeEvents')} />
        <div class="grid grid-3">
          {upcomingEvents.map(ev => (
            <article class={`card event-card fade-in${ev.description ? ' event-card--clickable' : ''}`}>
              <div class="card-body">
                <div class="flex items-center gap-sm mb-md">
                  <span class="news-date">{new Date(ev.date).toLocaleDateString('de-CH')}</span>
                  <span class="badge badge-green">
                    {ev.category === 'social' ? t(locale, 'eventCategorySocial')
                      : ev.category === 'verein' ? t(locale, 'eventCategoryClub')
                      : ev.category === 'meeting' ? t(locale, 'eventCategoryAssembly')
                      : ev.category === 'tournament' ? t(locale, 'eventCategoryTournament')
                      : t(locale, 'eventCategoryOther')}
                  </span>
                  {ev.description && <span class="event-expand-icon" aria-hidden="true">&#x25BC;</span>}
                </div>
                <h3>{ev.title}</h3>
                {ev.time && <p class="event-location">{ev.time}</p>}
                {ev.location && <p class="event-location">{ev.location}</p>}
              </div>
              {ev.description && (
                <div class="event-description" set:html={ev.description} />
              )}
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Scoreboard -->
  <section class="section" id="scoreboard">
    <div class="container">
      <SectionHeader title="KSCW Scoreboard" />
      <div id="home-scoreboard" data-scoreboard="all"></div>
    </div>
  </section>

  <!-- Sponsors -->
  <section class="section-alt" id="sponsors">
    <div class="container">
      <SectionHeader
        title={t(locale, 'homePartners')}
        actionHref={`/${locale}/sponsoren/`}
        actionLabel={t(locale, 'homeAllSponsors')}
      />
      <div class="sponsor-overflow">
        <div id="sponsor-track" class="sponsor-track">
          <!-- Populated by client-side JS -->
        </div>
      </div>
    </div>
  </section>

  <!-- Client-side data loading -->
  <script is:inline src="/js/scoreboard.js"></script>
  <script is:inline src="/js/game-modal.js"></script>
  <script is:inline src="/js/news-modal.js"></script>
  <script is:inline>
    (function () {
      'use strict';

      var DIRECTUS_URL = (window.location.hostname === 'kscw.ch' || window.location.hostname === 'www.kscw.ch')
        ? 'https://directus.kscw.ch' : 'https://directus-dev.kscw.ch';

      // Table loading rows
      ['upcoming-games-list', 'recent-results-list'].forEach(function(id) {
        var tbl = document.getElementById(id);
        if (tbl) {
          var tbody = tbl.querySelector('tbody') || tbl;
          if (!tbody.children.length) {
            var tr = document.createElement('tr');
            var td = document.createElement('td');
            td.setAttribute('colspan', '6');
            td.style.textAlign = 'center'; td.style.padding = '2rem'; td.style.opacity = '0.5';
            td.textContent = 'Laden...';
            tr.appendChild(td);
            tbody.appendChild(tr);
          }
        }
      });

      // Sport icons — filled versions matching Wiedisync (hardcoded SVG, safe)
      var VB_SVG = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" fill="#FFC832" stroke="#4A55A2" stroke-width="1.5"/><path d="M11.1 7.1a16.55 16.55 0 0 1 10.9 4" stroke="#4A55A2" stroke-width="1.5"/><path d="M12 12a12.6 12.6 0 0 1-8.7 5" stroke="#4A55A2" stroke-width="1.5"/><path d="M16.8 13.6a16.55 16.55 0 0 1-9 7.5" stroke="#4A55A2" stroke-width="1.5"/><path d="M20.7 17a12.8 12.8 0 0 0-8.7-5 13.3 13.3 0 0 1 0-10" stroke="#4A55A2" stroke-width="1.5"/><path d="M6.3 3.8a16.55 16.55 0 0 0 1.9 11.5" stroke="#4A55A2" stroke-width="1.5"/></svg>';
      var BB_SVG = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="transform:rotate(90deg)"><circle cx="12" cy="12" r="10" fill="#F97316"/><path d="M4.93 4.93c4.08 2.64 8.74 3.2 14.14 0"/><path d="M4.93 19.07c4.08-2.64 8.74-3.2 14.14 0"/><line x1="12" y1="2" x2="12" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/></svg>';

      function sportSvg(game) {
        return (game.teamSport === 'basketball') ? BB_SVG : VB_SVG;
      }

      function createIconEl(game) {
        var span = document.createElement('span');
        span.className = 'game-sport-icon';
        // SAFE: sportSvg() returns only hardcoded VB_SVG or BB_SVG constants defined above.
        // No user input flows into this string. Using innerHTML for SVG namespace compat.
        span.innerHTML = sportSvg(game); // eslint-disable-line no-unsanitized/property
        return span;
      }

      function createChip(game) {
        var chip = document.createElement('span');
        chip.className = 'chip';
        if (game.teamColor) {
          chip.style.background = game.teamColor; chip.style.color = '#fff';
          chip.textContent = game.teamName || '';
        } else {
          chip.style.background = '#e2e8f0'; chip.style.color = '#475569';
          chip.textContent = game.teamName || '';
        }
        return chip;
      }

      // ── Game data cache for filtering ──
      var cachedUpcoming = [];
      var cachedCompleted = [];

      function makeCell(content, className) {
        var td = document.createElement('td');
        if (className) td.className = className;
        if (typeof content === 'string') td.textContent = content;
        else if (content) td.appendChild(content);
        return td;
      }

      function formatDate(iso) {
        if (!iso) return '\u2013';
        try {
          var d = new Date(iso + 'T12:00:00');
          return d.toLocaleDateString('de-CH', { day: '2-digit', month: '2-digit', year: 'numeric' });
        } catch (e) { return '\u2013'; }
      }

      function buildGameRow(game, showScore) {
        var tr = document.createElement('tr');
        tr.className = 'fade-in';
        tr._gameData = game; // store for click handler

        var isHome = game.homeTeam && game.homeTeam.indexOf('KSCW') !== -1;

        // 1: sport icon
        tr.appendChild(makeCell(createIconEl(game), 'gt-icon'));

        // 2: date
        tr.appendChild(makeCell(formatDate(game.date), 'gt-date'));

        // 3: time
        tr.appendChild(makeCell(game.time ? game.time.slice(0, 5) : '', 'gt-time'));

        // 4: team chip
        tr.appendChild(makeCell(createChip(game), 'gt-team'));

        // 5: home/away
        var badge = document.createElement('span');
        badge.className = 'game-badge ' + (isHome ? 'home' : 'away');
        badge.textContent = isHome ? 'Heim' : 'Ausw.';
        tr.appendChild(makeCell(badge, 'gt-loc'));

        // 6: matchup
        tr.appendChild(makeCell(game.homeTeam + ' vs ' + game.awayTeam, 'gt-matchup'));

        // 7: score (results) or empty spacer (upcoming)
        if (showScore && game.homeScore != null && game.awayScore != null) {
          var scoreSpan = document.createElement('span');
          var homeWin = game.homeScore > game.awayScore;
          var kscwWin = isHome ? homeWin : !homeWin;
          scoreSpan.className = 'game-score';
          if (kscwWin) scoreSpan.className += ' win';
          else scoreSpan.className += ' loss';
          scoreSpan.textContent = game.homeScore + ':' + game.awayScore;
          tr.appendChild(makeCell(scoreSpan, 'gt-score'));
        } else {
          tr.appendChild(makeCell('', 'gt-score'));
        }

        return tr;
      }

      function renderGameTable(tableId, games, showScore) {
        var tbl = document.getElementById(tableId);
        if (!tbl) return;
        var tbody = tbl.querySelector('tbody') || tbl;
        while (tbody.firstChild) tbody.removeChild(tbody.firstChild);
        if (!games.length) {
          var tr = document.createElement('tr');
          var td = document.createElement('td');
          td.setAttribute('colspan', '7');
          td.className = 'game-empty';
          td.textContent = 'Keine Spiele gefunden.';
          tr.appendChild(td); tbody.appendChild(tr);
          return;
        }
        var frag = document.createDocumentFragment();
        for (var i = 0; i < games.length; i++) {
          frag.appendChild(buildGameRow(games[i], showScore));
        }
        tbody.appendChild(frag);
      }

      // ── Fetch games from Directus ──
      var today = new Date().toISOString().slice(0, 10);
      var gameFields = 'id,game_id,date,time,home_team,away_team,home_score,away_score,status,type,league,season,sets_json,kscw_team.id,kscw_team.name,kscw_team.sport,kscw_team.color,hall.id,hall.name,hall.address';

      function mapGame(g) {
        return {
          id: g.id, gameId: g.game_id, date: g.date, time: g.time,
          homeTeam: g.home_team, awayTeam: g.away_team,
          homeScore: g.home_score, awayScore: g.away_score,
          status: g.status, type: g.type, league: g.league, season: g.season,
          setsJson: g.sets_json ? (typeof g.sets_json === 'string' ? JSON.parse(g.sets_json) : g.sets_json) : null,
          teamId: g.kscw_team ? String(g.kscw_team.id) : null,
          teamName: g.kscw_team ? g.kscw_team.name : null,
          teamSport: g.kscw_team ? g.kscw_team.sport : null,
          teamColor: g.kscw_team ? g.kscw_team.color : null,
          teamShort: g.kscw_team ? g.kscw_team.name : '',
          isHome: g.type === 'home',
          opponent: g.type === 'home' ? g.away_team : g.home_team,
          score: (g.home_score != null && g.away_score != null) ? g.home_score + ':' + g.away_score : null,
          hall: g.hall || null,
          sport: g.kscw_team ? g.kscw_team.sport : 'volleyball'
        };
      }

      function fetchGames() {
        var upcomingUrl = DIRECTUS_URL + '/items/games?fields=' + encodeURIComponent(gameFields)
          + '&sort=date,time&limit=10&filter=' + encodeURIComponent(JSON.stringify({ _and: [{ date: { _gte: today } }, { status: { _neq: 'cancelled' } }] }));
        var completedUrl = DIRECTUS_URL + '/items/games?fields=' + encodeURIComponent(gameFields)
          + '&sort=-date,-time&limit=10&filter=' + encodeURIComponent(JSON.stringify({ status: { _eq: 'completed' } }));

        Promise.all([
          fetch(upcomingUrl).then(function(r) { return r.json(); }),
          fetch(completedUrl).then(function(r) { return r.json(); })
        ]).then(function(results) {
          cachedUpcoming = (results[0].data || []).map(mapGame);
          cachedCompleted = (results[1].data || []).map(mapGame);
          renderGameTable('upcoming-games-list', cachedUpcoming.slice(0, 5), false);
          renderGameTable('recent-results-list', cachedCompleted.slice(0, 5), true);
          requestAnimationFrame(observeNewFadeIns);
        }).catch(function(err) { console.warn('Failed to fetch games:', err); });
      }

      // ── Sponsor Carousel ──
      function fetchSponsors() {
        var sponsorTrack = document.getElementById('sponsor-track');
        if (!sponsorTrack) return;
        fetch(DIRECTUS_URL + '/items/sponsors?fields=id,name,logo,logo_url,website_url&sort=name&limit=-1')
          .then(function (res) { return res.json(); })
          .then(function (data) {
            var allSponsors = data.data || [];
            if (!allSponsors.length) return;
            var spFrag = document.createDocumentFragment();
            for (var pass = 0; pass < 2; pass++) {
              for (var s = 0; s < allSponsors.length; s++) {
                var sp = allSponsors[s];
                var link = document.createElement('a');
                link.href = sp.website_url || '#';
                link.className = 'sponsor-item';
                if (sp.website_url) { link.target = '_blank'; link.rel = 'noopener noreferrer'; }
                link.title = sp.name;
                var logoSrc = sp.logo ? (DIRECTUS_URL + '/assets/' + sp.logo + '?width=300&quality=80') : sp.logo_url;
                if (logoSrc) {
                  var img = document.createElement('img');
                  img.src = logoSrc;
                  img.alt = sp.name;
                  img.style.maxHeight = '40px'; img.style.objectFit = 'contain';
                  link.appendChild(img);
                } else {
                  var label = document.createElement('span');
                  label.textContent = sp.name; link.appendChild(label);
                }
                spFrag.appendChild(link);
              }
            }
            sponsorTrack.appendChild(spFrag);
          }).catch(function () {});
      }

      // ── Sport filter tabs ──
      function filterBySport(source, sport) {
        if (sport === 'all') return source.slice(0, 5);
        return source.filter(function (g) { return g.sport === sport; }).slice(0, 5);
      }

      document.querySelectorAll('.sport-tabs').forEach(function (tabGroup) {
        tabGroup.addEventListener('click', function (e) {
          var btn = e.target.closest('.sport-tab');
          if (!btn) return;
          var filter = btn.getAttribute('data-filter');
          var targetId = tabGroup.getAttribute('data-target');
          tabGroup.querySelectorAll('.sport-tab').forEach(function (b) { b.classList.remove('active'); });
          btn.classList.add('active');
          var isUpcoming = targetId === 'upcoming-games-list';
          var source = isUpcoming ? cachedUpcoming : cachedCompleted;
          renderGameTable(targetId, filterBySport(source, filter), !isUpcoming);
          requestAnimationFrame(observeNewFadeIns);
        });
      });

      function observeNewFadeIns() {
        var els = document.querySelectorAll('.fade-in:not(.visible)');
        if (!els.length) return;
        if (!('IntersectionObserver' in window)) {
          els.forEach(function(el) { el.classList.add('visible'); });
          return;
        }
        var obs = new IntersectionObserver(function(entries, o) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) { entry.target.classList.add('visible'); o.unobserve(entry.target); }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -20px 0px' });
        els.forEach(function(el) { obs.observe(el); });
      }

      // ── Init ──
      fetchGames();
      fetchSponsors();

      // ── Game row click → modal ──
      document.querySelectorAll('.game-table').forEach(function (tbl) {
        tbl.addEventListener('click', function (e) {
          var tr = e.target.closest('tr');
          if (tr && tr._gameData && window.showGameModal) {
            window.showGameModal(tr._gameData, 'de');
          }
        });
      });
    })();
  </script>
  <script src="../../islands/event-expand.ts"></script>
  <script src="../../islands/scroll-animations.ts"></script>
  <script src="../../islands/sponsor-carousel.ts"></script>
</BaseLayout>
