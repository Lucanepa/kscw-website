---
import PageLayout from '../../../layouts/PageLayout.astro';
import { t } from '../../../lib/i18n';

const locale = 'de';
---
<PageLayout
  title="News — KSC Wiedikon"
  description="Alle Neuigkeiten des KSC Wiedikon — Basketball und Volleyball."
  locale={locale}
  pageTitle={t(locale, 'newsTitle')}
  pageSubtitle={t(locale, 'newsSubtitle')}
>
  <section class="section">
    <div class="container">
      <div class="sport-tabs" id="news-filter-tabs">
        <button class="sport-tab active" data-filter="all">Alle</button>
        <button class="sport-tab" data-filter="volleyball">Volleyball</button>
        <button class="sport-tab" data-filter="basketball">Basketball</button>
        <button class="sport-tab" data-filter="club">Club</button>
      </div>
      <div class="grid grid-3" id="news-grid">
        <p id="news-empty">{t(locale, 'newsEmpty')}</p>
      </div>
      <div class="text-center mt-lg" id="news-load-more-wrap" style="display:none;">
        <button class="btn btn-outline" id="news-load-more">{t(locale, 'newsLoadMore')}</button>
      </div>
    </div>
  </section>

  <!-- Newsletter Subscribe -->
  <section class="section-alt">
    <div class="container" style="max-width: 560px;">
      <div class="newsletter-section">
        <h2>{t(locale, 'newsletterTitle')}</h2>
        <p>{t(locale, 'newsletterText')}</p>
        <form id="newsletter-form">
          <div class="form-group">
            <input type="email" id="nl-email" class="form-input" placeholder={t(locale, 'newsletterEmail')} required>
          </div>
          <div class="form-group">
            <label class="form-label">{t(locale, 'newsletterCategories')}</label>
            <div class="nl-categories">
              <label class="nl-cat-option"><input type="checkbox" name="nl-category" value="volleyball" checked> Volleyball</label>
              <label class="nl-cat-option"><input type="checkbox" name="nl-category" value="basketball" checked> Basketball</label>
              <label class="nl-cat-option"><input type="checkbox" name="nl-category" value="club" checked> Club</label>
            </div>
          </div>
          <div id="nl-turnstile" style="margin-bottom: var(--space-sm);"></div>
          <button type="submit" class="btn btn-gold form-submit">{t(locale, 'newsletterSubscribe')}</button>
          <div id="nl-feedback" class="form-feedback" style="display:none;"></div>
        </form>
        <p class="text-sm text-muted mt-md">
          <a href="/feed.xml" style="color: var(--text-muted);">{t(locale, 'newsletterRss')}</a>
        </p>
      </div>
    </div>
  </section>

  <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  <script is:inline src="/js/newsletter-form.js"></script>

  <script is:inline src="/js/news-modal.js"></script>
  <script is:inline>
    (function () {
      'use strict';

      var DIRECTUS_URL = (window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1')
        ? 'https://directus-dev.kscw.ch' : 'https://directus.kscw.ch';

      var PAGE_SIZE = 12;
      var offset = 0;
      var currentFilter = 'all';
      var allArticles = [];

      var grid = document.getElementById('news-grid');
      var empty = document.getElementById('news-empty');
      var loadMoreWrap = document.getElementById('news-load-more-wrap');
      var loadMoreBtn = document.getElementById('news-load-more');

      function fetchNews(append) {
        if (!append) {
          offset = 0;
          grid.innerHTML = '';
          if (empty) { empty.style.display = ''; grid.appendChild(empty); }
        }
        var newsFields = 'id,title,title_en,slug,excerpt,body,category,author,published_at,image,date_created';
        var filter = { is_published: { _eq: true } };
        if (currentFilter !== 'all') filter.category = { _eq: currentFilter };
        var url = DIRECTUS_URL + '/items/news?fields=' + encodeURIComponent(newsFields)
          + '&filter=' + encodeURIComponent(JSON.stringify(filter))
          + '&sort=-published_at&limit=' + PAGE_SIZE + '&offset=' + offset;

        fetch(url)
          .then(function (res) { return res.json(); })
          .then(function (data) {
            var articles = data.data || [];
            if (!append && !articles.length) return;
            if (empty) empty.style.display = 'none';
            var locale = document.documentElement.lang || 'de';
            var svgIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8"/><path d="M15 18h-5"/><path d="M10 6h8v4h-8V6Z"/></svg>';
            var frag = document.createDocumentFragment();
            for (var i = 0; i < articles.length; i++) {
              var n = articles[i];
              var imageUrl = n.image ? (DIRECTUS_URL + '/assets/' + n.image + '?width=800&quality=80') : '';
              var date = n.published_at || n.date_created;
              var title = (locale === 'en' && n.title_en) ? n.title_en : n.title;
              var badgeClass = n.category === 'volleyball' ? 'badge-blue' : n.category === 'basketball' ? 'badge-orange' : '';
              var catLabel = n.category === 'volleyball' ? 'Volleyball' : n.category === 'basketball' ? 'Basketball' : 'Club';

              var article = document.createElement('article');
              article.className = 'card news-card fade-in visible';
              article.setAttribute('data-news-id', n.id);

              var imgDiv = document.createElement('div');
              imgDiv.className = 'card-img-placeholder';
              if (imageUrl) {
                var img = document.createElement('img');
                img.src = imageUrl;
                img.alt = title;
                imgDiv.appendChild(img);
              } else {
                imgDiv.innerHTML = svgIcon;
              }
              article.appendChild(imgDiv);

              var body = document.createElement('div');
              body.className = 'card-body';
              var meta = document.createElement('div');
              meta.className = 'flex items-center gap-sm mb-md';
              var dateSpan = document.createElement('span');
              dateSpan.className = 'news-date';
              dateSpan.textContent = new Date(date).toLocaleDateString(locale === 'en' ? 'en-CH' : 'de-CH');
              meta.appendChild(dateSpan);
              var badge = document.createElement('span');
              badge.className = 'badge ' + badgeClass;
              badge.textContent = catLabel;
              meta.appendChild(badge);
              body.appendChild(meta);

              var h3 = document.createElement('h3');
              h3.textContent = title;
              body.appendChild(h3);

              if (n.excerpt) {
                var p = document.createElement('p');
                p.className = 'news-excerpt';
                p.textContent = n.excerpt;
                body.appendChild(p);
              }
              article.appendChild(body);

              var script = document.createElement('script');
              script.type = 'application/json';
              script.className = 'news-data';
              script.textContent = JSON.stringify({ title: title, body: n.body, date: date, category: n.category, image: imageUrl, author: n.author });
              article.appendChild(script);

              frag.appendChild(article);
            }
            grid.appendChild(frag);
            offset += articles.length;

            // Show/hide load more
            if (articles.length < PAGE_SIZE) {
              loadMoreWrap.style.display = 'none';
            } else {
              loadMoreWrap.style.display = '';
            }
          }).catch(function () {});
      }

      // Filter tabs
      document.getElementById('news-filter-tabs').addEventListener('click', function (e) {
        var tab = e.target.closest('.sport-tab');
        if (!tab) return;
        document.querySelectorAll('#news-filter-tabs .sport-tab').forEach(function (t) { t.classList.remove('active'); });
        tab.classList.add('active');
        currentFilter = tab.getAttribute('data-filter');
        fetchNews(false);
      });

      // Load more
      loadMoreBtn.addEventListener('click', function () {
        fetchNews(true);
      });

      fetchNews(false);
    })();
  </script>
</PageLayout>
