---
import PageLayout from '../../../layouts/PageLayout.astro';
import { t } from '../../../lib/i18n';

const locale = 'de';
---
<PageLayout
  title="Anmeldung — KSC Wiedikon"
  description="Mitglied werden beim KSC Wiedikon — Anmeldung für Volleyball, Basketball und Passivmitgliedschaft."
  locale={locale}
  pageTitle={t(locale, 'registrationTitle')}
  pageSubtitle={t(locale, 'registrationSubtitle')}
>
  <section class="section">
    <div class="container" style="max-width: 720px;">

      <!-- Coach Note -->
      <div class="card" style="border-left: 4px solid var(--kscw-gold); margin-bottom: var(--space-xl);">
        <div class="card-body">
          <p style="color: var(--text-secondary); display: flex; align-items: flex-start; gap: var(--space-sm); margin: 0;">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--kscw-gold)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0; margin-top: 2px;"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
            <span>{t(locale, 'registrationCoachNote')}</span>
          </p>
        </div>
      </div>

      <form id="registration-form">

        <!-- Membership Type -->
        <div class="form-group">
          <label>{t(locale, 'registrationType')} *</label>
          <div style="display: flex; gap: var(--space-md); flex-wrap: wrap; margin-top: var(--space-xs);">
            <label class="radio-card">
              <input type="radio" name="membership_type" value="volleyball" required>
              <span>{t(locale, 'registrationTypeVolleyball')}</span>
            </label>
            <label class="radio-card">
              <input type="radio" name="membership_type" value="basketball" required>
              <span>{t(locale, 'registrationTypeBasketball')}</span>
            </label>
            <label class="radio-card">
              <input type="radio" name="membership_type" value="passive" required>
              <span>{t(locale, 'registrationTypePassive')}</span>
            </label>
          </div>
        </div>

        <!-- Common Fields -->
        <div class="form-row">
          <div class="form-group">
            <label for="vorname">{t(locale, 'registrationFirstName')} *</label>
            <input type="text" id="vorname" name="vorname" class="form-input" required>
          </div>
          <div class="form-group">
            <label for="nachname">{t(locale, 'registrationLastName')} *</label>
            <input type="text" id="nachname" name="nachname" class="form-input" required>
          </div>
        </div>

        <div class="form-group">
          <label for="email">{t(locale, 'registrationEmail')} *</label>
          <input type="email" id="email" name="email" class="form-input" required>
        </div>

        <div class="form-group">
          <label for="telefon">{t(locale, 'registrationPhone')} *</label>
          <input type="tel" id="telefon" name="telefon" class="form-input" required>
        </div>

        <div class="form-group">
          <label for="adresse">{t(locale, 'registrationAddress')} *</label>
          <input type="text" id="adresse" name="adresse" class="form-input" required>
        </div>

        <div class="form-row">
          <div class="form-group" style="flex: 0 0 120px; min-width: 0;">
            <label for="plz">{t(locale, 'registrationPLZ')} *</label>
            <input type="text" id="plz" name="plz" class="form-input" required>
          </div>
          <div class="form-group">
            <label for="ort">{t(locale, 'registrationCity')} *</label>
            <input type="text" id="ort" name="ort" class="form-input" required>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="geburtsdatum">{t(locale, 'registrationDOB')} *</label>
            <input type="date" id="geburtsdatum" name="geburtsdatum" class="form-input" required>
          </div>
          <div class="form-group">
            <label for="geschlecht">{t(locale, 'registrationGender')} *</label>
            <select id="geschlecht" name="geschlecht" class="form-select" required>
              <option value="" disabled selected>—</option>
              <option value="männlich">{t(locale, 'registrationGenderMale')}</option>
              <option value="weiblich">{t(locale, 'registrationGenderFemale')}</option>
            </select>
          </div>
        </div>

        <div class="form-group nationality-wrapper">
          <label>{t(locale, 'registrationNationality')} *</label>
          <input type="hidden" id="nationalitaet" name="nationalitaet" required>
          <button type="button" class="form-select nationality-trigger" id="nationality-trigger">
            <span id="nationality-trigger-text">—</span>
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 4 6 8 10 4"/></svg>
          </button>
          <div class="nationality-dropdown" id="nationality-dropdown">
            <input type="text" class="form-input nationality-search" id="nationality-search" placeholder="Suchen…" autocomplete="off">
            <div class="nationality-options" id="nationality-options"></div>
          </div>
        </div>

        <!-- ═══ VOLLEYBALL-ONLY FIELDS ═══ -->
        <div id="vb-fields" style="display: none;">
          <input type="hidden" id="anrede" name="anrede">

          <div class="form-group">
            <label for="funktion-vb">{t(locale, 'registrationFunktion')} *</label>
            <select id="funktion-vb" name="funktion_vb" class="form-select" data-conditional-required>
              <option value="" disabled selected>{t(locale, 'registrationFunktionPlaceholder')}</option>
              <option value="Spieler*in">{t(locale, 'registrationFunktionPlayer')}</option>
              <option value="Trainer*in">{t(locale, 'registrationFunktionCoach')}</option>
              <option value="Teamverantwortliche*r">{t(locale, 'registrationFunktionTR')}</option>
              <option value="Andere">{t(locale, 'registrationFunktionOther')}</option>
            </select>
          </div>

          <div class="form-group team-wrapper" id="vb-team-wrapper" style="display: none;">
            <label>{t(locale, 'registrationTeam')} *</label>
            <button type="button" class="form-select team-trigger" id="vb-team-trigger">
              <span id="vb-team-trigger-text">{t(locale, 'registrationTeamPlaceholder')}</span>
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 4 6 8 10 4"/></svg>
            </button>
            <div class="team-dropdown" id="vb-team-dropdown">
              <div class="team-options" id="vb-team"></div>
            </div>
          </div>

          <div class="form-group">
            <label for="vb-fee">{t(locale, 'registrationFeeCategory')} *</label>
            <select id="vb-fee" name="vb_fee" class="form-select" data-conditional-required>
              <option value="" disabled selected>{t(locale, 'registrationFeeCategoryPlaceholder')}</option>
              <option value="VB Turnier KWI">{t(locale, 'registrationVBFeeTournamentKWI')}</option>
              <option value="VB Lernende/Studi Meisterschaft">{t(locale, 'registrationVBFeeTournament')}</option>
              <option value="VB Schüler*in Meisterschaft">{t(locale, 'registrationVBFeeHighSchool')}</option>
              <option value="VB Student*in Meisterschaft">{t(locale, 'registrationVBFeeStudent')}</option>
              <option value="VB Erwerbstätige">{t(locale, 'registrationVBFeeWorking')}</option>
            </select>
          </div>

          <div class="form-group" id="vb-ahv-group">
            <label for="vb-ahv">{t(locale, 'registrationAHV')} <span id="vb-ahv-star">*</span></label>
            <input type="text" id="vb-ahv" name="vb_ahv" class="form-input">
            <small style="color: var(--text-secondary);">{t(locale, 'registrationAHVNote')}</small>
          </div>

          <div class="form-group">
            <label for="kantonsschule-vb">{t(locale, 'registrationKantonsschule')} *</label>
            <select id="kantonsschule-vb" name="kantonsschule_vb" class="form-select" data-conditional-required>
              <option value="" disabled selected>—</option>
              <option value="Nein">{t(locale, 'registrationKantonsschuleNo')}</option>
              <option value="KS Rämibühl">{t(locale, 'registrationKantonsschuleWiedikon')}</option>
              <option value="Andere Kantonsschule">{t(locale, 'registrationKantonsschuleOther')}</option>
            </select>
          </div>

          <div class="form-group">
            <label>{t(locale, 'registrationLicence')}</label>
            <div class="toggle-group">
              <label class="toggle-label">
                <span>{t(locale, 'registrationLicenceSchreiber')}</span>
                <span class="toggle-switch"><input type="checkbox" name="lizenz_vb" value="Schreiber"><span class="toggle-slider"></span></span>
              </label>
              <label class="toggle-label">
                <span>{t(locale, 'registrationLicenceSchiedsrichter')}</span>
                <span class="toggle-switch"><input type="checkbox" name="lizenz_vb" value="Schiedsrichter" id="vb-ref-check"><span class="toggle-slider"></span></span>
              </label>
            </div>
          </div>
          <div class="form-group" id="vb-ref-level-group" style="display: none;">
            <label for="vb-ref-level">{t(locale, 'registrationLicenceSchiedsrichter')} — Stufe</label>
            <select id="vb-ref-level" name="vb_ref_level" class="form-select">
              <option value="" disabled selected>{t(locale, 'registrationLicenceRefLevelPlaceholder')}</option>
              <option value="N4-3">N4-3</option>
              <option value="N4-2">N4-2</option>
              <option value="N4-1">N4-1</option>
              <option value="N3-3">N3-3</option>
              <option value="N3-2">N3-2</option>
              <option value="N3-1">N3-1</option>
              <option value="N2-2">N2-2</option>
              <option value="N2-1">N2-1</option>
              <option value="N1 (NL-Kader)">N1 (NL-Kader)</option>
            </select>
          </div>
        </div>

        <!-- ═══ BASKETBALL-ONLY FIELDS ═══ -->
        <div id="bb-fields" style="display: none;">
          <div class="form-group">
            <label for="funktion-bb">{t(locale, 'registrationFunktion')} *</label>
            <select id="funktion-bb" name="funktion_bb" class="form-select" data-conditional-required>
              <option value="" disabled selected>{t(locale, 'registrationFunktionPlaceholder')}</option>
              <option value="Spieler*in">{t(locale, 'registrationFunktionPlayer')}</option>
              <option value="Trainer*in">{t(locale, 'registrationFunktionCoach')}</option>
              <option value="Teamverantwortliche*r">{t(locale, 'registrationFunktionTR')}</option>
              <option value="Andere">{t(locale, 'registrationFunktionOther')}</option>
            </select>
          </div>

          <div class="form-group team-wrapper" id="bb-team-wrapper" style="display: none;">
            <label>{t(locale, 'registrationTeam')} *</label>
            <button type="button" class="form-select team-trigger" id="bb-team-trigger">
              <span id="bb-team-trigger-text">{t(locale, 'registrationTeamPlaceholder')}</span>
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 4 6 8 10 4"/></svg>
            </button>
            <div class="team-dropdown" id="bb-team-dropdown">
              <div class="team-options" id="bb-team"></div>
            </div>
          </div>

          <div class="form-group">
            <label for="bb-fee">{t(locale, 'registrationFeeCategory')} *</label>
            <select id="bb-fee" name="bb_fee" class="form-select" data-conditional-required>
              <option value="" disabled selected>{t(locale, 'registrationFeeCategoryPlaceholder')}</option>
              <option value="BB Aktiv Erwachsene">{t(locale, 'registrationBBFeeAdult')}</option>
              <option value="BB Aktiv Junioren U18">{t(locale, 'registrationBBFeeJunior')}</option>
              <option value="BB Passiv">{t(locale, 'registrationBBFeePassive')}</option>
              <option value="BB Familie">{t(locale, 'registrationBBFeeFamily')}</option>
            </select>
          </div>

          <div class="form-group" id="bb-ahv-group">
            <label for="bb-ahv">{t(locale, 'registrationAHV')} <span id="bb-ahv-star">*</span></label>
            <input type="text" id="bb-ahv" name="bb_ahv" class="form-input">
            <small style="color: var(--text-secondary);">{t(locale, 'registrationAHVNote')}</small>
          </div>

          <div class="form-group">
            <label for="kantonsschule-bb">{t(locale, 'registrationKantonsschule')} *</label>
            <select id="kantonsschule-bb" name="kantonsschule_bb" class="form-select" data-conditional-required>
              <option value="" disabled selected>—</option>
              <option value="Nein">{t(locale, 'registrationKantonsschuleNo')}</option>
              <option value="KS Rämibühl">{t(locale, 'registrationKantonsschuleWiedikon')}</option>
              <option value="Andere Kantonsschule">{t(locale, 'registrationKantonsschuleOther')}</option>
            </select>
          </div>

          <div class="form-group">
            <label>{t(locale, 'registrationLicenceBBScorer')}</label>
            <div style="display: flex; gap: var(--space-lg); flex-wrap: wrap; margin-top: var(--space-xs);">
              <label class="radio-card">
                <input type="radio" name="bb_scorer_licence" value="">
                <span>{t(locale, 'registrationLicenceNone')}</span>
              </label>
              <label class="radio-card">
                <input type="radio" name="bb_scorer_licence" value="OTR 1">
                <span>{t(locale, 'registrationLicenceOTR1')}</span>
              </label>
              <label class="radio-card">
                <input type="radio" name="bb_scorer_licence" value="OTR 2">
                <span>{t(locale, 'registrationLicenceOTR2')}</span>
              </label>
              <label class="radio-card">
                <input type="radio" name="bb_scorer_licence" value="OTN">
                <span>{t(locale, 'registrationLicenceOTN')}</span>
              </label>
            </div>
          </div>

          <div class="form-group">
            <label>{t(locale, 'registrationLicenceBBReferee')}</label>
            <div class="toggle-group">
              <label class="toggle-label">
                <span>{t(locale, 'registrationLicenceSchiedsrichter')}</span>
                <span class="toggle-switch"><input type="checkbox" name="bb_referee" value="Schiedsrichter" id="bb-ref-check"><span class="toggle-slider"></span></span>
              </label>
            </div>
          </div>

          <div class="form-group">
            <label>{t(locale, 'registrationIDUpload')} *</label>
            <small style="color: var(--text-secondary); display: block; margin-bottom: var(--space-sm);">{t(locale, 'registrationIDUploadNote')}</small>
            <div style="display: flex; gap: var(--space-md); flex-wrap: wrap;">
              <div>
                <label for="id-front" style="font-size: var(--text-sm); font-weight: 600; display: block; margin-bottom: var(--space-xs);">{t(locale, 'registrationIDFront')} *</label>
                <input type="file" id="id-front" name="id_front" accept="image/*,.pdf" data-conditional-required>
              </div>
              <div>
                <label for="id-back" style="font-size: var(--text-sm); font-weight: 600; display: block; margin-bottom: var(--space-xs);">{t(locale, 'registrationIDBack')}</label>
                <input type="file" id="id-back" name="id_back" accept="image/*,.pdf">
              </div>
            </div>
          </div>

          <div class="form-group" id="bb-docs-group">
            <label>{t(locale, 'registrationBBDocs')}</label>
            <small style="color: var(--text-secondary); display: block; margin-bottom: var(--space-sm);">{t(locale, 'registrationBBDocsHint')}</small>
            <div class="bb-docs-list">
              <div class="bb-doc-item">
                <span>{t(locale, 'registrationBBDocsLizenz')}</span>
                <a href="/docs/lizenzantrag-swiss-basketball.pdf" target="_blank" class="bb-doc-download" id="bb-doc-lizenz">{t(locale, 'registrationBBDocsLizenzDownload')}</a>
              </div>
              <div class="bb-doc-item bb-doc-foreign" style="display: none;">
                <span>{t(locale, 'registrationBBDocsSelfDecl')}</span>
                <a href="/docs/player-self-declaration-fiba.pdf" target="_blank" class="bb-doc-download" id="bb-doc-selfdecl">{t(locale, 'registrationBBDocsSelfDeclDownload')}</a>
              </div>
              <div class="bb-doc-item bb-doc-foreign" style="display: none;">
                <span>{t(locale, 'registrationBBDocsNatDecl')}</span>
                <a href="/docs/national-team-declaration-fiba.pdf" target="_blank" class="bb-doc-download" id="bb-doc-natdecl">{t(locale, 'registrationBBDocsNatDeclDownload')}</a>
              </div>
            </div>
          </div>

          <div class="form-group" id="bb-docs-upload-group">
            <label>{t(locale, 'registrationBBDocsUpload')}</label>
            <small style="color: var(--text-secondary); display: block; margin-bottom: var(--space-sm);">{t(locale, 'registrationBBDocsUploadNote')}</small>
            <div style="display: flex; flex-direction: column; gap: var(--space-md);">
              <div>
                <label for="bb-doc-lizenz-upload" style="font-size: var(--text-sm); font-weight: 600; display: block; margin-bottom: var(--space-xs);">{t(locale, 'registrationBBDocsUploadLizenz')} *</label>
                <input type="file" id="bb-doc-lizenz-upload" name="bb_doc_lizenz" accept=".pdf" data-conditional-required>
              </div>
              <div class="bb-doc-foreign" style="display: none;">
                <label for="bb-doc-selfdecl-upload" style="font-size: var(--text-sm); font-weight: 600; display: block; margin-bottom: var(--space-xs);">{t(locale, 'registrationBBDocsUploadSelfDecl')}</label>
                <input type="file" id="bb-doc-selfdecl-upload" name="bb_doc_selfdecl" accept=".pdf">
              </div>
              <div class="bb-doc-foreign" style="display: none;">
                <label for="bb-doc-natdecl-upload" style="font-size: var(--text-sm); font-weight: 600; display: block; margin-bottom: var(--space-xs);">{t(locale, 'registrationBBDocsUploadNatDecl')}</label>
                <input type="file" id="bb-doc-natdecl-upload" name="bb_doc_natdecl" accept=".pdf">
              </div>
            </div>
          </div>
        </div>

        <!-- ═══ PASSIVE-ONLY FIELDS ═══ -->
        <div id="passive-fields" style="display: none;">
          <div class="form-group">
            <label>{t(locale, 'registrationPassiveLicenceVB')}</label>
            <div class="toggle-group">
              <label class="toggle-label">
                <span>{t(locale, 'registrationLicenceSchreiber')}</span>
                <span class="toggle-switch"><input type="checkbox" name="lizenz_passive" value="VB Schreiber"><span class="toggle-slider"></span></span>
              </label>
              <label class="toggle-label">
                <span>{t(locale, 'registrationLicenceSchiedsrichter')}</span>
                <span class="toggle-switch"><input type="checkbox" name="lizenz_passive" value="VB Schiedsrichter" id="passive-vb-ref-check"><span class="toggle-slider"></span></span>
              </label>
            </div>
          </div>
          <div class="form-group" id="passive-vb-ref-level-group" style="display: none;">
            <label for="passive-vb-ref-level">{t(locale, 'registrationLicenceSchiedsrichter')} — Stufe</label>
            <select id="passive-vb-ref-level" name="passive_vb_ref_level" class="form-select">
              <option value="" disabled selected>{t(locale, 'registrationLicenceRefLevelPlaceholder')}</option>
              <option value="N4-3">N4-3</option>
              <option value="N4-2">N4-2</option>
              <option value="N4-1">N4-1</option>
              <option value="N3-3">N3-3</option>
              <option value="N3-2">N3-2</option>
              <option value="N3-1">N3-1</option>
              <option value="N2-2">N2-2</option>
              <option value="N2-1">N2-1</option>
              <option value="N1 (NL-Kader)">N1 (NL-Kader)</option>
            </select>
          </div>

          <div class="form-group">
            <label>{t(locale, 'registrationPassiveLicenceBB')}</label>
            <div style="display: flex; gap: var(--space-md); flex-wrap: wrap; margin-top: var(--space-xs);">
              <label class="radio-card">
                <input type="radio" name="passive_bb_scorer" value="">
                <span>{t(locale, 'registrationLicenceNone')}</span>
              </label>
              <label class="radio-card">
                <input type="radio" name="passive_bb_scorer" value="BB OTR 1">
                <span>{t(locale, 'registrationLicenceOTR1')}</span>
              </label>
              <label class="radio-card">
                <input type="radio" name="passive_bb_scorer" value="BB OTR 2">
                <span>{t(locale, 'registrationLicenceOTR2')}</span>
              </label>
              <label class="radio-card">
                <input type="radio" name="passive_bb_scorer" value="BB OTN">
                <span>{t(locale, 'registrationLicenceOTN')}</span>
              </label>
            </div>
            <div class="toggle-group" style="margin-top: var(--space-sm);">
              <label class="toggle-label">
                <span>{t(locale, 'registrationLicenceSchiedsrichter')}</span>
                <span class="toggle-switch"><input type="checkbox" name="lizenz_passive" value="BB Schiedsrichter"><span class="toggle-slider"></span></span>
              </label>
            </div>
          </div>
        </div>

        <!-- Bemerkungen (all types) -->
        <div class="form-group">
          <label for="bemerkungen">{t(locale, 'registrationComments')}</label>
          <textarea id="bemerkungen" name="bemerkungen" class="form-textarea" placeholder={t(locale, 'registrationCommentsPlaceholder')}></textarea>
        </div>

        <!-- Privacy Notice (collapsible) -->
        <details style="margin-bottom: var(--space-lg);">
          <summary style="cursor: pointer; font-weight: 600; color: var(--kscw-blue);">{t(locale, 'registrationPrivacyTitle')}</summary>
          <p style="margin-top: var(--space-sm); color: var(--text-secondary); font-size: var(--text-sm); line-height: 1.7; text-align: justify;">{t(locale, 'registrationPrivacyText')}</p>
        </details>

        <!-- Consent Checkbox -->
        <div class="form-group">
          <label style="display: flex; align-items: flex-start; gap: var(--space-sm); cursor: pointer; font-weight: normal;">
            <input type="checkbox" id="consent" name="consent" required style="margin-top: 4px; flex-shrink: 0;">
            <span style="font-size: var(--text-sm);">{t(locale, 'registrationConsent')}</span>
          </label>
        </div>

        <!-- Turnstile -->
        <div id="turnstile-container" class="form-group"></div>

        <!-- Submit -->
        <button type="submit" class="form-submit" style="width: 100%; font-size: 1rem; padding: var(--space-md) var(--space-xl); justify-content: center;">
          {t(locale, 'registrationSubmit')}
        </button>
      </form>

      <div id="form-feedback" style="display: none;"></div>
    </div>
  </section>

  <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  <script is:inline src="/js/i18n.js"></script>
  <script is:inline>i18n.init();</script>
  <script is:inline src="/js/registration-form.js"></script>
  <script src="../../../islands/scroll-animations.ts"></script>
</PageLayout>

<style>
  .form-group {
    margin-bottom: var(--space-md);
  }
  .form-group label {
    display: block;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-xs);
  }
  .form-input,
  .form-select,
  .form-textarea {
    width: 100%;
    padding: 0.625rem 0.875rem;
    font-size: var(--text-sm);
    font-family: 'Inter', sans-serif;
    border: 1px solid var(--border);
    border-radius: var(--radius-md, 8px);
    background: var(--bg-white);
    color: var(--text-primary);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    box-sizing: border-box;
  }
  .form-input:focus,
  .form-select:focus,
  .form-textarea:focus {
    outline: none;
