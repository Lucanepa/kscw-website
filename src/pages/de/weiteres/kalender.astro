---
import PageLayout from '../../../layouts/PageLayout.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import { t } from '../../../lib/i18n';

const locale = 'de';
---
<PageLayout
  title="Kalender — KSC Wiedikon"
  description="Kalender des KSC Wiedikon — Alle Spiele, Trainings und Events auf einen Blick."
  locale={locale}
  pageTitle={t(locale, 'calendarTitle')}
  pageSubtitle={t(locale, 'calendarSubtitle')}
>
  <!-- Kalender Info -->
  <section class="section">
    <div class="container">
      <SectionHeader title={t(locale, 'calendarHeading')} />
      <div style="max-width: 720px;">
        <p style="font-size: 1.125rem; line-height: 1.8; color: var(--text-secondary); margin-bottom: var(--space-md);">
          {t(locale, 'calendarDescription')}
        </p>
        <div style="background: var(--surface-alt); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: var(--space-lg); margin-bottom: var(--space-lg);">
          <p style="margin-bottom: var(--space-md); color: var(--text-secondary);">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 6px;"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
            <span>{t(locale, 'calendarPlatformInfo')}</span>
          </p>
          <a href="https://kscw.lucanepa.com/calendar" class="btn btn-gold" target="_blank" rel="noopener noreferrer">
            <span>{t(locale, 'calendarPlatformLink')} &rarr;</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- iCal Subscriptions -->
  <section class="section-alt">
    <div class="container">
      <SectionHeader title={t(locale, 'calendarSubscribe')} />
      <p style="color: var(--text-secondary); margin-bottom: var(--space-lg); max-width: 640px;">
        {t(locale, 'calendarSubscribeDescription')}
      </p>
      <div class="grid grid-2" style="max-width: 720px;">
        <div class="card">
          <div class="card-body" style="text-align: center;">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--kscw-blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: var(--space-md);"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/><path d="m9 16 2 2 4-4"/></svg>
            <h3 style="margin-bottom: var(--space-sm);">{t(locale, 'calendarVolleyball')}</h3>
            <p style="color: var(--text-secondary); margin-bottom: var(--space-md);">{t(locale, 'calendarVolleyballDescription')}</p>
            <a href="https://kscw.lucanepa.com/api/ical/volleyball" class="btn btn-outline" target="_blank" rel="noopener noreferrer">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 4px;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
              <span>{t(locale, 'calendarICalSubscribe')}</span>
            </a>
          </div>
        </div>
        <div class="card">
          <div class="card-body" style="text-align: center;">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--kscw-gold)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: var(--space-md);"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/><path d="m9 16 2 2 4-4"/></svg>
            <h3 style="margin-bottom: var(--space-sm);">{t(locale, 'calendarBasketball')}</h3>
            <p style="color: var(--text-secondary); margin-bottom: var(--space-md);">{t(locale, 'calendarBasketballDescription')}</p>
            <a href="https://kscw.lucanepa.com/api/ical/basketball" class="btn btn-outline" target="_blank" rel="noopener noreferrer">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 4px;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
              <span>{t(locale, 'calendarICalSubscribe')}</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Upcoming Events -->
  <section class="section">
    <div class="container">
      <SectionHeader title={t(locale, 'calendarUpcoming')} />

      <div style="display: flex; flex-direction: column; gap: var(--space-sm);">

        <!-- Termin 1 -->
        <div class="card" style="border-left: 4px solid var(--kscw-blue);">
          <div class="card-body" style="display: flex; align-items: center; gap: var(--space-md); flex-wrap: wrap;">
            <div style="min-width: 100px;">
              <span style="font-weight: 700; color: var(--kscw-blue);">Sa, 22. März</span><br>
              <span style="color: var(--text-secondary); font-size: 0.875rem;">14:00 Uhr</span>
            </div>
            <span class="chip" style="background: #1e40af; color: #fff;">H1</span>
            <div>
              <strong>KSCW Herren 1 vs. VBC Züri Unterland</strong><br>
              <span style="color: var(--text-secondary); font-size: 0.875rem;">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle;"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                Turnhalle Utogrund, Zürich
              </span>
            </div>
            <span class="badge badge-blue" style="margin-left: auto;">{t(locale, 'calendarHomeGame')}</span>
          </div>
        </div>

        <!-- Termin 2 -->
        <div class="card" style="border-left: 4px solid var(--kscw-gold);">
          <div class="card-body" style="display: flex; align-items: center; gap: var(--space-md); flex-wrap: wrap;">
            <div style="min-width: 100px;">
              <span style="font-weight: 700; color: var(--kscw-gold);">Sa, 22. März</span><br>
              <span style="color: var(--text-secondary); font-size: 0.875rem;">16:00 Uhr</span>
            </div>
            <span class="chip" style="background: #f59e0b; color: #78350f;">Lions</span>
            <div>
              <strong>KSCW Lions vs. BC Winterthur</strong><br>
              <span style="color: var(--text-secondary); font-size: 0.875rem;">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle;"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                Turnhalle Lavater, Zürich
              </span>
            </div>
            <span class="badge badge-gold" style="margin-left: auto;">{t(locale, 'calendarHomeGame')}</span>
          </div>
        </div>

        <!-- Termin 3 -->
        <div class="card" style="border-left: 4px solid var(--kscw-blue);">
          <div class="card-body" style="display: flex; align-items: center; gap: var(--space-md); flex-wrap: wrap;">
            <div style="min-width: 100px;">
              <span style="font-weight: 700; color: var(--kscw-blue);">Di, 25. März</span><br>
              <span style="color: var(--text-secondary); font-size: 0.875rem;">20:00 Uhr</span>
            </div>
            <span class="chip" style="background: #2563eb; color: #fff;">H2</span>
            <div>
              <strong>Training Herren 2</strong><br>
              <span style="color: var(--text-secondary); font-size: 0.875rem;">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle;"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                Turnhalle Sihlfeld, Zürich
              </span>
            </div>
            <span class="badge" style="margin-left: auto;">{t(locale, 'calendarTraining')}</span>
          </div>
        </div>

        <!-- Termin 4 -->
        <div class="card" style="border-left: 4px solid var(--kscw-blue);">
          <div class="card-body" style="display: flex; align-items: center; gap: var(--space-md); flex-wrap: wrap;">
            <div style="min-width: 100px;">
              <span style="font-weight: 700; color: var(--kscw-blue);">Mi, 26. März</span><br>
              <span style="color: var(--text-secondary); font-size: 0.875rem;">20:00 Uhr</span>
            </div>
            <span class="chip" style="background: #be123c; color: #fff;">D1</span>
            <div>
              <strong>Training Damen 1</strong><br>
              <span style="color: var(--text-secondary); font-size: 0.875rem;">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle;"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                Turnhalle Utogrund, Zürich
              </span>
            </div>
            <span class="badge" style="margin-left: auto;">{t(locale, 'calendarTraining')}</span>
          </div>
        </div>

        <!-- Termin 5 -->
        <div class="card" style="border-left: 4px solid var(--kscw-gold);">
          <div class="card-body" style="display: flex; align-items: center; gap: var(--space-md); flex-wrap: wrap;">
            <div style="min-width: 100px;">
              <span style="font-weight: 700; color: var(--kscw-gold);">Sa, 29. März</span><br>
              <span style="color: var(--text-secondary); font-size: 0.875rem;">11:00 Uhr</span>
            </div>
            <span class="chip" style="background: #ea580c; color: #fff;">BB H1</span>
            <div>
              <strong>KSCW Herren 1 vs. Puma Basket Zürich</strong><br>
              <span style="color: var(--text-secondary); font-size: 0.875rem;">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle;"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                Turnhalle Utogrund, Zürich
              </span>
            </div>
            <span class="badge badge-gold" style="margin-left: auto;">{t(locale, 'calendarHomeGame')}</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <script src="../../../islands/scroll-animations.ts"></script>
</PageLayout>
