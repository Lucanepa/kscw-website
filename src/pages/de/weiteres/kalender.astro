---
import PageLayout from '../../../layouts/PageLayout.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import { t } from '../../../lib/i18n';

const locale = 'de';
---
<PageLayout
  title="Kalender — KSC Wiedikon"
  description="Kalender des KSC Wiedikon — Alle Spiele, Trainings und Events auf einen Blick."
  locale={locale}
  pageTitle={t(locale, 'calendarTitle')}
  pageSubtitle={t(locale, 'calendarSubtitle')}
>
  <!-- Live Calendar Grid -->
  <section class="section">
    <div class="container">
      <div id="calendar-grid" data-lang="de">
        <div class="cal-loading">Spiele werden geladen...</div>
      </div>
    </div>
  </section>

  <!-- iCal Subscriptions -->
  <section class="section-alt">
    <div class="container">
      <SectionHeader title={t(locale, 'calendarSubscribe')} />
      <p style="color: var(--text-secondary); margin-bottom: var(--space-lg); max-width: 640px;">
        {t(locale, 'calendarSubscribeDescription')}
      </p>
      <div class="grid grid-2" style="max-width: 720px;">
        <div class="card">
          <div class="card-body" style="text-align: center;">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--kscw-blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: var(--space-md);"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/><path d="m9 16 2 2 4-4"/></svg>
            <h3 style="margin-bottom: var(--space-sm);">{t(locale, 'calendarVolleyball')}</h3>
            <p style="color: var(--text-secondary); margin-bottom: var(--space-md);">{t(locale, 'calendarVolleyballDescription')}</p>
            <a href="https://kscw.lucanepa.com/api/ical/volleyball" class="btn btn-outline" target="_blank" rel="noopener noreferrer">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 4px;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
              <span>{t(locale, 'calendarICalSubscribe')}</span>
            </a>
          </div>
        </div>
        <div class="card">
          <div class="card-body" style="text-align: center;">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--kscw-gold)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: var(--space-md);"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/><path d="m9 16 2 2 4-4"/></svg>
            <h3 style="margin-bottom: var(--space-sm);">{t(locale, 'calendarBasketball')}</h3>
            <p style="color: var(--text-secondary); margin-bottom: var(--space-md);">{t(locale, 'calendarBasketballDescription')}</p>
            <a href="https://kscw.lucanepa.com/api/ical/basketball" class="btn btn-outline" target="_blank" rel="noopener noreferrer">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 4px;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
              <span>{t(locale, 'calendarICalSubscribe')}</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script src="../../../islands/calendar-grid.ts"></script>
  <script src="../../../islands/scroll-animations.ts"></script>
</PageLayout>
