---
import PageLayout from '../../../layouts/PageLayout.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import { t } from '../../../lib/i18n';

const locale = 'de';
---
<PageLayout
  title="Mitgliedschaft — KSC Wiedikon"
  description="Mitglied werden beim KSC Wiedikon — Beiträge, Anmeldung und Vorteile."
  locale={locale}
  pageTitle={t(locale, 'membershipTitle')}
  pageSubtitle={t(locale, 'membershipSubtitle')}
>
  <!-- Warum KSCW? -->
  <section class="section">
    <div class="container">
      <SectionHeader title={t(locale, 'membershipWhy')} />
      <div class="grid grid-3">

        <div class="card">
          <div class="card-body" style="text-align: center;">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--kscw-blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: var(--space-md);"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            <h3 style="margin-bottom: var(--space-sm);">{t(locale, 'membershipTeamSpirit')}</h3>
            <p style="color: var(--text-secondary);">{t(locale, 'membershipTeamSpiritText')}</p>
          </div>
        </div>

        <div class="card">
          <div class="card-body" style="text-align: center;">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--kscw-gold)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: var(--space-md);"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5C7 4 9 7 12 7s5-3 7.5-3a2.5 2.5 0 0 1 0 5H18"/><path d="M18 15h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M6 15H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="m2 21 8-8"/><path d="m14 21 8-8"/><path d="m8 21 4-4 4 4"/><path d="M12 3v4"/></svg>
            <h3 style="margin-bottom: var(--space-sm);">{t(locale, 'membershipTraining')}</h3>
            <p style="color: var(--text-secondary);">{t(locale, 'membershipTrainingText')}</p>
          </div>
        </div>

        <div class="card">
          <div class="card-body" style="text-align: center;">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--kscw-blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: var(--space-md);"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
            <h3 style="margin-bottom: var(--space-sm);">{t(locale, 'membershipCommunity')}</h3>
            <p style="color: var(--text-secondary);">{t(locale, 'membershipCommunityText')}</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Mitgliederbeiträge -->
  <section class="section-alt">
    <div class="container">
      <SectionHeader title={t(locale, 'membershipFees')} />
      <div style="max-width: 640px;">
        <table style="width: 100%; border-collapse: collapse; background: var(--surface); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-sm);">
          <thead>
            <tr style="background: var(--kscw-blue); color: white;">
              <th style="padding: var(--space-md) var(--space-lg); text-align: left; font-weight: 600;">{t(locale, 'membershipCategory')}</th>
              <th style="padding: var(--space-md) var(--space-lg); text-align: right; font-weight: 600;">{t(locale, 'membershipFee')}</th>
            </tr>
          </thead>
          <tbody>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: var(--space-md) var(--space-lg);">
                <strong>{t(locale, 'membershipCategoryActive')}</strong><br>
                <span style="font-size: 0.875rem; color: var(--text-secondary);">{t(locale, 'membershipCategoryActiveDesc')}</span>
              </td>
              <td style="padding: var(--space-md) var(--space-lg); text-align: right; font-weight: 700; font-size: 1.125rem; color: var(--kscw-blue);">
                CHF 350/Jahr
              </td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: var(--space-md) var(--space-lg);">
                <strong>{t(locale, 'membershipCategoryYouth')}</strong><br>
                <span style="font-size: 0.875rem; color: var(--text-secondary);">{t(locale, 'membershipCategoryYouthDesc')}</span>
              </td>
              <td style="padding: var(--space-md) var(--space-lg); text-align: right; font-weight: 700; font-size: 1.125rem; color: var(--kscw-blue);">
                CHF 200/Jahr
              </td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: var(--space-md) var(--space-lg);">
                <strong>{t(locale, 'membershipCategoryPassive')}</strong><br>
                <span style="font-size: 0.875rem; color: var(--text-secondary);">{t(locale, 'membershipCategoryPassiveDesc')}</span>
              </td>
              <td style="padding: var(--space-md) var(--space-lg); text-align: right; font-weight: 700; font-size: 1.125rem; color: var(--kscw-blue);">
                CHF 50/Jahr
              </td>
            </tr>
            <tr>
              <td style="padding: var(--space-md) var(--space-lg);">
                <strong>{t(locale, 'membershipCategoryFamily')}</strong><br>
                <span style="font-size: 0.875rem; color: var(--text-secondary);">{t(locale, 'membershipCategoryFamilyDesc')}</span>
              </td>
              <td style="padding: var(--space-md) var(--space-lg); text-align: right; font-weight: 700; font-size: 1.125rem; color: var(--kscw-blue);">
                CHF 600/Jahr
              </td>
            </tr>
          </tbody>
        </table>
        <p style="margin-top: var(--space-md); font-size: 0.875rem; color: var(--text-secondary);">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 4px;"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
          <span>{t(locale, 'membershipFeesNote')}</span>
        </p>
      </div>
    </div>
  </section>

  <!-- Anmeldung -->
  <section class="section">
    <div class="container">
      <SectionHeader title={t(locale, 'membershipRegistration')} />
      <div style="max-width: 720px;">
        <p style="font-size: 1.125rem; line-height: 1.8; color: var(--text-secondary); margin-bottom: var(--space-lg);">
          <span>{t(locale, 'membershipRegistrationText')}</span>
        </p>

        <div style="display: flex; flex-direction: column; gap: var(--space-md); margin-bottom: var(--space-xl);">

          <div class="card" style="border-left: 4px solid var(--kscw-gold);">
            <div class="card-body" style="display: flex; align-items: flex-start; gap: var(--space-md);">
              <div style="min-width: 48px; height: 48px; background: var(--kscw-gold); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 1.25rem;">1</div>
              <div>
                <h3 style="margin-bottom: var(--space-xs);">{t(locale, 'membershipStep1')}</h3>
                <p style="color: var(--text-secondary);">{t(locale, 'membershipStep1Text')}</p>
              </div>
            </div>
          </div>

          <div class="card" style="border-left: 4px solid var(--kscw-blue);">
            <div class="card-body" style="display: flex; align-items: flex-start; gap: var(--space-md);">
              <div style="min-width: 48px; height: 48px; background: var(--kscw-blue); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 1.25rem;">2</div>
              <div>
                <h3 style="margin-bottom: var(--space-xs);">{t(locale, 'membershipStep2')}</h3>
                <p style="color: var(--text-secondary);">{t(locale, 'membershipStep2Text')}</p>
              </div>
            </div>
          </div>

          <div class="card" style="border-left: 4px solid var(--kscw-gold);">
            <div class="card-body" style="display: flex; align-items: flex-start; gap: var(--space-md);">
              <div style="min-width: 48px; height: 48px; background: var(--kscw-gold); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 1.25rem;">3</div>
              <div>
                <h3 style="margin-bottom: var(--space-xs);">{t(locale, 'membershipStep3')}</h3>
                <p style="color: var(--text-secondary);">{t(locale, 'membershipStep3Text')}</p>
              </div>
            </div>
          </div>

        </div>

        <div style="margin-bottom: var(--space-lg);">
          <p style="text-align: center; color: var(--text-secondary); margin-bottom: var(--space-lg);">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 4px;"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
            <span>{t(locale, 'membershipCoachNote')}</span>
          </p>
          <div style="display: flex; flex-wrap: wrap; gap: var(--space-md); justify-content: center;">
            <a href="https://www.kscw.ch/weiteres/mitglied_werden/volleyball" target="_blank" rel="noopener noreferrer" class="btn btn-gold" style="font-size: 1rem; padding: var(--space-md) var(--space-xl);">
              <span>{t(locale, 'membershipRegisterVB')}</span>
            </a>
            <a href="https://forms.gle/v4qNHrQybzpFuXgW9" target="_blank" rel="noopener noreferrer" class="btn" style="font-size: 1rem; padding: var(--space-md) var(--space-xl); background: var(--kscw-blue); color: white;">
              <span>{t(locale, 'membershipRegisterBB')}</span>
            </a>
            <a href="https://www.kscw.ch/weiteres/mitglied_werden" target="_blank" rel="noopener noreferrer" class="btn btn-outline" style="font-size: 1rem; padding: var(--space-md) var(--space-xl);">
              <span>{t(locale, 'membershipRegisterPassive')}</span>
            </a>
          </div>
        </div>
        <div style="text-align: center;">
          <a href={`/${locale}/club/kontakt`} class="btn btn-outline btn-sm">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 6px;"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            <span>{t(locale, 'membershipCTAButton')}</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <script src="../../../islands/scroll-animations.ts"></script>
</PageLayout>
