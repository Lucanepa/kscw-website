---
import PageLayout from '../../../layouts/PageLayout.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import { t } from '../../../lib/i18n';

const locale = 'de';
---
<PageLayout
  title="Partner — KSC Wiedikon"
  description="Partner des KSC Wiedikon — functiomed für Prävention und medizinische Betreuung."
  locale={locale}
  pageTitle={t(locale, 'partnerTitle')}
  pageSubtitle={t(locale, 'partnerSubtitle')}
>
  <!-- functiomed -->
  <section class="section">
    <div class="container">
      <SectionHeader title={t(locale, 'partnerFunctiomed')} />
      <div style="max-width: 720px;">

        <div style="display: flex; flex-direction: column; gap: var(--space-md); margin-bottom: var(--space-xl);">

          <div class="card" style="border-left: 4px solid var(--kscw-gold);">
            <div class="card-body" style="display: flex; align-items: flex-start; gap: var(--space-md);">
              <div style="min-width: 48px; height: 48px; background: var(--kscw-gold); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>
              </div>
              <div>
                <h3 style="margin-bottom: var(--space-xs);">{t(locale, 'partnerPrevention')}</h3>
                <p style="color: var(--text-secondary);">{t(locale, 'partnerPreventionText')}</p>
              </div>
            </div>
          </div>

          <div class="card" style="border-left: 4px solid var(--kscw-blue);">
            <div class="card-body" style="display: flex; align-items: flex-start; gap: var(--space-md);">
              <div style="min-width: 48px; height: 48px; background: var(--kscw-blue); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/><path d="M3.22 12H9.5l.5-1 2 4.5 2-7 1.5 3.5h5.27"/></svg>
              </div>
              <div>
                <h3 style="margin-bottom: var(--space-xs);">{t(locale, 'partnerMedical')}</h3>
                <p style="color: var(--text-secondary);">{t(locale, 'partnerMedicalText')}</p>
              </div>
            </div>
          </div>

        </div>

        <div style="text-align: center; margin-bottom: var(--space-lg);">
          <a href="https://functiomed.ch" target="_blank" rel="noopener noreferrer" class="btn btn-gold" style="font-size: 1.125rem; padding: var(--space-md) var(--space-xl);">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 8px;"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
            <span>{t(locale, 'partnerVisitWebsite')}</span>
          </a>
        </div>

        <p style="font-size: 0.875rem; color: var(--text-secondary); text-align: center;">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 4px;"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
          <span>{t(locale, 'partnerContactNote')}</span>
        </p>
      </div>
    </div>
  </section>

  <script src="../../../islands/scroll-animations.ts"></script>
</PageLayout>
