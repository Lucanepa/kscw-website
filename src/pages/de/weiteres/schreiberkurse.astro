---
import PageLayout from '../../../layouts/PageLayout.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import { t } from '../../../lib/i18n';

const locale = 'de';
---
<PageLayout
  title="Schreiberkurse — KSC Wiedikon"
  description="Ausbildungsmaterial und Kursunterlagen für Volleyball-Schreiber*innen beim KSC Wiedikon."
  locale={locale}
  pageTitle={t(locale, 'scorerCoursesTitle')}
  pageSubtitle={t(locale, 'scorerCoursesSubtitle')}
>
  <!-- Intro -->
  <section class="section">
    <div class="container">
      <div style="max-width: 800px;">
        <p style="font-size: 1.125rem; line-height: 1.8; color: var(--text-secondary);">
          {t(locale, 'scorerCoursesIntro')}
        </p>
      </div>
    </div>
  </section>

  <!-- Resources Grid -->
  <section class="section-alt">
    <div class="container">
      <SectionHeader title={t(locale, 'scorerCoursesResourcesTitle')} />
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: var(--space-lg); max-width: 900px;">

        <!-- Offizielles Matchblatt -->
        <div class="card">
          <div class="card-body" style="display: flex; flex-direction: column; gap: var(--space-md);">
            <div style="display: flex; align-items: center; gap: var(--space-sm);">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--kscw-blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
              <h3 style="margin: 0;">{t(locale, 'scorerCoursesMatchblatt')}</h3>
            </div>
            <p style="color: var(--text-secondary); flex: 1;">{t(locale, 'scorerCoursesMatchblattDesc')}</p>
            <a href="https://drive.google.com/file/d/18OH8RnmQCJsvF5Haa7FciNQBuk83B6C1/view" target="_blank" rel="noopener noreferrer" class="btn btn-blue" style="align-self: flex-start;">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 6px;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
              <span>{t(locale, 'scorerCoursesDownload')}</span>
            </a>
          </div>
        </div>

        <!-- E-Learning -->
        <div class="card">
          <div class="card-body" style="display: flex; flex-direction: column; gap: var(--space-md);">
            <div style="display: flex; align-items: center; gap: var(--space-sm);">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--kscw-gold)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/><polygon points="10 8 16 11 10 14 10 8"/></svg>
              <h3 style="margin: 0;">{t(locale, 'scorerCoursesElearning')}</h3>
            </div>
            <p style="color: var(--text-secondary); flex: 1;">{t(locale, 'scorerCoursesElearningDesc')}</p>
            <a href="https://swissvolley.triagonal.net/online/login/index.php" target="_blank" rel="noopener noreferrer" class="btn btn-gold" style="align-self: flex-start;">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 6px;"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
              <span>{t(locale, 'scorerCoursesOpen')}</span>
            </a>
          </div>
        </div>

        <!-- PDF DE -->
        <div class="card">
          <div class="card-body" style="display: flex; flex-direction: column; gap: var(--space-md);">
            <div style="display: flex; align-items: center; gap: var(--space-sm);">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--kscw-blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M12 18v-6"/><path d="m9 15 3 3 3-3"/></svg>
              <h3 style="margin: 0;">{t(locale, 'scorerCoursesPdfDe')}</h3>
            </div>
            <p style="color: var(--text-secondary); flex: 1;">{t(locale, 'scorerCoursesPdfDeDesc')}</p>
            <a href="https://drive.google.com/file/d/12zgdNh41Yk-OH6pHp9_Y0cDme00SG5L2/view" target="_blank" rel="noopener noreferrer" class="btn btn-blue" style="align-self: flex-start;">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 6px;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
              <span>{t(locale, 'scorerCoursesDownload')}</span>
            </a>
          </div>
        </div>

        <!-- PDF EN -->
        <div class="card">
          <div class="card-body" style="display: flex; flex-direction: column; gap: var(--space-md);">
            <div style="display: flex; align-items: center; gap: var(--space-sm);">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--kscw-gold)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M12 18v-6"/><path d="m9 15 3 3 3-3"/></svg>
              <h3 style="margin: 0;">{t(locale, 'scorerCoursesPdfEn')}</h3>
            </div>
            <p style="color: var(--text-secondary); flex: 1;">{t(locale, 'scorerCoursesPdfEnDesc')}</p>
            <a href="https://drive.google.com/file/d/1vhJRAaqi1lZ8LCk32vc7j6xOPoPj_Ak_/view" target="_blank" rel="noopener noreferrer" class="btn btn-blue" style="align-self: flex-start;">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 6px;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
              <span>{t(locale, 'scorerCoursesDownload')}</span>
            </a>
          </div>
        </div>

        <!-- PPT DE -->
        <div class="card">
          <div class="card-body" style="display: flex; flex-direction: column; gap: var(--space-md);">
            <div style="display: flex; align-items: center; gap: var(--space-sm);">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--kscw-blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;"><path d="M2 3h20"/><path d="M21 3v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V3"/><path d="m7 21 5-5 5 5"/></svg>
              <h3 style="margin: 0;">{t(locale, 'scorerCoursesPptDe')}</h3>
            </div>
            <p style="color: var(--text-secondary); flex: 1;">{t(locale, 'scorerCoursesPptDeDesc')}</p>
            <a href="https://drive.google.com/file/d/1PZp872ULqE6eQAQCqirDhpqGSzJ_PRSL/view" target="_blank" rel="noopener noreferrer" class="btn btn-blue" style="align-self: flex-start;">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 6px;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
              <span>{t(locale, 'scorerCoursesDownload')}</span>
            </a>
          </div>
        </div>

        <!-- PPT EN -->
        <div class="card">
          <div class="card-body" style="display: flex; flex-direction: column; gap: var(--space-md);">
            <div style="display: flex; align-items: center; gap: var(--space-sm);">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--kscw-gold)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;"><path d="M2 3h20"/><path d="M21 3v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V3"/><path d="m7 21 5-5 5 5"/></svg>
              <h3 style="margin: 0;">{t(locale, 'scorerCoursesPptEn')}</h3>
            </div>
            <p style="color: var(--text-secondary); flex: 1;">{t(locale, 'scorerCoursesPptEnDesc')}</p>
            <a href="https://drive.google.com/file/d/1schQMhMisMvREcENKssmgI4VHmtP1mwh/view" target="_blank" rel="noopener noreferrer" class="btn btn-blue" style="align-self: flex-start;">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 6px;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
              <span>{t(locale, 'scorerCoursesDownload')}</span>
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Swiss Volley Link -->
  <section class="section">
    <div class="container">
      <div style="max-width: 800px; text-align: center;">
        <p style="font-size: 1.125rem; line-height: 1.8; color: var(--text-secondary); margin-bottom: var(--space-lg);">
          {t(locale, 'scorerCoursesSwissVolley')}
        </p>
        <a href="https://www.volleyball.ch/de/ausbildung/schiedsrichter-innen/schreiber-in-werden" target="_blank" rel="noopener noreferrer" class="btn btn-gold" style="font-size: 1.125rem; padding: var(--space-md) var(--space-xl);">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 8px;"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
          <span>{t(locale, 'scorerCoursesSwissVolleyLink')}</span>
        </a>
      </div>
    </div>
  </section>

  <script src="../../../islands/scroll-animations.ts"></script>
</PageLayout>
