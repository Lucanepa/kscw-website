            </div>
            <span class="badge badge-blue">U16</span>
            <p class="team-card-meta mt-sm">Tue 17:00-18:30, Thu 17:00-18:30</p>
            <p class="team-card-meta mt-md" style="color: var(--kscw-blue); font-weight: 600;">{t(locale, 'bbMore')} &rarr;</p>
