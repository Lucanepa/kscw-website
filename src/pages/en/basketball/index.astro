---
import PageLayout from '../../../layouts/PageLayout.astro';
import CTA from '../../../components/CTA.astro';
import { t } from '../../../lib/i18n';
import SectionHeader from '../../../components/SectionHeader.astro';

const locale = 'en';
---
<PageLayout
  title="Basketball — KSC Wiedikon"
  description="All basketball teams of KSC Wiedikon — From 1. Liga to U8."
  locale={locale}
  pageTitle={t(locale, 'bbTitle')}
  pageSubtitle={t(locale, 'bbSubtitle')}
>
  <!-- Women -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>{t(locale, 'bbWomen')}</h2>
          <div class="gold-bar"></div>
        </div>
      </div>
      <div class="grid grid-4">

        <a href={`/${locale}/basketball/lions`} class="card team-card team-card--photo">
          <img src="https://kscw-api.lucanepa.com/api/files/pbc_1568971955/31k9c1qk62p23oe/bblions_ldzkbkw0b2.jpg?thumb=640x0" alt="Team photo" class="team-card-img" loading="lazy">
          <div class="card-body">
            <div class="team-card-header">
              <span class="chip" style="background: #6d28d9; color: #ffffff;">Lions</span>
              <h3>Lions</h3>
            </div>
            <span class="badge badge-blue">1. Liga</span>
            <p class="team-card-meta mt-sm">Mon 20:00-21:30, Thu 19:30-21:30</p>
            <p class="team-card-meta mt-md" style="color: var(--kscw-blue); font-weight: 600;">{t(locale, 'bbMore')} &rarr;</p>
          </div>
        </a>

        <a href={`/${locale}/basketball/rhinos`} class="card team-card team-card--photo">
          <img src="https://kscw-api.lucanepa.com/api/files/pbc_1568971955/cj55682587v210q/bbrhinos_jzjphi50in.jpg?thumb=640x0" alt="Team photo" class="team-card-img" loading="lazy">
          <div class="card-body">
            <div class="team-card-header">
              <span class="chip" style="background: #059669; color: #ffffff;">Rhinos</span>
              <h3>Rhinos</h3>
            </div>
            <span class="badge badge-blue">2. Liga</span>
            <p class="team-card-meta mt-sm">Tue 20:00-21:30, Thu 20:00-21:30</p>
            <p class="team-card-meta mt-md" style="color: var(--kscw-blue); font-weight: 600;">{t(locale, 'bbMore')} &rarr;</p>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- Men -->
  <section class="section-alt">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>{t(locale, 'bbMen')}</h2>
          <div class="gold-bar"></div>
        </div>
      </div>
      <div class="grid grid-4">

        <a href={`/${locale}/basketball/h1`} class="card team-card team-card--photo">
          <img src="https://kscw-api.lucanepa.com/api/files/pbc_1568971955/wpg9887276cdkd9/bbh1_bo760yoe5s.jpg?thumb=640x0" alt="Team photo" class="team-card-img" loading="lazy">
          <div class="card-body">
            <div class="team-card-header">
              <span class="chip" style="background: #9a3412; color: #ffffff;">BB-H1</span>
              <h3>Herren 1</h3>
            </div>
            <span class="badge badge-blue">1. Liga</span>
            <p class="team-card-meta mt-sm">Mon 20:00-21:30, Wed 20:00-21:30</p>
            <p class="team-card-meta mt-md" style="color: var(--kscw-blue); font-weight: 600;">{t(locale, 'bbMore')} &rarr;</p>
          </div>
        </a>

        <a href={`/${locale}/basketball/h3`} class="card team-card team-card--photo">
