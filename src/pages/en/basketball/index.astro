---
import PageLayout from '../../../layouts/PageLayout.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import TeamCard from '../../../components/TeamCard.astro';
import CTA from '../../../components/CTA.astro';
import { t } from '../../../lib/i18n';
import { getActiveTeams, type Team } from '../../../lib/fetch/teams';
import { allTeamDefs } from '../../../data/teams';

const locale = 'en';
const basePath = `/${locale}/basketball`;

let allTeams: Team[];
try {
  allTeams = await getActiveTeams();
} catch {
  allTeams = allTeamDefs.map(d => ({ ...d, league: d.fallbackLeague || '', photoUrl: '', season: '' }));
}
const bb = (cat: string) =>
  allTeams
    .filter(t => t.sport === 'basketball' && t.category === cat)
    .sort((a, b) => a.order - b.order);

const women = bb('women');
const men = bb('men');
const youth = bb('youth');

const moreText = `${t(locale, 'bbMore')} &rarr;`;
---
<PageLayout
  title="Basketball — KSC Wiedikon"
  description="All basketball teams of KSC Wiedikon — From 1. Liga to U8."
  locale={locale}
  pageTitle={t(locale, 'bbTitle')}
  pageSubtitle={t(locale, 'bbSubtitle')}
>
  <!-- Women -->
  <section class="section">
    <div class="container">
      <SectionHeader title={t(locale, 'bbWomen')} />
      <div class="grid grid-4">
        {women.map((team: TeamData) => (
          <TeamCard team={team} locale={locale} basePath={basePath} moreText={moreText} />
        ))}
      </div>
    </div>
  </section>

  <!-- Men -->
  <section class="section-alt">
    <div class="container">
      <SectionHeader title={t(locale, 'bbMen')} />
      <div class="grid grid-4">
        {men.map((team: TeamData) => (
          <TeamCard team={team} locale={locale} basePath={basePath} moreText={moreText} />
        ))}
      </div>
    </div>
  </section>

  <!-- Youth -->
  <section class="section">
    <div class="container">
      <SectionHeader title={t(locale, 'bbYouth')} />
      <div class="grid grid-4">
        {youth.map((team: TeamData) => (
          <TeamCard team={team} locale={locale} basePath={basePath} moreText={moreText} />
        ))}
      </div>
    </div>
  </section>

  <!-- Scoreboard -->
  <section class="section-alt" id="bb-scoreboard-section">
    <div class="container">
      <SectionHeader title="KSCW Basketball Scoreboard" />
      <div id="bb-scoreboard" data-scoreboard="basketball"></div>
    </div>
  </section>

  <CTA
    title={t(locale, 'bbCTA')}
    text={t(locale, 'bbCTAText')}
    buttonLabel={t(locale, 'bbCTAButton')}
    buttonHref={`/${locale}/club/kontakt`}
  />

  <script is:inline src="/js/scoreboard.js"></script>
</PageLayout>
