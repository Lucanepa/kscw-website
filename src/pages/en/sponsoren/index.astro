---
import PageLayout from '../../../layouts/PageLayout.astro';
import { t } from '../../../lib/i18n';
import { getSponsors } from '../../../lib/fetch/sponsors';

const locale = 'en';

let sponsors: any[] = [];
try {
  sponsors = await getSponsors();
} catch (e) {
  console.warn('Failed to fetch sponsors:', e);
}
---
<PageLayout
  title="Sponsors — KSC Wiedikon"
  description="Our sponsors — Partners of KSC Wiedikon for volleyball and basketball in Zurich."
  locale={locale}
  pageTitle={t(locale, 'sponsorsTitle')}
  pageSubtitle={t(locale, 'sponsorsSubtitle')}
>
  <!-- Sponsors Grid -->
  <section class="section">
    <div class="container">
      <div id="sponsors-grid">
        {sponsors.length > 0 ? (
          <div class="sponsors-grid">
            {sponsors.map(s => (
              <div class="sponsor-card">
                {s.websiteUrl ? (
                  <a href={s.websiteUrl} target="_blank" rel="noopener noreferrer">
                    {s.logoUrl && <img class="sponsor-logo" src={s.logoUrl} alt={s.name} loading="lazy" />}
                    {s.name && <div class="sponsor-name">{s.name}</div>}
                  </a>
                ) : (
                  <div>
                    {s.logoUrl && <img class="sponsor-logo" src={s.logoUrl} alt={s.name} loading="lazy" />}
                    {s.name && <div class="sponsor-name">{s.name}</div>}
                  </div>
                )}
              </div>
            ))}
          </div>
        ) : (
          <div class="sponsors-error">Sponsors could not be loaded</div>
        )}
      </div>
    </div>
  </section>

  <!-- Become a Sponsor -->
  <section class="section" style="background: var(--bg-muted, #f9fafb);">
    <div class="container">
      <div class="become-sponsor">
        <h2>{t(locale, 'sponsorsBecome')}</h2>
        <p style="font-size: var(--text-lg); opacity: 0.9; margin-bottom: var(--space-xl); max-width: 600px; margin-left: auto; margin-right: auto;">
          {t(locale, 'sponsorsBecomeText')}
        </p>
        <div class="benefits-list">
          <div class="benefit-item">
            <span class="benefit-check">
              <i data-lucide="check" style="width: 14px; height: 14px;"></i>
            </span>
            <span>{t(locale, 'sponsorsBenefitLogo')}</span>
          </div>
          <div class="benefit-item">
            <span class="benefit-check">
              <i data-lucide="check" style="width: 14px; height: 14px;"></i>
            </span>
            <span>{t(locale, 'sponsorsBenefitJersey')}</span>
          </div>
          <div class="benefit-item">
            <span class="benefit-check">
              <i data-lucide="check" style="width: 14px; height: 14px;"></i>
            </span>
            <span>{t(locale, 'sponsorsBenefitSocial')}</span>
          </div>
          <div class="benefit-item">
            <span class="benefit-check">
              <i data-lucide="check" style="width: 14px; height: 14px;"></i>
            </span>
            <span>{t(locale, 'sponsorsBenefitVIP')}</span>
          </div>
        </div>
        <a href={`/${locale}/club/kontakt`} class="btn btn-gold" style="font-size: var(--text-base);">{t(locale, 'sponsorsCTAButton')}</a>
      </div>
    </div>
  </section>


</PageLayout>

<style is:global>
  .sponsors-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
  }
  @media (max-width: 1024px) {
    .sponsors-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .sponsors-grid { grid-template-columns: 1fr; }
  }
  .sponsor-card {
    background: var(--card-bg, #ffffff);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl) var(--space-lg);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: 120px;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
    overflow: hidden;
  }
  .sponsor-card:hover {
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    transform: translateY(-2px);
  }
  .sponsor-card a {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: inherit;
  }
  .sponsor-logo {
    max-height: 80px;
    max-width: 100%;
    object-fit: contain;
  }
  .sponsor-name {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-primary);
    margin-top: var(--space-sm);
  }
  .sponsors-loading,
  .sponsors-error {
    text-align: center;
    padding: var(--space-3xl) 0;
    font-size: var(--text-lg);
    color: var(--text-muted);
  }
  .sponsors-error {
    color: var(--text-primary);
  }
  .become-sponsor {
    background: linear-gradient(135deg, var(--kscw-blue, #4A55A2) 0%, #3b4590 100%);
    color: #ffffff;
    border-radius: var(--radius-lg);
    padding: var(--space-3xl);
    text-align: center;
  }
  @media (max-width: 480px) {
    .become-sponsor { padding: var(--space-xl) var(--space-lg); }
  }
  .become-sponsor h2 {
    font-size: var(--text-2xl);
    font-weight: 800;
    margin-bottom: var(--space-lg);
  }
  .benefits-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-sm) var(--space-xl);
    max-width: 560px;
    margin: 0 auto var(--space-xl);
    text-align: left;
  }
  @media (max-width: 480px) {
    .benefits-list { grid-template-columns: 1fr; }
  }
  .benefit-item {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-sm);
    font-weight: 500;
  }
  .benefit-check {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: rgba(255,255,255,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
</style>
