---
import PageLayout from '../../../layouts/PageLayout.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import TeamCard from '../../../components/TeamCard.astro';
import CTA from '../../../components/CTA.astro';
import { t } from '../../../lib/i18n';
import { fetchAllTeams } from '../../../lib/pocketbase';
import type { TeamData } from '../../../data/teams';

const locale = 'en';
const basePath = `/${locale}/volleyball`;

const allTeams = await fetchAllTeams();
const vb = (cat: string) =>
  allTeams
    .filter((t: TeamData) => t.sport === 'volleyball' && t.category === cat)
    .sort((a: TeamData, b: TeamData) => a.order - b.order);

const men = vb('men');
const women = vb('women');
const youth = vb('youth');

const moreText = `${t(locale, 'vbMore')} &rarr;`;
---
<PageLayout
  title="Volleyball — KSC Wiedikon"
  description="All volleyball teams of KSC Wiedikon — From 2. Liga to youth."
  locale={locale}
  pageTitle={t(locale, 'vbTitle')}
  pageSubtitle={t(locale, 'vbSubtitle')}
>
  <!-- Men -->
  <section class="section">
    <div class="container">
      <SectionHeader title={t(locale, 'vbMen')} />
      <div class="grid grid-4">
        {men.map((team: TeamData) => (
          <TeamCard team={team} locale={locale} basePath={basePath} moreText={moreText} />
        ))}
      </div>
    </div>
  </section>

  <!-- Women -->
  <section class="section-alt">
    <div class="container">
      <SectionHeader title={t(locale, 'vbWomen')} />
      <div class="grid grid-4">
        {women.map((team: TeamData) => (
          <TeamCard team={team} locale={locale} basePath={basePath} moreText={moreText} />
        ))}
      </div>
    </div>
  </section>

  <!-- Youth -->
  <section class="section">
    <div class="container">
      <SectionHeader title={t(locale, 'vbYouth')} />
      <div class={`grid grid-${Math.min(youth.length, 4)}`}>
        {youth.map((team: TeamData) => (
          <TeamCard team={team} locale={locale} basePath={basePath} moreText={moreText} />
        ))}
      </div>
    </div>
  </section>

  <!-- Scoreboard -->
  <section class="section-alt" id="vb-scoreboard-section">
    <div class="container">
      <SectionHeader title="KSCW Volleyball Scoreboard" />
      <div id="vb-scoreboard" data-scoreboard="volleyball"></div>
    </div>
  </section>

  <CTA
    title={t(locale, 'vbCTA')}
    text={t(locale, 'vbCTAText')}
    buttonLabel={t(locale, 'vbCTAButton')}
    buttonHref={`/${locale}/club/kontakt`}
  />

  <script is:inline src="/js/data.js"></script>
  <script is:inline src="/js/scoreboard.js"></script>
</PageLayout>
