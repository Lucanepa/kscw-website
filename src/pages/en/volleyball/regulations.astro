---
import PageLayout from '../../../layouts/PageLayout.astro';
import { t } from '../../../lib/i18n';

const locale = 'en';
---
<PageLayout
  title="Regulations — KSC Wiedikon"
  description="Volleyball regulations and rules — Swiss Volley, SVRZ and FIVB game rules."
  locale={locale}
  pageTitle={t(locale, 'regTitle')}
  pageSubtitle={t(locale, 'regSubtitle')}
>
  <!-- Intro -->
  <section class="section">
    <div class="container">
      <div style="max-width: 800px;">
        <p style="font-size: 1.125rem; line-height: 1.8; color: var(--text-secondary);">
          {t(locale, 'regIntro')}
        </p>
      </div>
    </div>
  </section>

  <!-- Accordion Sections -->
  <section class="section-alt">
    <div class="container">
      <div class="accordion">

        <!-- Swiss Volley -->
        <div class="accordion-item">
          <button class="accordion-header" aria-expanded="false">
            <span class="accordion-header-left">
              <svg class="accordion-header-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              <span>{t(locale, 'regSwissVolley')}</span>
            </span>
            <svg class="accordion-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </button>
          <div class="accordion-content">
            <div class="accordion-body">
              <p class="accordion-desc">{t(locale, 'regSwissVolleyDesc')}</p>
              <div class="reg-list">
                <a href="https://www.volleyball.ch/de/wissen/clublizenzierung" target="_blank" rel="noopener noreferrer" class="reg-link">
                  <svg class="reg-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
                  <div class="reg-link-text">
                    <div class="reg-link-title">{t(locale, 'regClubLicensing')}</div>
                    <div class="reg-link-subtitle">{t(locale, 'regClubLicensingDesc')}</div>
                  </div>
                  <svg class="reg-link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </a>
                <a href="https://www.volleyball.ch/de/wissen/entschaedigung-von-trainer-innen" target="_blank" rel="noopener noreferrer" class="reg-link">
                  <svg class="reg-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
                  <div class="reg-link-text">
                    <div class="reg-link-title">{t(locale, 'regTrainerCompensation')}</div>
                    <div class="reg-link-subtitle">{t(locale, 'regTrainerCompensationDesc')}</div>
                  </div>
                  <svg class="reg-link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </a>
                <a href="https://www.volleyball.ch/de/wissen/ethik-charta-swiss-volley" target="_blank" rel="noopener noreferrer" class="reg-link">
                  <svg class="reg-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
                  <div class="reg-link-text">
                    <div class="reg-link-title">{t(locale, 'regEthicsCharter')}</div>
                    <div class="reg-link-subtitle">{t(locale, 'regEthicsCharterDesc')}</div>
                  </div>
                  <svg class="reg-link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </a>
                <a href="https://www.volleyball.ch/de/wissen/leitlinien-zur-verankerung-der-praevention-von-sexuellen-uebergriffen" target="_blank" rel="noopener noreferrer" class="reg-link">
                  <svg class="reg-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
                  <div class="reg-link-text">
                    <div class="reg-link-title">{t(locale, 'regPrevention')}</div>
                    <div class="reg-link-subtitle">{t(locale, 'regPreventionDesc')}</div>
                  </div>
                  <svg class="reg-link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- SVRZ Reglemente -->
        <div class="accordion-item">
          <button class="accordion-header" aria-expanded="false">
            <span class="accordion-header-left">
              <svg class="accordion-header-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
              <span>{t(locale, 'regSVRZ')}</span>
            </span>
            <svg class="accordion-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </button>
          <div class="accordion-content">
            <div class="accordion-body">
              <p class="accordion-desc">{t(locale, 'regSVRZDesc')}</p>
              <div class="reg-list">
                <a href="https://www.svrz.ch/_Resources/Persistent/3/0/c/c/30cc3b51e69852fa58e527f749c44b35584cdace/Volleyballreglement%20inkl.%20ER%20SVRZ%2025-26.pdf" target="_blank" rel="noopener noreferrer" class="reg-link">
                  <svg class="reg-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                  <div class="reg-link-text">
                    <div class="reg-link-title">{t(locale, 'regSVRZVolleyball')}</div>
                  </div>
                  <svg class="reg-link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </a>
                <a href="https://www.svrz.ch/_Resources/Persistent/1/0/b/d/10bd802a6d467aa6377b57861dbb45486aec85f6/SVRZ-RE_25-26.pdf" target="_blank" rel="noopener noreferrer" class="reg-link">
                  <svg class="reg-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                  <div class="reg-link-text">
                    <div class="reg-link-title">{t(locale, 'regSVRZCompensation')}</div>
                  </div>
                  <svg class="reg-link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </a>
                <a href="https://www.svrz.ch/_Resources/Persistent/f/9/9/5/f9956469b1702fe3c6223185cdf32102638861c8/SVRZ-GBO_25-26.pdf" target="_blank" rel="noopener noreferrer" class="reg-link">
                  <svg class="reg-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                  <div class="reg-link-text">
                    <div class="reg-link-title">{t(locale, 'regSVRZFees')}</div>
                  </div>
                  <svg class="reg-link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </a>
                <a href="https://www.svrz.ch/_Resources/Persistent/9/3/c/d/93cd66cf96300887998d1d9f57b6eb71cc86d27d/SVRZ_Reglement-Verbandsgericht_Juni18.pdf" target="_blank" rel="noopener noreferrer" class="reg-link">
                  <svg class="reg-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                  <div class="reg-link-text">
                    <div class="reg-link-title">{t(locale, 'regSVRZCourt')}</div>
                  </div>
                  <svg class="reg-link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </a>
                <a href="https://www.svrz.ch/_Resources/Persistent/0/6/1/a/061a1b2e822545a409d76335cb0bfb9434da8046/SVRZ%20Cup%20Reglement_25-26.pdf" target="_blank" rel="noopener noreferrer" class="reg-link">
                  <svg class="reg-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                  <div class="reg-link-text">
                    <div class="reg-link-title">{t(locale, 'regSVRZCup')}</div>
                  </div>
                  <svg class="reg-link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </a>
                <a href="https://www.svrz.ch/_Resources/Persistent/b/e/3/b/be3b0f05238243789d957a61e99ff1dc0ed7182d/SVRZ-ZM_25-26.pdf" target="_blank" rel="noopener noreferrer" class="reg-link">
                  <svg class="reg-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                  <div class="reg-link-text">
                    <div class="reg-link-title">{t(locale, 'regSVRZChampionship')}</div>
                  </div>
                  <svg class="reg-link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </a>
                <a href="https://www.svrz.ch/_Resources/Persistent/e/6/0/2/e60237dbc14332135468954a647046f0c1a25697/Reglement%20zur%20regionalen%20N-SM%20Qualifikation.pdf" target="_blank" rel="noopener noreferrer" class="reg-link">
                  <svg class="reg-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                  <div class="reg-link-text">
                    <div class="reg-link-title">{t(locale, 'regSVRZQualification')}</div>
                  </div>
                  <svg class="reg-link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- SVRZ Spielplanung -->
        <div class="accordion-item">
          <button class="accordion-header" aria-expanded="false">
            <span class="accordion-header-left">
              <svg class="accordion-header-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
              <span>{t(locale, 'regSVRZScheduling')}</span>
            </span>
            <svg class="accordion-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </button>
          <div class="accordion-content">
            <div class="accordion-body">
              <p class="accordion-desc">{t(locale, 'regSVRZSchedulingDesc')}</p>
              <div class="reg-list">
                <a href="https://www.svrz.ch/_Resources/Persistent/4/4/8/6/4486bed64ff107fe4fa7743b2f40c3c0c8937dc1/Gruppeneinteilung%20Saison%2025-26.pdf" target="_blank" rel="noopener noreferrer" class="reg-link">
                  <svg class="reg-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                  <div class="reg-link-text">
                    <div class="reg-link-title">{t(locale, 'regSVRZGroups')}</div>
                  </div>
                  <svg class="reg-link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </a>
                <a href="https://www.svrz.ch/fileadmin/SVRZ/user_upload/Reglemente/Rastervorlagen.pdf" target="_blank" rel="noopener noreferrer" class="reg-link">
                  <svg class="reg-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                  <div class="reg-link-text">
                    <div class="reg-link-title">{t(locale, 'regSVRZTemplates')}</div>
                  </div>
                  <svg class="reg-link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </a>
                <a href="https://www.svrz.ch/_Resources/Persistent/b/0/4/9/b0497b0c615e404892a7bbb216645220a3c8405a/SVRZ-MK_SpiPlaSitz-Vorgaben.xlsx" target="_blank" rel="noopener noreferrer" class="reg-link">
                  <svg class="reg-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                  <div class="reg-link-text">
                    <div class="reg-link-title">{t(locale, 'regSVRZRaster')}</div>
                  </div>
                  <svg class="reg-link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Regionaler Züri Cup -->
        <div class="accordion-item">
          <button class="accordion-header" aria-expanded="false">
            <span class="accordion-header-left">
              <svg class="accordion-header-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
              <span>{t(locale, 'regZuriCup')}</span>
            </span>
            <svg class="accordion-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </button>
          <div class="accordion-content">
            <div class="accordion-body">
              <p class="accordion-desc">{t(locale, 'regZuriCupDesc')}</p>
              <div class="reg-list">
                <a href="https://www.svrz.ch/_Resources/Persistent/6/3/2/6/63266ccc29b82f3baea8d4fffd713b92a424f432/Reglement%20Z%C3%BCri%20Cup%202023-24.pdf" target="_blank" rel="noopener noreferrer" class="reg-link">
                  <svg class="reg-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                  <div class="reg-link-text">
                    <div class="reg-link-title">{t(locale, 'regSVRZCup')}</div>
                  </div>
                  <svg class="reg-link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </a>
                <a href="https://www.svrz.ch/erwachsene/volleyball/regionaler-zueri-cup" target="_blank" rel="noopener noreferrer" class="reg-link">
                  <svg class="reg-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
                  <div class="reg-link-text">
                    <div class="reg-link-title">Züri Cup — SVRZ</div>
                    <div class="reg-link-subtitle">Dates, registration and current information</div>
                  </div>
                  <svg class="reg-link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- FIVB Spielregeln -->
        <div class="accordion-item">
          <button class="accordion-header" aria-expanded="false">
            <span class="accordion-header-left">
              <svg class="accordion-header-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/><path d="M12 13V7"/><path d="m15 10-3 3-3-3"/></svg>
              <span>{t(locale, 'regFIVB')}</span>
            </span>
            <svg class="accordion-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </button>
          <div class="accordion-content">
            <div class="accordion-body">
              <p class="accordion-desc">{t(locale, 'regFIVBDesc')}</p>
              <div class="reg-iframe-wrapper">
                <iframe src="https://readvolley.openvolley.app" title="FIVB Volleyball Rules" loading="lazy" allow="fullscreen"></iframe>
              </div>
              <div style="text-align: center; margin-top: var(--space-lg);">
                <a href="https://readvolley.openvolley.app" target="_blank" rel="noopener noreferrer" class="btn btn-blue">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 6px;"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
                  <span>{t(locale, 'regFIVBOpen')}</span>
                </a>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <script src="../../../islands/accordion.ts"></script>
  <script src="../../../islands/scroll-animations.ts"></script>
</PageLayout>
