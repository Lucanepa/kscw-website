---
import PageLayout from '../../../layouts/PageLayout.astro';
import { t } from '../../../lib/i18n';

const locale = 'en';
---
<PageLayout
  title="Privacy Policy — KSC Wiedikon"
  description="Privacy policy of KSC Wiedikon — Information about how we handle your data."
  locale={locale}
  pageTitle={t(locale, 'privacyTitle')}
  pageSubtitle={t(locale, 'privacySubtitle')}
>
  <section class="section">
    <div class="container">
      <div class="legal-content">

        <p class="legal-intro">{t(locale, 'privacyIntro')}</p>

        <div class="legal-card">
          <h2>{t(locale, 'privacyResponsible')}</h2>
          <p>{t(locale, 'privacyResponsibleText')}</p>
          <p style="margin-top: var(--space-sm);"><strong>KSC Wiedikon</strong><br>Schrennengasse 7<br>8003 Zürich<br><a href="mailto:kscw@kscw.ch">kscw@kscw.ch</a></p>
        </div>

        <div class="legal-card">
          <h2>{t(locale, 'privacyCollection')}</h2>
          <p>{t(locale, 'privacyCollectionText')}</p>
        </div>

        <div class="legal-card">
          <h2>{t(locale, 'privacyContact')}</h2>
          <p>{t(locale, 'privacyContactText')}</p>
        </div>

        <div class="legal-card">
          <h2>{t(locale, 'privacyCookies')}</h2>
          <p>{t(locale, 'privacyCookiesText')}</p>
        </div>

        <div class="legal-card">
          <h2>{t(locale, 'privacyThirdParty')}</h2>
          <p>{t(locale, 'privacyThirdPartyText')}</p>
        </div>

        <div class="legal-card">
          <h2>{t(locale, 'privacyRights')}</h2>
          <p>{t(locale, 'privacyRightsText')}</p>
          <p style="margin-top: var(--space-sm);"><a href="mailto:kscw@kscw.ch">kscw@kscw.ch</a></p>
        </div>

        <div class="legal-card">
          <h2>{t(locale, 'privacyChanges')}</h2>
          <p>{t(locale, 'privacyChangesText')}</p>
        </div>

      </div>
    </div>
  </section>
</PageLayout>

<style>
  .legal-content {
    max-width: 720px;
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    text-align: justify;
  }
  .legal-intro {
    font-size: var(--text-base);
    line-height: 1.8;
    color: var(--text-secondary);
  }
  .legal-card h2 {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--kscw-blue, #4A55A2);
    margin-bottom: var(--space-sm);
  }
  .legal-card p {
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--text-secondary);
  }
  .legal-card a {
    color: var(--kscw-blue, #4A55A2);
  }
  .legal-card a:hover {
    text-decoration: underline;
  }
</style>
