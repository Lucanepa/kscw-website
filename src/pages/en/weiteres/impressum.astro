---
import PageLayout from '../../../layouts/PageLayout.astro';
import { t } from '../../../lib/i18n';

const locale = 'en';
---
<PageLayout
  title="Imprint — KSC Wiedikon"
  description="Imprint of KSC Wiedikon — Legal information and liability notices."
  locale={locale}
  pageTitle={t(locale, 'imprintTitle')}
  pageSubtitle={t(locale, 'imprintSubtitle')}
>
  <section class="section">
    <div class="container">
      <div class="legal-content">

        <div class="legal-card">
          <h2>{t(locale, 'imprintClubName')}</h2>
          <p><strong>KSC Wiedikon</strong></p>
          <p>Kultur- und Sportclub Wiedikon</p>
        </div>

        <div class="legal-card">
          <h2>{t(locale, 'imprintAddress')}</h2>
          <p>Schrennengasse 7</p>
          <p>8003 Zürich</p>
        </div>

        <div class="legal-card">
          <h2>{t(locale, 'imprintContact')}</h2>
          <p>Email: <a href="mailto:kscw@kscw.ch">kscw@kscw.ch</a></p>
          <p>Website: <a href="https://kscw.ch">kscw.ch</a></p>
        </div>

        <div class="legal-card">
          <h2>{t(locale, 'imprintBoard')}</h2>
          <p>{t(locale, 'imprintBoardText')}</p>
          <p style="margin-top: var(--space-sm);"><a href={`/${locale}/club/vorstand`} class="btn btn-sm">{t(locale, 'imprintBoardLink')}</a></p>
        </div>

        <div class="legal-card">
          <h2>{t(locale, 'imprintDisclaimer')}</h2>
          <p>{t(locale, 'imprintDisclaimerText')}</p>
        </div>

        <div class="legal-card">
          <h2>{t(locale, 'imprintLinks')}</h2>
          <p>{t(locale, 'imprintLinksText')}</p>
        </div>

        <div class="legal-card">
          <h2>{t(locale, 'imprintCopyright')}</h2>
          <p>{t(locale, 'imprintCopyrightText')}</p>
        </div>

      </div>
    </div>
  </section>
</PageLayout>

<style>
  .legal-content {
    max-width: 720px;
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    text-align: justify;
  }
  .legal-card h2 {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--kscw-blue, #4A55A2);
    margin-bottom: var(--space-sm);
  }
  .legal-card p {
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--text-secondary);
  }
  .legal-card a {
    color: var(--kscw-blue, #4A55A2);
  }
  .legal-card a:hover {
    text-decoration: underline;
  }
</style>
