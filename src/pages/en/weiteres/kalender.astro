---
import PageLayout from '../../../layouts/PageLayout.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import { t } from '../../../lib/i18n';

const locale = 'en';
const PB = 'https://api.kscw.ch';

let allEvents: any[] = [];
try {
  const res = await fetch(`${PB}/api/collections/events/records?sort=start_date&perPage=100`);
  if (res.ok) {
    const data = await res.json();
    allEvents = (data.items ?? []).map((ev: any) => ({
      title: ev.title,
      date: ev.start_date?.split(' ')[0] || ev.start_date,
      endDate: ev.end_date?.split(' ')[0] || '',
      time: ev.all_day ? '' : (ev.start_date?.split(' ')[1]?.slice(0, 5) || ''),
      location: ev.location || '',
      category: ev.event_type || 'other',
      description: ev.description || '',
      body: ev.description || '',
    }));
  }
} catch (e) {
  console.warn('Failed to fetch events from PocketBase:', e);
}

const now = new Date();
const upcomingEvents = allEvents
  .filter(e => new Date(e.date) >= now)
  .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());
---
<PageLayout
  title="Calendar — KSC Wiedikon"
  description="KSC Wiedikon calendar — All games, training sessions and events at a glance."
  locale={locale}
  pageTitle={t(locale, 'calendarTitle')}
  pageSubtitle={t(locale, 'calendarSubtitle')}
>
  <!-- Live Calendar Grid -->
  <section class="section">
    <div class="container">
      <div id="calendar-grid" data-lang="en">
        <div class="cal-loading">Loading games...</div>
      </div>
    </div>
  </section>

  <!-- Events data for calendar grid -->
  <script id="events-data" type="application/json" set:html={JSON.stringify(allEvents)} />

  <!-- Upcoming Events List -->
  {upcomingEvents.length > 0 && (
    <section class="section-alt">
      <div class="container">
        <SectionHeader title={t(locale, 'calendarEvents')} />
        <div class="grid grid-3">
          {upcomingEvents.map(ev => (
            <article class={`card event-card fade-in${ev.description ? ' event-card--clickable' : ''}`}>
              <div class="card-body">
                <div class="flex items-center gap-sm mb-md">
                  <span class="news-date">{new Date(ev.date).toLocaleDateString('en-CH')}</span>
                  <span class="badge badge-green">
                    {ev.category === 'social' ? t(locale, 'eventCategorySocial')
                      : ev.category === 'verein' ? t(locale, 'eventCategoryClub')
                      : ev.category === 'meeting' ? t(locale, 'eventCategoryAssembly')
                      : ev.category === 'tournament' ? t(locale, 'eventCategoryTournament')
                      : t(locale, 'eventCategoryOther')}
                  </span>
                  {ev.description && <span class="event-expand-icon" aria-hidden="true">&#x25BC;</span>}
                </div>
                <h3>{ev.title}</h3>
                {ev.time && <p class="event-location">{ev.time}</p>}
                {ev.location && <p class="event-location">{ev.location}</p>}
              </div>
              {ev.description && (
                <div class="event-description" set:html={ev.description} />
              )}
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- iCal Subscriptions -->
  <section class="section-alt">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>{t(locale, 'calendarSubscribe')}</h2>
          <div class="gold-bar"></div>
        </div>
      </div>
      <p style="color: var(--text-secondary); margin-bottom: var(--space-lg); max-width: 640px;">
        {t(locale, 'calendarSubscribeDescription')}
      </p>
      <div class="grid grid-3" style="max-width: 960px;">
        <div class="card">
          <div class="card-body" style="text-align: center;">
            <i data-lucide="calendar-check" style="width: 48px; height: 48px; color: var(--kscw-blue); margin-bottom: var(--space-md);"></i>
            <h3 style="margin-bottom: var(--space-sm);">{t(locale, 'calendarVolleyball')}</h3>
            <p style="color: var(--text-secondary); margin-bottom: var(--space-md);">{t(locale, 'calendarVolleyballDescription')}</p>
            <a href="webcal://api.kscw.ch/api/ical/volleyball" class="btn btn-outline" target="_blank" rel="noopener noreferrer">
              <i data-lucide="download" style="width: 16px; height: 16px; vertical-align: middle; margin-right: 4px;"></i>
              <span>{t(locale, 'calendarICalSubscribe')}</span>
            </a>
          </div>
        </div>
        <div class="card">
          <div class="card-body" style="text-align: center;">
            <i data-lucide="calendar-check" style="width: 48px; height: 48px; color: var(--kscw-gold); margin-bottom: var(--space-md);"></i>
            <h3 style="margin-bottom: var(--space-sm);">{t(locale, 'calendarBasketball')}</h3>
            <p style="color: var(--text-secondary); margin-bottom: var(--space-md);">{t(locale, 'calendarBasketballDescription')}</p>
            <a href="webcal://api.kscw.ch/api/ical/basketball" class="btn btn-outline" target="_blank" rel="noopener noreferrer">
              <i data-lucide="download" style="width: 16px; height: 16px; vertical-align: middle; margin-right: 4px;"></i>
              <span>{t(locale, 'calendarICalSubscribe')}</span>
            </a>
          </div>
        </div>
        <div class="card">
          <div class="card-body" style="text-align: center;">
            <i data-lucide="calendar-check" style="width: 48px; height: 48px; color: var(--text-primary); margin-bottom: var(--space-md);"></i>
            <h3 style="margin-bottom: var(--space-sm);">{t(locale, 'calendarBoth')}</h3>
            <p style="color: var(--text-secondary); margin-bottom: var(--space-md);">{t(locale, 'calendarBothDescription')}</p>
            <a href="webcal://api.kscw.ch/api/ical" class="btn btn-outline" target="_blank" rel="noopener noreferrer">
              <i data-lucide="download" style="width: 16px; height: 16px; vertical-align: middle; margin-right: 4px;"></i>
              <span>{t(locale, 'calendarICalSubscribe')}</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script src="../../../islands/event-expand.ts"></script>
  <script src="../../../islands/calendar-grid.ts"></script>
</PageLayout>
