---
import PageLayout from '../../../layouts/PageLayout.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import { t } from '../../../lib/i18n';

const locale = 'en';
---
<PageLayout
  title="Calendar — KSC Wiedikon"
  description="KSC Wiedikon calendar — All games, training sessions and events at a glance."
  locale={locale}
  pageTitle={t(locale, 'calendarTitle')}
  pageSubtitle={t(locale, 'calendarSubtitle')}
>
  <!-- Live Calendar Grid -->
  <section class="section">
    <div class="container">
      <div id="calendar-grid" data-lang="en">
        <div class="cal-loading">Loading games...</div>
      </div>
    </div>
  </section>

  <!-- iCal Subscriptions -->
  <section class="section-alt">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>{t(locale, 'calendarSubscribe')}</h2>
          <div class="gold-bar"></div>
        </div>
      </div>
      <p style="color: var(--text-secondary); margin-bottom: var(--space-lg); max-width: 640px;">
        {t(locale, 'calendarSubscribeDescription')}
      </p>
      <div class="grid grid-2" style="max-width: 720px;">
        <div class="card">
          <div class="card-body" style="text-align: center;">
            <i data-lucide="calendar-check" style="width: 48px; height: 48px; color: var(--kscw-blue); margin-bottom: var(--space-md);"></i>
            <h3 style="margin-bottom: var(--space-sm);">{t(locale, 'calendarVolleyball')}</h3>
            <p style="color: var(--text-secondary); margin-bottom: var(--space-md);">{t(locale, 'calendarVolleyballDescription')}</p>
            <a href="https://kscw.lucanepa.com/api/ical/volleyball" class="btn btn-outline" target="_blank" rel="noopener noreferrer">
              <i data-lucide="download" style="width: 16px; height: 16px; vertical-align: middle; margin-right: 4px;"></i>
              <span>{t(locale, 'calendarICalSubscribe')}</span>
            </a>
          </div>
        </div>
        <div class="card">
          <div class="card-body" style="text-align: center;">
            <i data-lucide="calendar-check" style="width: 48px; height: 48px; color: var(--kscw-gold); margin-bottom: var(--space-md);"></i>
            <h3 style="margin-bottom: var(--space-sm);">{t(locale, 'calendarBasketball')}</h3>
            <p style="color: var(--text-secondary); margin-bottom: var(--space-md);">{t(locale, 'calendarBasketballDescription')}</p>
            <a href="https://kscw.lucanepa.com/api/ical/basketball" class="btn btn-outline" target="_blank" rel="noopener noreferrer">
              <i data-lucide="download" style="width: 16px; height: 16px; vertical-align: middle; margin-right: 4px;"></i>
              <span>{t(locale, 'calendarICalSubscribe')}</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script src="../../../islands/calendar-grid.ts"></script>
</PageLayout>
