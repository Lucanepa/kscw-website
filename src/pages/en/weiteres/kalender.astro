---
import PageLayout from '../../../layouts/PageLayout.astro';
import { t } from '../../../lib/i18n';
import { getAllEvents } from '../../../lib/fetch/events';

const locale = 'en';

let allEvents: any[] = [];
try {
  const events = await getAllEvents();
  allEvents = events.map(ev => ({
    title: ev.title,
    date: ev.startDate,
    endDate: ev.endDate || '',
    time: '',
    location: ev.location || '',
    category: ev.eventType || 'other',
    description: ev.description || '',
    body: ev.description || '',
  }));
} catch (e) {
  console.warn('Failed to fetch events:', e);
}
---
<PageLayout
  title="Calendar — KSC Wiedikon"
  description="KSC Wiedikon calendar — All games, training sessions and events at a glance."
  locale={locale}
  pageTitle={t(locale, 'calendarTitle')}
  pageSubtitle={t(locale, 'calendarSubtitle')}
>
  <section class="section">
    <div class="container">
      <div id="calendar-grid" data-lang="en">
        <div class="cal-loading">Loading games...</div>
      </div>
    </div>
  </section>

  <script id="events-data" type="application/json" set:html={JSON.stringify(allEvents)} />
  <script src="../../../islands/calendar-grid.ts"></script>
  <script src="../../../islands/scroll-animations.ts"></script>
</PageLayout>
