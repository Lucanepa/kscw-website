---
import PageLayout from '../../../layouts/PageLayout.astro';
import { t } from '../../../lib/i18n';

const locale = 'en';
---
<PageLayout
  title="Membership — KSC Wiedikon"
  description="Become a member of KSC Wiedikon — fees, registration and benefits."
  locale={locale}
  pageTitle={t(locale, 'membershipTitle')}
  pageSubtitle={t(locale, 'membershipSubtitle')}
>
  <!-- Why KSCW? -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>{t(locale, 'membershipWhy')}</h2>
          <div class="gold-bar"></div>
        </div>
      </div>
      <div class="grid grid-3">
        <div class="card">
          <div class="card-body" style="text-align: center;">
            <i data-lucide="users" style="width: 48px; height: 48px; color: var(--kscw-blue); margin-bottom: var(--space-md);"></i>
            <h3 style="margin-bottom: var(--space-sm);">{t(locale, 'membershipTeamSpirit')}</h3>
            <p style="color: var(--text-secondary);">{t(locale, 'membershipTeamSpiritText')}</p>
          </div>
        </div>
        <div class="card">
          <div class="card-body" style="text-align: center;">
            <i data-lucide="trophy" style="width: 48px; height: 48px; color: var(--kscw-gold); margin-bottom: var(--space-md);"></i>
            <h3 style="margin-bottom: var(--space-sm);">{t(locale, 'membershipTraining')}</h3>
            <p style="color: var(--text-secondary);">{t(locale, 'membershipTrainingText')}</p>
          </div>
        </div>
        <div class="card">
          <div class="card-body" style="text-align: center;">
            <i data-lucide="heart" style="width: 48px; height: 48px; color: var(--kscw-blue); margin-bottom: var(--space-md);"></i>
            <h3 style="margin-bottom: var(--space-sm);">{t(locale, 'membershipCommunity')}</h3>
            <p style="color: var(--text-secondary);">{t(locale, 'membershipCommunityText')}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Membership Fees -->
  <section class="section-alt">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>{t(locale, 'membershipFees')}</h2>
          <div class="gold-bar"></div>
        </div>
      </div>
      <div style="max-width: 640px;">
        <!-- Volleyball Fees -->
        <h3 style="margin-bottom: var(--space-md);">
          <i data-lucide="volleyball" style="width: 22px; height: 22px; vertical-align: middle; margin-right: 8px; color: var(--kscw-gold);"></i>
          {t(locale, 'membershipFeesVolleyball')}
        </h3>
        <div class="table-wrap">
        <table style="width: 100%; border-collapse: collapse; background: var(--surface); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-sm);">
          <thead>
            <tr style="background: var(--kscw-blue); color: white;">
              <th style="padding: var(--space-md) var(--space-lg); text-align: left; font-weight: 600;">{t(locale, 'membershipCategory')}</th>
              <th style="padding: var(--space-md) var(--space-lg); text-align: right; font-weight: 600;">{t(locale, 'membershipFee')}</th>
            </tr>
          </thead>
          <tbody>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: var(--space-md) var(--space-lg);">
                <strong>{t(locale, 'membershipCategoryTournamentKWI')}</strong><br>
                <span style="font-size: 0.875rem; color: var(--text-secondary);">{t(locale, 'membershipCategoryTournamentKWIDesc')}</span>
              </td>
              <td style="padding: var(--space-md) var(--space-lg); text-align: right; font-weight: 700; font-size: 1.125rem; color: var(--kscw-blue);">CHF 110</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: var(--space-md) var(--space-lg);">
                <strong>{t(locale, 'membershipCategoryTournament')}</strong><br>
                <span style="font-size: 0.875rem; color: var(--text-secondary);">{t(locale, 'membershipCategoryTournamentDesc')}</span>
              </td>
              <td style="padding: var(--space-md) var(--space-lg); text-align: right; font-weight: 700; font-size: 1.125rem; color: var(--kscw-blue);">CHF 210</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: var(--space-md) var(--space-lg);">
                <strong>{t(locale, 'membershipCategoryHighSchool')}</strong><br>
                <span style="font-size: 0.875rem; color: var(--text-secondary);">{t(locale, 'membershipCategoryHighSchoolDesc')}</span>
              </td>
              <td style="padding: var(--space-md) var(--space-lg); text-align: right; font-weight: 700; font-size: 1.125rem; color: var(--kscw-blue);">CHF 310</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: var(--space-md) var(--space-lg);">
                <strong>{t(locale, 'membershipCategoryStudent')}</strong><br>
                <span style="font-size: 0.875rem; color: var(--text-secondary);">{t(locale, 'membershipCategoryStudentDesc')}</span>
              </td>
              <td style="padding: var(--space-md) var(--space-lg); text-align: right; font-weight: 700; font-size: 1.125rem; color: var(--kscw-blue);">CHF 380</td>
            </tr>
            <tr>
              <td style="padding: var(--space-md) var(--space-lg);">
                <strong>{t(locale, 'membershipCategoryWorking')}</strong><br>
                <span style="font-size: 0.875rem; color: var(--text-secondary);">{t(locale, 'membershipCategoryWorkingDesc')}</span>
              </td>
              <td style="padding: var(--space-md) var(--space-lg); text-align: right; font-weight: 700; font-size: 1.125rem; color: var(--kscw-blue);">CHF 440</td>
            </tr>
          </tbody>
        </table>
        </div>
        <p style="margin-top: var(--space-md); font-size: 0.875rem; color: var(--text-secondary);">
          <i data-lucide="info" style="width: 14px; height: 14px; vertical-align: middle; margin-right: 4px;"></i>
          <span>{t(locale, 'membershipFeesNoteVB')}</span>
        </p>
        <p style="margin-top: var(--space-sm); font-size: 0.875rem; color: var(--kscw-blue); font-weight: 600;">
          <i data-lucide="alert-circle" style="width: 14px; height: 14px; vertical-align: middle; margin-right: 4px;"></i>
          <span>{t(locale, 'membershipFeesNoteScorer')}</span>
        </p>

        <!-- Swiss Volley Licence Fees -->
        <h3 style="margin-top: var(--space-xl); margin-bottom: var(--space-md);">{t(locale, 'membershipLicenceTitle')}</h3>
        <div class="table-wrap">
        <table style="width: 100%; border-collapse: collapse; background: var(--surface); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-sm);">
          <thead>
            <tr style="background: var(--kscw-blue); color: white;">
              <th style="padding: var(--space-sm) var(--space-lg); text-align: left; font-weight: 600;">{t(locale, 'membershipCategory')}</th>
              <th style="padding: var(--space-sm) var(--space-lg); text-align: right; font-weight: 600;">{t(locale, 'membershipFee')}</th>
            </tr>
          </thead>
          <tbody>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: var(--space-sm) var(--space-lg);">{t(locale, 'membershipLicenceNLL')}</td>
              <td style="padding: var(--space-sm) var(--space-lg); text-align: right; font-weight: 600;">CHF 250</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: var(--space-sm) var(--space-lg);">{t(locale, 'membershipLicenceRLL')}</td>
              <td style="padding: var(--space-sm) var(--space-lg); text-align: right; font-weight: 600;">CHF 110</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: var(--space-sm) var(--space-lg);">{t(locale, 'membershipLicenceJLL')}</td>
              <td style="padding: var(--space-sm) var(--space-lg); text-align: right; font-weight: 600;">CHF 60</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: var(--space-sm) var(--space-lg);">{t(locale, 'membershipLicenceU16')}</td>
              <td style="padding: var(--space-sm) var(--space-lg); text-align: right; font-weight: 600;">CHF 30</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: var(--space-sm) var(--space-lg);">{t(locale, 'membershipLicenceU13')}</td>
              <td style="padding: var(--space-sm) var(--space-lg); text-align: right; font-weight: 600;">CHF 15</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: var(--space-sm) var(--space-lg);">{t(locale, 'membershipLicenceDoppelR')}</td>
              <td style="padding: var(--space-sm) var(--space-lg); text-align: right; font-weight: 600;">CHF 110</td>
            </tr>
            <tr>
              <td style="padding: var(--space-sm) var(--space-lg);">{t(locale, 'membershipLicenceDoppelN')}</td>
              <td style="padding: var(--space-sm) var(--space-lg); text-align: right; font-weight: 600;">CHF 250</td>
            </tr>
          </tbody>
        </table>
        </div>

        <!-- Basketball Fees -->
        <h3 style="margin-top: var(--space-2xl); margin-bottom: var(--space-md);">
          <i data-lucide="dribbble" style="width: 22px; height: 22px; vertical-align: middle; margin-right: 8px; color: var(--kscw-gold);"></i>
          {t(locale, 'membershipFeesBasketball')}
        </h3>
        <div class="table-wrap">
        <table style="width: 100%; border-collapse: collapse; background: var(--surface); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-sm);">
          <thead>
            <tr style="background: var(--kscw-blue); color: white;">
              <th style="padding: var(--space-md) var(--space-lg); text-align: left; font-weight: 600;">{t(locale, 'membershipCategory')}</th>
              <th style="padding: var(--space-md) var(--space-lg); text-align: right; font-weight: 600;">{t(locale, 'membershipFee')}</th>
            </tr>
          </thead>
          <tbody>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: var(--space-md) var(--space-lg);">
                <strong>{t(locale, 'membershipCategoryBBActive')}</strong><br>
                <span style="font-size: 0.875rem; color: var(--text-secondary);">{t(locale, 'membershipCategoryBBActiveDesc')}</span>
              </td>
              <td style="padding: var(--space-md) var(--space-lg); text-align: right; font-weight: 700; font-size: 1.125rem; color: var(--kscw-blue);">CHF 350</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: var(--space-md) var(--space-lg);">
                <strong>{t(locale, 'membershipCategoryBBYouth')}</strong><br>
                <span style="font-size: 0.875rem; color: var(--text-secondary);">{t(locale, 'membershipCategoryBBYouthDesc')}</span>
              </td>
              <td style="padding: var(--space-md) var(--space-lg); text-align: right; font-weight: 700; font-size: 1.125rem; color: var(--kscw-blue);">CHF 200</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: var(--space-md) var(--space-lg);">
                <strong>{t(locale, 'membershipCategoryBBPassive')}</strong><br>
                <span style="font-size: 0.875rem; color: var(--text-secondary);">{t(locale, 'membershipCategoryBBPassiveDesc')}</span>
              </td>
              <td style="padding: var(--space-md) var(--space-lg); text-align: right; font-weight: 700; font-size: 1.125rem; color: var(--kscw-blue);">CHF 50</td>
            </tr>
            <tr>
              <td style="padding: var(--space-md) var(--space-lg);">
                <strong>{t(locale, 'membershipCategoryBBFamily')}</strong><br>
                <span style="font-size: 0.875rem; color: var(--text-secondary);">{t(locale, 'membershipCategoryBBFamilyDesc')}</span>
              </td>
              <td style="padding: var(--space-md) var(--space-lg); text-align: right; font-weight: 700; font-size: 1.125rem; color: var(--kscw-blue);">CHF 600</td>
            </tr>
          </tbody>
        </table>
        </div>
        <p style="margin-top: var(--space-md); font-size: 0.875rem; color: var(--text-secondary);">
          <i data-lucide="info" style="width: 14px; height: 14px; vertical-align: middle; margin-right: 4px;"></i>
          <span>{t(locale, 'membershipFeesNoteBB')}</span>
        </p>
      </div>
    </div>
  </section>

  <!-- Registration -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>{t(locale, 'membershipRegistration')}</h2>
          <div class="gold-bar"></div>
        </div>
      </div>
      <div style="max-width: 720px;">
        <p style="font-size: 1.125rem; line-height: 1.8; color: var(--text-secondary); margin-bottom: var(--space-lg);">
          {t(locale, 'membershipRegistrationText')}
        </p>

        <div style="display: flex; flex-direction: column; gap: var(--space-md); margin-bottom: var(--space-xl);">
          <div class="card" style="border-left: 4px solid var(--kscw-gold);">
            <div class="card-body" style="display: flex; align-items: flex-start; gap: var(--space-md);">
              <div style="min-width: 48px; height: 48px; background: var(--kscw-gold); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 1.25rem;">1</div>
              <div>
                <h3 style="margin-bottom: var(--space-xs);">{t(locale, 'membershipStep1')}</h3>
                <p style="color: var(--text-secondary);">{t(locale, 'membershipStep1Text')}</p>
              </div>
            </div>
          </div>
          <div class="card" style="border-left: 4px solid var(--kscw-blue);">
            <div class="card-body" style="display: flex; align-items: flex-start; gap: var(--space-md);">
              <div style="min-width: 48px; height: 48px; background: var(--kscw-blue); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 1.25rem;">2</div>
              <div>
                <h3 style="margin-bottom: var(--space-xs);">{t(locale, 'membershipStep2')}</h3>
                <p style="color: var(--text-secondary);">{t(locale, 'membershipStep2Text')}</p>
              </div>
            </div>
          </div>
          <div class="card" style="border-left: 4px solid var(--kscw-gold);">
            <div class="card-body" style="display: flex; align-items: flex-start; gap: var(--space-md);">
              <div style="min-width: 48px; height: 48px; background: var(--kscw-gold); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 1.25rem;">3</div>
              <div>
                <h3 style="margin-bottom: var(--space-xs);">{t(locale, 'membershipStep3')}</h3>
                <p style="color: var(--text-secondary);">{t(locale, 'membershipStep3Text')}</p>
              </div>
            </div>
          </div>
        </div>

        <div style="margin-bottom: var(--space-lg);">
          <p style="text-align: center; color: var(--text-secondary); margin-bottom: var(--space-lg);">
            <i data-lucide="alert-circle" style="width: 16px; height: 16px; vertical-align: middle; margin-right: 4px;"></i>
            <span>{t(locale, 'membershipCoachNote')}</span>
          </p>
          <div style="display: flex; flex-wrap: wrap; gap: var(--space-md); justify-content: center;">
            <a href="https://www.kscw.ch/weiteres/mitglied_werden/volleyball" target="_blank" rel="noopener noreferrer" class="btn btn-gold" style="font-size: 1rem; padding: var(--space-md) var(--space-xl);">
              <i data-lucide="volleyball" style="width: 18px; height: 18px; vertical-align: middle; margin-right: 8px;"></i>
              <span>{t(locale, 'membershipRegisterVB')}</span>
            </a>
            <a href="https://forms.gle/v4qNHrQybzpFuXgW9" target="_blank" rel="noopener noreferrer" class="btn" style="font-size: 1rem; padding: var(--space-md) var(--space-xl); background: var(--kscw-blue); color: white;">
              <i data-lucide="dribbble" style="width: 18px; height: 18px; vertical-align: middle; margin-right: 8px;"></i>
              <span>{t(locale, 'membershipRegisterBB')}</span>
            </a>
            <a href="https://www.kscw.ch/weiteres/mitglied_werden" target="_blank" rel="noopener noreferrer" class="btn btn-outline" style="font-size: 1rem; padding: var(--space-md) var(--space-xl);">
              <i data-lucide="heart" style="width: 18px; height: 18px; vertical-align: middle; margin-right: 8px;"></i>
              <span>{t(locale, 'membershipRegisterPassive')}</span>
            </a>
          </div>
        </div>
        <div style="text-align: center;">
          <a href={`/${locale}/club/kontakt`} class="btn btn-outline btn-sm">
            <i data-lucide="mail" style="width: 16px; height: 16px; vertical-align: middle; margin-right: 6px;"></i>
            <span>{t(locale, 'membershipCTAButton')}</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
