---
import PageLayout from '../../../layouts/PageLayout.astro';
import { t } from '../../../lib/i18n';

const locale = 'en';
---
<PageLayout
  title="Partners — KSC Wiedikon"
  description="Partners of KSC Wiedikon — functiomed for prevention and medical support."
  locale={locale}
  pageTitle={t(locale, 'partnerTitle')}
  pageSubtitle={t(locale, 'partnerSubtitle')}
>
  <!-- functiomed -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>{t(locale, 'partnerFunctiomed')}</h2>
          <div class="gold-bar"></div>
        </div>
      </div>
      <div style="max-width: 720px;">

        <div style="display: flex; flex-direction: column; gap: var(--space-md); margin-bottom: var(--space-xl);">

          <div class="card" style="border-left: 4px solid var(--kscw-gold);">
            <div class="card-body" style="display: flex; align-items: flex-start; gap: var(--space-md);">
              <div style="min-width: 48px; height: 48px; background: var(--kscw-gold); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                <i data-lucide="shield-check" style="width: 24px; height: 24px;"></i>
              </div>
              <div>
                <h3 style="margin-bottom: var(--space-xs);">{t(locale, 'partnerPrevention')}</h3>
                <p style="color: var(--text-secondary);">{t(locale, 'partnerPreventionText')}</p>
              </div>
            </div>
          </div>

          <div class="card" style="border-left: 4px solid var(--kscw-blue);">
            <div class="card-body" style="display: flex; align-items: flex-start; gap: var(--space-md);">
              <div style="min-width: 48px; height: 48px; background: var(--kscw-blue); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                <i data-lucide="heart-pulse" style="width: 24px; height: 24px;"></i>
              </div>
              <div>
                <h3 style="margin-bottom: var(--space-xs);">{t(locale, 'partnerMedical')}</h3>
                <p style="color: var(--text-secondary);">{t(locale, 'partnerMedicalText')}</p>
              </div>
            </div>
          </div>

        </div>

        <div style="text-align: center; margin-bottom: var(--space-lg);">
          <a href="https://functiomed.ch" target="_blank" rel="noopener noreferrer" class="btn btn-gold" style="font-size: 1.125rem; padding: var(--space-md) var(--space-xl);">
            <i data-lucide="external-link" style="width: 20px; height: 20px; vertical-align: middle; margin-right: 8px;"></i>
            <span>{t(locale, 'partnerVisitWebsite')}</span>
          </a>
        </div>

        <p style="font-size: 0.875rem; color: var(--text-secondary); text-align: center;">
          <i data-lucide="info" style="width: 14px; height: 14px; vertical-align: middle; margin-right: 4px;"></i>
          <span>{t(locale, 'partnerContactNote')}</span>
        </p>
      </div>
    </div>
  </section>
</PageLayout>
