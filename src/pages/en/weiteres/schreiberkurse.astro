---
import PageLayout from '../../../layouts/PageLayout.astro';
import { t } from '../../../lib/i18n';

const locale = 'en';
---
<PageLayout
  title="Scorer Courses — KSC Wiedikon"
  description="Training materials for volleyball scorers at KSC Wiedikon."
  locale={locale}
  pageTitle={t(locale, 'scorerCoursesTitle')}
  pageSubtitle={t(locale, 'scorerCoursesSubtitle')}
>
  <!-- Intro -->
  <section class="section">
    <div class="container">
      <div style="max-width: 800px;">
        <p style="font-size: 1.125rem; line-height: 1.8; color: var(--text-secondary);">
          {t(locale, 'scorerCoursesIntro')}
        </p>
      </div>
    </div>
  </section>

  <!-- Resources Grid -->
  <section class="section-alt">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>Resources</h2>
          <div class="gold-bar"></div>
        </div>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: var(--space-lg); max-width: 900px;">

        <div class="card">
          <div class="card-body" style="display: flex; flex-direction: column; gap: var(--space-md);">
            <div style="display: flex; align-items: center; gap: var(--space-sm);">
              <i data-lucide="file-text" style="width: 32px; height: 32px; color: var(--kscw-blue); flex-shrink: 0;"></i>
              <h3 style="margin: 0;">{t(locale, 'scorerCoursesMatchblatt')}</h3>
            </div>
            <p style="color: var(--text-secondary); flex: 1;">{t(locale, 'scorerCoursesMatchblattDesc')}</p>
            <a href="https://www.volleyball.ch/fileadmin/user_upload/Documents/07_Schiri___Schreiber/Schreiber/Matchblatt_leer.pdf" target="_blank" rel="noopener noreferrer" class="btn btn-blue" style="align-self: flex-start;">
              <i data-lucide="download" style="width: 16px; height: 16px; vertical-align: middle; margin-right: 6px;"></i>
              <span>{t(locale, 'scorerCoursesDownload')}</span>
            </a>
          </div>
        </div>

        <div class="card">
          <div class="card-body" style="display: flex; flex-direction: column; gap: var(--space-md);">
            <div style="display: flex; align-items: center; gap: var(--space-sm);">
              <i data-lucide="monitor-play" style="width: 32px; height: 32px; color: var(--kscw-gold); flex-shrink: 0;"></i>
              <h3 style="margin: 0;">{t(locale, 'scorerCoursesElearning')}</h3>
            </div>
            <p style="color: var(--text-secondary); flex: 1;">{t(locale, 'scorerCoursesElearningDesc')}</p>
            <a href="https://www.volleyball.ch/ausbildung/schiedsrichter-schreiber/schreiber-ausbildung/" target="_blank" rel="noopener noreferrer" class="btn btn-gold" style="align-self: flex-start;">
              <i data-lucide="external-link" style="width: 16px; height: 16px; vertical-align: middle; margin-right: 6px;"></i>
              <span>{t(locale, 'scorerCoursesOpen')}</span>
            </a>
          </div>
        </div>

        <div class="card">
          <div class="card-body" style="display: flex; flex-direction: column; gap: var(--space-md);">
            <div style="display: flex; align-items: center; gap: var(--space-sm);">
              <i data-lucide="file-down" style="width: 32px; height: 32px; color: var(--kscw-blue); flex-shrink: 0;"></i>
              <h3 style="margin: 0;">{t(locale, 'scorerCoursesPdfDe')}</h3>
            </div>
            <p style="color: var(--text-secondary); flex: 1;">{t(locale, 'scorerCoursesPdfDeDesc')}</p>
            <a href="https://www.volleyball.ch/fileadmin/user_upload/Documents/07_Schiri___Schreiber/Schreiber/Schreiberkurs_DE.pdf" target="_blank" rel="noopener noreferrer" class="btn btn-blue" style="align-self: flex-start;">
              <i data-lucide="download" style="width: 16px; height: 16px; vertical-align: middle; margin-right: 6px;"></i>
              <span>{t(locale, 'scorerCoursesDownload')}</span>
            </a>
          </div>
        </div>

        <div class="card">
          <div class="card-body" style="display: flex; flex-direction: column; gap: var(--space-md);">
            <div style="display: flex; align-items: center; gap: var(--space-sm);">
              <i data-lucide="file-down" style="width: 32px; height: 32px; color: var(--kscw-gold); flex-shrink: 0;"></i>
              <h3 style="margin: 0;">{t(locale, 'scorerCoursesPdfEn')}</h3>
            </div>
            <p style="color: var(--text-secondary); flex: 1;">{t(locale, 'scorerCoursesPdfEnDesc')}</p>
            <a href="https://www.volleyball.ch/fileadmin/user_upload/Documents/07_Schiri___Schreiber/Schreiber/Scorer_Course_EN.pdf" target="_blank" rel="noopener noreferrer" class="btn btn-blue" style="align-self: flex-start;">
              <i data-lucide="download" style="width: 16px; height: 16px; vertical-align: middle; margin-right: 6px;"></i>
              <span>{t(locale, 'scorerCoursesDownload')}</span>
            </a>
          </div>
        </div>

        <div class="card">
          <div class="card-body" style="display: flex; flex-direction: column; gap: var(--space-md);">
            <div style="display: flex; align-items: center; gap: var(--space-sm);">
              <i data-lucide="presentation" style="width: 32px; height: 32px; color: var(--kscw-blue); flex-shrink: 0;"></i>
              <h3 style="margin: 0;">{t(locale, 'scorerCoursesPptDe')}</h3>
            </div>
            <p style="color: var(--text-secondary); flex: 1;">{t(locale, 'scorerCoursesPptDeDesc')}</p>
            <a href="https://www.volleyball.ch/fileadmin/user_upload/Documents/07_Schiri___Schreiber/Schreiber/Schreiberkurs_DE.pptx" target="_blank" rel="noopener noreferrer" class="btn btn-blue" style="align-self: flex-start;">
              <i data-lucide="download" style="width: 16px; height: 16px; vertical-align: middle; margin-right: 6px;"></i>
              <span>{t(locale, 'scorerCoursesDownload')}</span>
            </a>
          </div>
        </div>

        <div class="card">
          <div class="card-body" style="display: flex; flex-direction: column; gap: var(--space-md);">
            <div style="display: flex; align-items: center; gap: var(--space-sm);">
              <i data-lucide="presentation" style="width: 32px; height: 32px; color: var(--kscw-gold); flex-shrink: 0;"></i>
              <h3 style="margin: 0;">{t(locale, 'scorerCoursesPptEn')}</h3>
            </div>
            <p style="color: var(--text-secondary); flex: 1;">{t(locale, 'scorerCoursesPptEnDesc')}</p>
            <a href="https://www.volleyball.ch/fileadmin/user_upload/Documents/07_Schiri___Schreiber/Schreiber/Scorer_Course_EN.pptx" target="_blank" rel="noopener noreferrer" class="btn btn-blue" style="align-self: flex-start;">
              <i data-lucide="download" style="width: 16px; height: 16px; vertical-align: middle; margin-right: 6px;"></i>
              <span>{t(locale, 'scorerCoursesDownload')}</span>
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Swiss Volley Link -->
  <section class="section">
    <div class="container">
      <div style="max-width: 800px; text-align: center;">
        <p style="font-size: 1.125rem; line-height: 1.8; color: var(--text-secondary); margin-bottom: var(--space-lg);">
          {t(locale, 'scorerCoursesSwissVolley')}
        </p>
        <a href="https://www.volleyball.ch/ausbildung/schiedsrichter-schreiber/schreiber-ausbildung/" target="_blank" rel="noopener noreferrer" class="btn btn-gold" style="font-size: 1.125rem; padding: var(--space-md) var(--space-xl);">
          <i data-lucide="external-link" style="width: 20px; height: 20px; vertical-align: middle; margin-right: 8px;"></i>
          <span>{t(locale, 'scorerCoursesSwissVolleyLink')}</span>
        </a>
      </div>
    </div>
  </section>
</PageLayout>
