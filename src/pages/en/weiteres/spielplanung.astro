---
import PageLayout from '../../../layouts/PageLayout.astro';
import { t } from '../../../lib/i18n';

const locale = 'en';
---
<PageLayout
  title="Game Scheduling — KSC Wiedikon"
  description="KSC Wiedikon game scheduling — Plan and coordinate home games."
  locale={locale}
  pageTitle={t(locale, 'schedulingTitle')}
  pageSubtitle={t(locale, 'schedulingSubtitle')}
>
  <!-- Introduction -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>{t(locale, 'schedulingIntro')}</h2>
          <div class="gold-bar"></div>
        </div>
      </div>
      <div style="max-width: 720px;">
        <p style="font-size: 1.125rem; line-height: 1.8; color: var(--text-secondary); margin-bottom: var(--space-md);">
          {t(locale, 'schedulingIntroText1')}
        </p>
        <p style="font-size: 1.125rem; line-height: 1.8; color: var(--text-secondary); margin-bottom: var(--space-lg);">
          {t(locale, 'schedulingIntroText2')}
        </p>
      </div>
    </div>
  </section>

  <!-- Game Saturdays -->
  <section class="section-alt">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>{t(locale, 'schedulingSaturdays')}</h2>
          <div class="gold-bar"></div>
        </div>
      </div>
      <div style="max-width: 720px;">
        <p style="color: var(--text-secondary); margin-bottom: var(--space-lg);">
          {t(locale, 'schedulingSaturdaysText')}
        </p>
        <div class="grid grid-3" style="margin-bottom: var(--space-lg);">
          <div class="card" style="text-align: center; border-top: 4px solid var(--kscw-gold);">
            <div class="card-body">
              <i data-lucide="clock" style="width: 32px; height: 32px; color: var(--kscw-gold); margin-bottom: var(--space-sm);"></i>
              <h3 style="font-size: 1.5rem; margin-bottom: var(--space-xs);">11:00</h3>
              <p style="color: var(--text-secondary); font-size: 0.875rem;">{t(locale, 'schedulingMorning')}</p>
            </div>
          </div>
          <div class="card" style="text-align: center; border-top: 4px solid var(--kscw-blue);">
            <div class="card-body">
              <i data-lucide="clock" style="width: 32px; height: 32px; color: var(--kscw-blue); margin-bottom: var(--space-sm);"></i>
              <h3 style="font-size: 1.5rem; margin-bottom: var(--space-xs);">13:30</h3>
              <p style="color: var(--text-secondary); font-size: 0.875rem;">{t(locale, 'schedulingAfternoon')}</p>
            </div>
          </div>
          <div class="card" style="text-align: center; border-top: 4px solid var(--kscw-gold);">
            <div class="card-body">
              <i data-lucide="clock" style="width: 32px; height: 32px; color: var(--kscw-gold); margin-bottom: var(--space-sm);"></i>
              <h3 style="font-size: 1.5rem; margin-bottom: var(--space-xs);">16:00</h3>
              <p style="color: var(--text-secondary); font-size: 0.875rem;">{t(locale, 'schedulingLateAfternoon')}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- For Opponents -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>{t(locale, 'schedulingOpponents')}</h2>
          <div class="gold-bar"></div>
        </div>
      </div>
      <div style="max-width: 720px;">
        <p style="font-size: 1.125rem; line-height: 1.8; color: var(--text-secondary); margin-bottom: var(--space-md);">
          {t(locale, 'schedulingOpponentsText')}
        </p>
        <div style="background: var(--surface-alt); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: var(--space-lg); margin-bottom: var(--space-lg);">
          <h3 style="margin-bottom: var(--space-md);">
            <i data-lucide="list-checks" style="width: 20px; height: 20px; vertical-align: middle; margin-right: 8px; color: var(--kscw-blue);"></i>
            <span>{t(locale, 'schedulingHowItWorks')}</span>
          </h3>
          <ol style="color: var(--text-secondary); line-height: 1.8; padding-left: var(--space-lg); margin: 0;">
            <li>{t(locale, 'schedulingStep1')}</li>
            <li>{t(locale, 'schedulingStep2')}</li>
            <li>{t(locale, 'schedulingStep3')}</li>
            <li>{t(locale, 'schedulingStep4')}</li>
            <li>{t(locale, 'schedulingStep5')}</li>
          </ol>
        </div>
        <div style="text-align: center; margin-bottom: var(--space-xl);">
          <a href="https://kscw.lucanepa.com/terminplanung" class="btn btn-gold" style="font-size: 1.125rem; padding: var(--space-md) var(--space-xl);" target="_blank" rel="noopener noreferrer">
            <i data-lucide="calendar-plus" style="width: 20px; height: 20px; vertical-align: middle; margin-right: 8px;"></i>
            <span>{t(locale, 'schedulingGoTo')}</span>
          </a>
          <p style="margin-top: var(--space-sm); font-size: 0.875rem; color: var(--text-secondary);">
            {t(locale, 'schedulingAccessNote')}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Halls -->
  <section class="section-alt">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>{t(locale, 'schedulingHalls')}</h2>
          <div class="gold-bar"></div>
        </div>
      </div>
      <p style="color: var(--text-secondary); margin-bottom: var(--space-lg); max-width: 640px;">
        {t(locale, 'schedulingHallsText')}
      </p>
      <div class="grid grid-3">
        <div class="card" style="border-top: 4px solid var(--kscw-blue);">
          <div class="card-body">
            <div style="display: flex; align-items: center; gap: var(--space-sm); margin-bottom: var(--space-md);">
              <i data-lucide="building-2" style="width: 24px; height: 24px; color: var(--kscw-blue);"></i>
              <h3>Utogrund</h3>
            </div>
            <p style="color: var(--text-secondary); margin-bottom: var(--space-md);">Our main hall for volleyball and basketball. Two courts, spectator gallery, modern equipment.</p>
            <div style="display: flex; align-items: flex-start; gap: var(--space-xs); color: var(--text-secondary); font-size: 0.875rem;">
              <i data-lucide="map-pin" style="width: 16px; height: 16px; flex-shrink: 0; margin-top: 2px;"></i>
              <span>Utogrundstrasse 2<br>8045 Zurich</span>
            </div>
          </div>
        </div>
        <div class="card" style="border-top: 4px solid var(--kscw-gold);">
          <div class="card-body">
            <div style="display: flex; align-items: center; gap: var(--space-sm); margin-bottom: var(--space-md);">
              <i data-lucide="building-2" style="width: 24px; height: 24px; color: var(--kscw-gold);"></i>
              <h3>Lavater</h3>
            </div>
            <p style="color: var(--text-secondary); margin-bottom: var(--space-md);">Gym at the Lavater school. Primarily used for basketball training and individual home games.</p>
            <div style="display: flex; align-items: flex-start; gap: var(--space-xs); color: var(--text-secondary); font-size: 0.875rem;">
              <i data-lucide="map-pin" style="width: 16px; height: 16px; flex-shrink: 0; margin-top: 2px;"></i>
              <span>Lavaterstrasse 99<br>8002 Zurich</span>
            </div>
          </div>
        </div>
        <div class="card" style="border-top: 4px solid var(--kscw-blue);">
          <div class="card-body">
            <div style="display: flex; align-items: center; gap: var(--space-sm); margin-bottom: var(--space-md);">
              <i data-lucide="building-2" style="width: 24px; height: 24px; color: var(--kscw-blue);"></i>
              <h3>Sihlfeld</h3>
            </div>
            <p style="color: var(--text-secondary); margin-bottom: var(--space-md);">Large triple gym at Sihlfeld school. Ideal for parallel training sessions and weekend tournaments.</p>
            <div style="display: flex; align-items: flex-start; gap: var(--space-xs); color: var(--text-secondary); font-size: 0.875rem;">
              <i data-lucide="map-pin" style="width: 16px; height: 16px; flex-shrink: 0; margin-top: 2px;"></i>
              <span>Sihlfeld Strasse 15<br>8003 Zurich</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
