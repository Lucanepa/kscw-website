---
// Root page: detect browser language and redirect to /de/ or /en/
---
<html lang="de">
<head>
  <meta charset="UTF-8">
  <title>KSC Wiedikon</title>
  <script is:inline>
    // Root defaults to /de/. Only honor an explicit prior choice (set when
    // the user clicked EN/DE in the header) to avoid breaking the default
    // German experience for first-time visitors with English browsers.
    (function() {
      var pref = null;
      try { pref = localStorage.getItem('kscw-locale'); } catch (e) {}
      var locale = pref === 'en' ? 'en' : 'de';
      window.location.replace('/' + locale + '/');
    })();
  </script>
  <meta http-equiv="refresh" content="0;url=/de/">
</head>
<body>
  <p>Redirecting...</p>
</body>
</html>
